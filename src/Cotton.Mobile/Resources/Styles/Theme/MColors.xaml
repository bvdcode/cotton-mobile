<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="M3Accent">#C6FF00</Color>
    <Color x:Key="M3OnAccent">#151900</Color>
    <Color x:Key="M3DocumentSurface">#FFFFFF</Color>
    <Color x:Key="M3Transparent">Transparent</Color>

    <Color x:Key="M3LightSurface">#F8FAF7</Color>
    <Color x:Key="M3LightOnSurface">#171D18</Color>
    <Color x:Key="M3LightOnSurfaceVariant">#424A42</Color>
    <Color x:Key="M3LightSurfaceContainerLowest">#FFFFFF</Color>
    <Color x:Key="M3LightSurfaceContainerLow">#F1F4F0</Color>
    <Color x:Key="M3LightSurfaceContainer">#E9EDE7</Color>
    <Color x:Key="M3LightSurfaceContainerHigh">#E1E7DF</Color>
    <Color x:Key="M3LightSurfaceContainerHighest">#D9E0D8</Color>
    <Color x:Key="M3LightOutline">#737B73</Color>
    <Color x:Key="M3LightOutlineVariant">#C0C8BF</Color>
    <Color x:Key="M3LightError">#BA1A1A</Color>

    <Color x:Key="M3DarkSurface">#0A0F0C</Color>
    <Color x:Key="M3DarkOnSurface">#E4ECE3</Color>
    <Color x:Key="M3DarkOnSurfaceVariant">#BEC8BD</Color>
    <Color x:Key="M3DarkSurfaceContainerLowest">#050806</Color>
    <Color x:Key="M3DarkSurfaceContainerLow">#111711</Color>
    <Color x:Key="M3DarkSurfaceContainer">#171E17</Color>
    <Color x:Key="M3DarkSurfaceContainerHigh">#202820</Color>
    <Color x:Key="M3DarkSurfaceContainerHighest">#2B342A</Color>
    <Color x:Key="M3DarkOutline">#899389</Color>
    <Color x:Key="M3DarkOutlineVariant">#3E493E</Color>
    <Color x:Key="M3DarkError">#FFB4AB</Color>

    <SolidColorBrush x:Key="M3AccentBrush" Color="{StaticResource M3Accent}" />
</ResourceDictionary>
