<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:Cotton.Mobile.Behaviors"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.RecentFilesPage"
             x:Name="RecentFilesRoot"
             x:DataType="viewModels:RecentFilesViewModel"
             Shell.NavBarIsVisible="False"
             Title="Recent files">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar PrimaryIconData="{x:Static controls:IconPathData.Delete}"
                            PrimaryCommand="{Binding ClearRecentFilesCommand}"
                            PrimaryDescription="Clear recent files"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh recent files" />

        <Grid Grid.Row="1"
              RowDefinitions="Auto,Auto,*"
              Style="{StaticResource M3ScreenContentGrid}">
        <Grid ColumnDefinitions="*,Auto"
              Style="{StaticResource M3ScreenHeaderGrid}">
            <VerticalStackLayout Style="{StaticResource M3ScreenHeaderTextStack}">
                <Label Text="Recent files"
                       Style="{StaticResource M3ScreenTitle}" />

                <Label Text="{Binding SummaryText}"
                       Style="{StaticResource M3ScreenHeaderSupporting}" />
            </VerticalStackLayout>

            <ActivityIndicator Grid.Column="1"
                               IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Style="{StaticResource M3ScreenHeaderActivityIndicator}" />
        </Grid>

        <Label Grid.Row="1"
               Text="{Binding Status}"
               IsVisible="{Binding IsStatusVisible}"
               Style="{StaticResource M3ScreenStatus}" />

        <controls:MetadataListSkeletonView Grid.Row="2"
                                           IsVisible="{Binding IsLoadingPlaceholderVisible}"
                                           IsBodyLineVisible="False"
                                           Style="{StaticResource M3MetadataListSkeletonView}" />

        <Border Grid.Row="2"
                IsVisible="{Binding IsEmpty}"
                Style="{StaticResource M3EmptyStateCard}">
            <VerticalStackLayout Style="{StaticResource M3EmptyStateStack}">
                <Border Style="{StaticResource M3EmptyStateIconFrame}">
                    <controls:IconView IconData="{x:Static controls:IconPathData.File}"
                                       Style="{StaticResource M3EmptyStateIcon}" />
                </Border>

                <Label Text="{Binding EmptyMessage}"
                       Style="{StaticResource M3EmptyTitle}" />

                <Label Text="{Binding EmptyDetails}"
                       Style="{StaticResource M3EmptyBody}" />
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Items}"
                        IsVisible="{Binding IsListVisible}"
                        SelectionMode="None"
                        ItemSizingStrategy="MeasureFirstItem"
                        ItemsLayout="{StaticResource M3VerticalCardListItemsLayout}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="services:CottonRecentFileListItem">
                    <Border Style="{StaticResource M3ContentCard}">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              Style="{StaticResource M3SecondaryFileListItemGrid}">
                            <controls:IconFrame IconData="{x:Static controls:IconPathData.File}"
                                                Style="{StaticResource M3FileThumbnailFrame}" />

                            <VerticalStackLayout Grid.Column="1"
                                                 Style="{StaticResource M3SecondaryFileListTextStack}">
                                <Label Text="{Binding FileName}"
                                       Style="{StaticResource M3CardTitle}" />

                                <Label Text="{Binding DetailText}"
                                       Style="{StaticResource M3CardSupportingLine}" />
                            </VerticalStackLayout>

                            <HorizontalStackLayout Grid.Column="2"
                                                   Style="{StaticResource M3RowActionCluster}">
                                <Border Style="{StaticResource M3RowActionChip}">
                                    <Label Text="{Binding BadgeText}"
                                           Style="{StaticResource M3ChipLabel}" />
                                </Border>

                                <controls:IconButton IconData="{x:Static controls:IconPathData.Delete}"
                                                     Style="{StaticResource M3FileChromeIconButton}"
                                                     Command="{Binding BindingContext.RemoveRecentFileCommand, Source={x:Reference RecentFilesRoot}}"
                                                     CommandParameter="{Binding .}"
                                                     SemanticProperties.Description="Remove recent file" />
                            </HorizontalStackLayout>

                            <Grid Grid.ColumnSpan="2"
                                  Style="{StaticResource M3ListItemTouchSurface}">
                                <Grid.Behaviors>
                                    <behaviors:LongPressBehavior TapCommand="{Binding BindingContext.OpenRecentFileCommand, Source={x:Reference RecentFilesRoot}}"
                                                                 TapCommandParameter="{Binding .}" />
                                </Grid.Behaviors>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
