<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.CaptureDestinationPickerPage"
             x:DataType="viewModels:CaptureDestinationPickerViewModel"
             Shell.NavBarIsVisible="False"
             Title="Choose Destination">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh destinations" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Padding="{StaticResource M3ScreenPadding}"
                             Spacing="{StaticResource Space16}">
            <Grid ColumnDefinitions="*,Auto"
                  Style="{StaticResource M3ScreenHeaderGrid}">
                <VerticalStackLayout Style="{StaticResource M3ScreenHeaderTextStack}">
                    <Label Text="{Binding CurrentFolderName}"
                           Style="{StaticResource M3ScreenTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Text="{Binding PathText}"
                           IsVisible="{Binding IsPathTextVisible}"
                           Style="{StaticResource M3BodyMedium}"
                           MaxLines="2"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   Style="{StaticResource M3BodyMedium}"
                   MaxLines="2"
                   LineBreakMode="TailTruncation" />

            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="{StaticResource Space12}">
                <controls:IconButton IconData="{x:Static controls:IconPathData.ArrowUp}"
                                     Command="{Binding UpCommand}"
                                     Style="{StaticResource M3FileChromeIconButton}"
                                     VerticalOptions="Center"
                                     SemanticProperties.Description="Up" />

                <Button Grid.Column="1"
                        Text="Choose this folder"
                        Command="{Binding ChooseCommand}"
                        Style="{StaticResource M3PrimaryButton}"
                        VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding SummaryText}"
                   Style="{StaticResource M3BodyMedium}"
                   MaxLines="1"
                   LineBreakMode="TailTruncation" />

            <Border IsVisible="{Binding IsEmpty}"
                    Style="{StaticResource M3EmptyStateCard}">
                <VerticalStackLayout Style="{StaticResource M3EmptyStateStack}">
                    <Label Text="No folders here"
                           Style="{StaticResource M3EmptyTitle}"
                           HorizontalTextAlignment="Center" />

                    <Label Text="Choose this folder or go back."
                           Style="{StaticResource M3CardSupporting}"
                           MaxLines="2"
                           LineBreakMode="WordWrap"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="{StaticResource Space12}"
                                 IsVisible="{Binding IsListVisible}"
                                 BindableLayout.ItemsSource="{Binding Folders}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:CaptureDestinationFolderItemViewModel">
                        <Border Style="{StaticResource M3ContentCard}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenCommand}" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="{StaticResource Space12}">
                                <Label Text="{Binding DisplayName}"
                                       Style="{StaticResource M3CardTitle}"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation"
                                       VerticalOptions="Center" />

                                <controls:IconButton Grid.Column="1"
                                                     IconData="{x:Static controls:IconPathData.ChevronRight}"
                                                     Command="{Binding OpenCommand}"
                                                     Style="{StaticResource M3FileChromeIconButton}"
                                                     VerticalOptions="Center"
                                                     SemanticProperties.Description="{Binding DisplayName, StringFormat='Open {0}'}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
