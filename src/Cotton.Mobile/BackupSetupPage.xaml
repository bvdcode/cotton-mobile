<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.BackupSetupPage"
             x:DataType="viewModels:BackupSetupViewModel"
             Shell.NavBarIsVisible="False"
             Title="Camera Backup">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Save}"
                            SecondaryCommand="{Binding SaveCommand}"
                            SecondaryDescription="Save camera backup" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Padding="{StaticResource M3ScreenPadding}"
                             Spacing="16">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="3">
                    <Label Text="Camera Backup"
                           Style="{StaticResource M3ScreenTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Text="{Binding ExecutionStatusText}"
                           Style="{StaticResource M3BodyMedium}"
                           MaxLines="2"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   Style="{StaticResource M3BodyMedium}"
                   MaxLines="2"
                   LineBreakMode="TailTruncation" />

            <Border Style="{StaticResource M3ContentCard}">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="8"
                      ColumnSpacing="12">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Destination"
                               Style="{StaticResource M3CardTitle}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />

                        <Label Text="{Binding DestinationText}"
                               Style="{StaticResource M3CardSupporting}"
                               MaxLines="2"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>

                    <Button Grid.Column="1"
                            Text="Choose"
                            Command="{Binding ChooseDestinationCommand}"
                            Style="{StaticResource PanelChromeButton}"
                            VerticalOptions="Center" />

                    <VerticalStackLayout Grid.Row="1"
                                         Grid.ColumnSpan="2"
                                         Spacing="2">
                        <Label Text="{Binding PolicySummaryText}"
                               Style="{StaticResource M3CardSupporting}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />

                        <Label Text="{Binding DestinationStorageEstimateTitle}"
                               Style="{StaticResource M3CardSupportingStrong}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />

                        <Label Text="{Binding DestinationStorageEstimateText}"
                               Style="{StaticResource M3CardSupporting}"
                               MaxLines="2"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="6"
                      ColumnSpacing="12">
                    <Label Text="{Binding MediaAccessTitle}"
                           Style="{StaticResource M3CardTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Grid.Column="1"
                           Text="{Binding MediaAccessStatusText}"
                           Style="{StaticResource M3CardSupporting}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           HorizontalTextAlignment="End" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding MediaAccessDetailText}"
                           Style="{StaticResource M3CardSupporting}"
                           MaxLines="2"
                           LineBreakMode="TailTruncation" />

                    <Button Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Text="{Binding MediaAccessActionText}"
                            IsVisible="{Binding IsMediaAccessActionVisible}"
                            Command="{Binding MediaAccessActionCommand}"
                            Style="{StaticResource PanelChromeButton}"
                            HorizontalOptions="Start" />
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                      RowSpacing="8">
                    <Label Text="{Binding HealthTitle}"
                           Style="{StaticResource M3CardTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Grid.Row="1"
                           Text="{Binding HealthCountsText}"
                           Style="{StaticResource M3CardSupportingStrong}"
                           MaxLines="2"
                           LineBreakMode="TailTruncation" />

                    <Label Grid.Row="2"
                           Text="{Binding HealthStatusText}"
                           Style="{StaticResource M3CardSupporting}"
                           MaxLines="2"
                           LineBreakMode="TailTruncation" />

                    <Button Grid.Row="3"
                            Text="Queue now"
                            Command="{Binding QueueNowCommand}"
                            Style="{StaticResource PanelChromeButton}"
                            HorizontalOptions="Start" />
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="12"
                      ColumnSpacing="12">
                    <Label Text="Backup running"
                           Style="{StaticResource M3CardTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Switch Grid.Column="1"
                            IsEnabled="{Binding CanEnableBackup}"
                            IsToggled="{Binding IsBackupEnabled, Mode=OneWay}" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding LocalMediaRetentionText}"
                           Style="{StaticResource M3CardSupporting}"
                           MaxLines="2"
                           LineBreakMode="TailTruncation" />

                    <Label Grid.Row="2"
                           Text="Photos only"
                           Style="{StaticResource M3LabelLarge}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Switch Grid.Row="2"
                            Grid.Column="1"
                            IsToggled="{Binding PhotosOnly, Mode=TwoWay}" />

                    <Label Grid.Row="3"
                           Text="While charging"
                           Style="{StaticResource M3LabelLarge}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Switch Grid.Row="3"
                            Grid.Column="1"
                            IsToggled="{Binding ChargingOnly, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <Grid RowDefinitions="Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="12"
                      ColumnSpacing="12">
                    <Label Text="Wi-Fi only"
                           Style="{StaticResource M3LabelLarge}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Switch Grid.Column="1"
                            IsToggled="{Binding WifiOnly, Mode=TwoWay}" />

                    <Label Grid.Row="1"
                           Text="Allow cellular"
                           Style="{StaticResource M3LabelLarge}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Switch Grid.Row="1"
                            Grid.Column="1"
                            IsToggled="{Binding AllowCellular, Mode=TwoWay}" />
                </Grid>
            </Border>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
