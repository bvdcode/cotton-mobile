<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.FileVersionHistoryPage"
             x:DataType="viewModels:FileVersionHistoryViewModel"
             Shell.NavBarIsVisible="False"
             Title="Version history">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh versions" />

        <Grid Grid.Row="1"
              RowDefinitions="Auto,Auto,*"
              Style="{StaticResource M3ScreenContentGrid}">
        <controls:ScreenHeaderView Title="Version history"
                                   SupportingText="{Binding FileName}"
                                   SupportingTextStyleResourceKey="M3CardTitle"
                                   DetailText="{Binding SummaryText}"
                                   DetailTextStyleResourceKey="M3ScreenHeaderSupportingMultiline"
                                   IsBusy="{Binding IsBusy}" />

        <controls:ScreenStatusView Grid.Row="1"
                                   Text="{Binding Status}"
                                   IsVisible="{Binding IsStatusVisible}" />

            <Grid Grid.Row="2">
                <controls:MetadataListSkeletonView IsVisible="{Binding IsLoadingPlaceholderVisible}"
                                                   Style="{StaticResource M3MetadataListSkeletonView}" />

                <controls:EmptyStateView IsVisible="{Binding IsEmpty}"
                                         IconData="{x:Static controls:IconPathData.File}"
                                         Title="{Binding EmptyMessage}"
                                         Body="{Binding EmptyDetails}" />

                <CollectionView ItemsSource="{Binding Items}"
                                IsVisible="{Binding IsListVisible}"
                                SelectionMode="None"
                                ItemsLayout="{StaticResource M3VerticalCardListItemsLayout}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="services:CottonFileVersionItemSnapshot">
                            <controls:MetadataCardView LeadingIconData="{x:Static controls:IconPathData.File}"
                                                       LeadingIconFrameStyleResourceKey="M3CardFileThumbnailFrame"
                                                       Title="{Binding VersionText}"
                                                       SupportingText="{Binding Name}"
                                                       TrailingText="{Binding KindText}">
                                <VerticalStackLayout Style="{StaticResource M3MetadataCardBodyStack}">
                                    <Label Text="{Binding DetailText}"
                                           Style="{StaticResource M3CardSupportingWrap}" />

                                    <Label Text="{Binding ContentTypeText}"
                                           Style="{StaticResource M3CardMetaLine}" />
                                </VerticalStackLayout>
                            </controls:MetadataCardView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
