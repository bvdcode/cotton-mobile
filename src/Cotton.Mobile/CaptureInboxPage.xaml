<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.CaptureInboxPage"
             x:DataType="viewModels:CaptureInboxViewModel"
             Shell.NavBarIsVisible="False"
             Title="Capture Inbox">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar PrimaryIconData="{x:Static controls:IconPathData.Delete}"
                            PrimaryCommand="{Binding ClearCommand}"
                            PrimaryDescription="Clear capture inbox"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh capture inbox" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Style="{StaticResource M3ScreenContentStack}">
            <Grid ColumnDefinitions="*,Auto"
                  Style="{StaticResource M3ScreenHeaderGrid}">
                <VerticalStackLayout Style="{StaticResource M3ScreenHeaderTextStack}">
                    <Label Text="{Binding SummaryText}"
                           Style="{StaticResource M3ScreenTitle}" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Style="{StaticResource M3ScreenHeaderActivityIndicator}" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   Style="{StaticResource M3ScreenStatus}" />

            <Grid ColumnDefinitions="Auto,Auto,Auto,*"
                  ColumnSpacing="{StaticResource Space12}"
                  IsVisible="{Binding IsActionBarVisible}">
                <controls:IconButton IconData="{x:Static controls:IconPathData.Folder}"
                                     Command="{Binding DestinationCommand}"
                                     Style="{StaticResource M3FileChromeIconButton}"
                                     SemanticProperties.Description="Choose destination" />

                <controls:IconButton Grid.Column="1"
                                     IconData="{x:Static controls:IconPathData.Edit}"
                                     Command="{Binding RenameCommand}"
                                     Style="{StaticResource M3FileChromeIconButton}"
                                     SemanticProperties.Description="Rename capture item" />

                <controls:IconButton Grid.Column="2"
                                     IconData="{x:Static controls:IconPathData.Transfer}"
                                     Command="{Binding EnqueueCommand}"
                                     Style="{StaticResource M3PrimaryFileChromeIconButton}"
                                     SemanticProperties.Description="Queue captured items" />
            </Grid>

            <Border IsVisible="{Binding IsEmpty}"
                    Style="{StaticResource M3EmptyStateCard}">
                <VerticalStackLayout Style="{StaticResource M3EmptyStateStack}">
                    <Border Style="{StaticResource M3EmptyStateIconFrame}">
                        <controls:IconView IconData="{x:Static controls:IconPathData.Transfer}"
                                           Style="{StaticResource M3EmptyStateIcon}" />
                    </Border>

                    <Label Text="{Binding EmptyMessage}"
                           Style="{StaticResource M3EmptyTitle}" />

                    <Label Text="{Binding EmptyDetails}"
                           Style="{StaticResource M3EmptyBody}" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Style="{StaticResource M3SettingsSectionStack}"
                                 IsVisible="{Binding IsListVisible}"
                                 BindableLayout.ItemsSource="{Binding Items}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonCaptureInboxListItem">
                        <Border Style="{StaticResource M3ContentCard}">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                  ColumnDefinitions="Auto,*,Auto"
                                  Style="{StaticResource M3MetadataCardGrid}">
                                <controls:IconFrame Grid.RowSpan="4"
                                                    IconData="{x:Static controls:IconPathData.Transfer}"
                                                    Style="{StaticResource M3CaptureThumbnailFrame}"
                                                    VerticalOptions="Start" />

                                <VerticalStackLayout Grid.Column="1"
                                                     Style="{StaticResource M3CardTextStack}">
                                    <Label Text="{Binding DisplayName}"
                                           Style="{StaticResource M3CardTitle}" />

                                    <Label Text="{Binding DetailText}"
                                           Style="{StaticResource M3CardSupportingLine}" />
                                </VerticalStackLayout>

                                <Border Grid.Column="2"
                                        Style="{StaticResource M3NeutralChip}">
                                    <Label Text="{Binding StatusText}"
                                           Style="{StaticResource M3ChipLabel}" />
                                </Border>

                                <Grid Grid.Row="1"
                                      Grid.Column="1"
                                      Grid.ColumnSpan="2"
                                      ColumnDefinitions="Auto,*"
                                      ColumnSpacing="{StaticResource Space8}">
                                    <Label Text="{Binding KindText}"
                                           Style="{StaticResource M3CardSupportingStrongLine}" />

                                    <Label Grid.Column="1"
                                           Text="{Binding MetadataText}"
                                           Style="{StaticResource M3CardSupportingLine}" />
                                </Grid>

                                <Label Grid.Row="2"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding DestinationText}"
                                       IsVisible="{Binding IsDestinationVisible}"
                                       Style="{StaticResource M3CardSupportingStrongWrap}" />

                                <Label Grid.Row="3"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding FailureMessage}"
                                       IsVisible="{Binding IsFailureVisible}"
                                       Style="{StaticResource M3ErrorSupportingWrap}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
