<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.BackupSetupPage"
             x:DataType="viewModels:BackupSetupViewModel"
             Shell.NavBarIsVisible="False"
             Title="Camera Backup"
             BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">

    <Grid RowDefinitions="Auto,*"
          BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Save}"
                            SecondaryCommand="{Binding SaveCommand}"
                            SecondaryDescription="Save camera backup" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Padding="18"
                             Spacing="16">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="3">
                    <Label Text="Camera Backup"
                           Style="{StaticResource M3ScreenTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Text="{Binding ExecutionStatusText}"
                           FontSize="13"
                           MaxLines="2"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   FontSize="13"
                   MaxLines="2"
                   LineBreakMode="TailTruncation"
                   TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

            <Border Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                    StrokeShape="RoundRectangle 18"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="8"
                      ColumnSpacing="12">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Destination"
                               FontSize="15"
                               FontAttributes="Bold"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                        <Label Text="{Binding DestinationText}"
                               FontSize="13"
                               MaxLines="2"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                    </VerticalStackLayout>

                    <Button Grid.Column="1"
                            Text="Choose"
                            Command="{Binding ChooseDestinationCommand}"
                            Style="{StaticResource FileChromeButton}"
                            HeightRequest="40"
                            VerticalOptions="Center" />

                    <VerticalStackLayout Grid.Row="1"
                                         Grid.ColumnSpan="2"
                                         Spacing="2">
                        <Label Text="{Binding PolicySummaryText}"
                               FontSize="12"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                        <Label Text="{Binding DestinationStorageEstimateTitle}"
                               FontSize="12"
                               FontAttributes="Bold"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                        <Label Text="{Binding DestinationStorageEstimateText}"
                               FontSize="12"
                               MaxLines="2"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Border Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                    StrokeShape="RoundRectangle 18"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="6"
                      ColumnSpacing="12">
                    <Label Text="{Binding MediaAccessTitle}"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Label Grid.Column="1"
                           Text="{Binding MediaAccessStatusText}"
                           FontSize="13"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           HorizontalTextAlignment="End"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding MediaAccessDetailText}"
                           FontSize="12"
                           MaxLines="2"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                    <Button Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Text="{Binding MediaAccessActionText}"
                            IsVisible="{Binding IsMediaAccessActionVisible}"
                            Command="{Binding MediaAccessActionCommand}"
                            Style="{StaticResource FileChromeButton}"
                            HeightRequest="40"
                            HorizontalOptions="Start" />
                </Grid>
            </Border>

            <Border Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                    StrokeShape="RoundRectangle 18"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                      RowSpacing="8">
                    <Label Text="{Binding HealthTitle}"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Label Grid.Row="1"
                           Text="{Binding HealthCountsText}"
                           FontSize="13"
                           MaxLines="2"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Label Grid.Row="2"
                           Text="{Binding HealthStatusText}"
                           FontSize="12"
                           MaxLines="2"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                    <Button Grid.Row="3"
                            Text="Queue now"
                            Command="{Binding QueueNowCommand}"
                            Style="{StaticResource FileChromeButton}"
                            HeightRequest="40"
                            HorizontalOptions="Start" />
                </Grid>
            </Border>

            <Border Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                    StrokeShape="RoundRectangle 18"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="12"
                      ColumnSpacing="12">
                    <Label Text="Backup running"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Switch Grid.Column="1"
                            IsEnabled="{Binding CanEnableBackup}"
                            IsToggled="{Binding IsBackupEnabled, Mode=OneWay}" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding LocalMediaRetentionText}"
                           FontSize="12"
                           MaxLines="2"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                    <Label Grid.Row="2"
                           Text="Photos only"
                           FontSize="14"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Switch Grid.Row="2"
                            Grid.Column="1"
                            IsToggled="{Binding PhotosOnly, Mode=TwoWay}" />

                    <Label Grid.Row="3"
                           Text="While charging"
                           FontSize="14"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Switch Grid.Row="3"
                            Grid.Column="1"
                            IsToggled="{Binding ChargingOnly, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                    StrokeShape="RoundRectangle 18"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                <Grid RowDefinitions="Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="12"
                      ColumnSpacing="12">
                    <Label Text="Wi-Fi only"
                           FontSize="14"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Switch Grid.Column="1"
                            IsToggled="{Binding WifiOnly, Mode=TwoWay}" />

                    <Label Grid.Row="1"
                           Text="Allow cellular"
                           FontSize="14"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Switch Grid.Row="1"
                            Grid.Column="1"
                            IsToggled="{Binding AllowCellular, Mode=TwoWay}" />
                </Grid>
            </Border>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
