<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:Cotton.Mobile.Behaviors"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.NotificationSettingsPage"
             x:DataType="viewModels:NotificationSettingsViewModel"
             Shell.NavBarIsVisible="False"
             Title="Notifications">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh notifications" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Style="{StaticResource M3ScreenContentStack}">
            <Grid ColumnDefinitions="*,Auto"
                  Style="{StaticResource M3ScreenHeaderGrid}">
                <VerticalStackLayout Style="{StaticResource M3ScreenHeaderTextStack}">
                    <Label Text="Notifications"
                           Style="{StaticResource M3ScreenTitle}" />

                    <Label Text="{Binding EnabledCategoriesText}"
                           Style="{StaticResource M3ScreenHeaderSupporting}" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Style="{StaticResource M3ScreenHeaderActivityIndicator}" />
            </Grid>

            <Border IsVisible="{Binding IsAttentionStatusVisible}"
                    Style="{StaticResource M3AttentionStatusPanel}">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      Style="{StaticResource M3ActionListItemGrid}">
                    <controls:IconView IconData="{x:Static controls:IconPathData.Error}"
                                       Style="{StaticResource M3AttentionStatusIcon}"
                                       VerticalOptions="Center" />

                    <Label Grid.Column="1"
                           Text="{Binding Status}"
                           Style="{StaticResource M3LabelLargeBlock}"
                           VerticalOptions="Center" />

                    <Grid Grid.ColumnSpan="3"
                          Style="{StaticResource M3ListItemTouchSurface}">
                        <Grid.Behaviors>
                            <behaviors:LongPressBehavior TapCommand="{Binding LoadCommand}" />
                        </Grid.Behaviors>
                    </Grid>

                    <controls:IconButton Grid.Column="2"
                                         IconData="{x:Static controls:IconPathData.Refresh}"
                                         Command="{Binding LoadCommand}"
                                         Style="{StaticResource M3FileChromeIconButton}"
                                         SemanticProperties.Description="Retry notifications" />
                </Grid>
            </Border>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsNeutralStatusVisible}"
                   Style="{StaticResource M3ScreenStatus}" />

            <Border Style="{StaticResource M3ContentCard}">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      Style="{StaticResource M3SettingsSummaryGrid}">
                    <Label Text="{Binding PermissionTitle}"
                           Style="{StaticResource M3CardTitle}" />

                    <Label Grid.Column="1"
                           Text="{Binding PermissionStatusText}"
                           Style="{StaticResource M3CardTitle}" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding PermissionDetailText}"
                           Style="{StaticResource M3CardSupportingBlock}" />

                    <Grid Grid.Row="2"
                          Grid.ColumnSpan="2"
                          ColumnDefinitions="Auto,*,Auto"
                          IsVisible="{Binding IsPermissionActionVisible}"
                          Style="{StaticResource M3SettingsListItemGrid}">
                        <controls:IconFrame IconData="{x:Static controls:IconPathData.Activity}"
                                            Style="{StaticResource M3CardActivityThumbnailFrame}" />

                        <Label Grid.Column="1"
                               Text="{Binding PermissionActionText}"
                               Style="{StaticResource M3CardSupportingStrongLine}"
                               VerticalOptions="Center" />

                        <Grid Grid.ColumnSpan="3"
                              Style="{StaticResource M3ListItemTouchSurface}">
                            <Grid.Behaviors>
                                <behaviors:LongPressBehavior TapCommand="{Binding PermissionActionCommand}" />
                            </Grid.Behaviors>
                        </Grid>

                        <controls:IconButton Grid.Column="2"
                                             IconData="{x:Static controls:IconPathData.OpenInNew}"
                                             Command="{Binding PermissionActionCommand}"
                                             Style="{StaticResource M3PrimaryFileChromeIconButton}"
                                             SemanticProperties.Description="{Binding PermissionActionText}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <VerticalStackLayout Style="{StaticResource M3SettingsSectionStack}">
                    <Grid ColumnDefinitions="*,Auto"
                          Style="{StaticResource M3SettingsSummaryGrid}">
                        <Label Text="Server push"
                               Style="{StaticResource M3CardTitle}" />

                        <Label Grid.Column="1"
                               Text="{Binding RemotePushStatusText}"
                               IsVisible="{Binding IsRemotePushStatusVisible}"
                               Style="{StaticResource M3CardSupportingLine}" />
                    </Grid>

                    <Grid IsVisible="{Binding IsRemotePushUnavailable}"
                          ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto,Auto"
                          Style="{StaticResource M3SettingsSummaryGrid}">
                        <controls:IconView IconData="{x:Static controls:IconPathData.Error}"
                                           Style="{StaticResource M3AttentionStatusIcon}"
                                           VerticalOptions="Start" />

                        <Label Grid.Column="1"
                               Text="{Binding RemotePushUnavailableTitle}"
                               Style="{StaticResource M3CardTitle}" />

                        <Label Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="{Binding RemotePushUnavailableDetail}"
                               Style="{StaticResource M3CardSupportingBlock}" />

                        <Grid Grid.Row="2"
                              Grid.ColumnSpan="2"
                              ColumnDefinitions="*,Auto"
                              Style="{StaticResource M3SettingsListItemGrid}">
                            <Label Text="Retry server push"
                                   Style="{StaticResource M3CardSupportingStrongLine}"
                                   VerticalOptions="Center" />

                            <Grid Grid.ColumnSpan="2"
                                  Style="{StaticResource M3ListItemTouchSurface}">
                                <Grid.Behaviors>
                                    <behaviors:LongPressBehavior TapCommand="{Binding LoadCommand}" />
                                </Grid.Behaviors>
                            </Grid>

                            <controls:IconButton Grid.Column="1"
                                                 IconData="{x:Static controls:IconPathData.Refresh}"
                                                 Command="{Binding LoadCommand}"
                                                 Style="{StaticResource M3FileChromeIconButton}"
                                                 SemanticProperties.Description="Retry server push" />
                        </Grid>
                    </Grid>

                    <VerticalStackLayout Style="{StaticResource M3SettingsSectionStack}"
                                         IsVisible="{Binding HasRemotePushPreferences}"
                                         BindableLayout.ItemsSource="{Binding RemotePushPreferences}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:RemotePushPreferenceItemViewModel">
                                <Grid ColumnDefinitions="*,Auto"
                                      Style="{StaticResource M3SettingsSummaryGrid}">
                                    <VerticalStackLayout Style="{StaticResource M3CardTextStack}">
                                        <Label Text="{Binding Title}"
                                               Style="{StaticResource M3LabelLargeLine}" />

                                        <Label Text="{Binding DetailText}"
                                               Style="{StaticResource M3CardSupportingBlock}" />
                                    </VerticalStackLayout>

                                    <controls:ToggleSwitch Grid.Column="1"
                                                           IsEnabled="{Binding CanToggle}"
                                                           IsToggled="{Binding IsEnabled, Mode=TwoWay}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
