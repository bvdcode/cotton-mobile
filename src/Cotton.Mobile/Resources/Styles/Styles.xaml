    <Style TargetType="Button" x:Key="PanelDestructiveChromeButton" BasedOn="{StaticResource PanelChromeButton}">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightError}, Dark={StaticResource M3DarkError}}" />
        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource M3LightError}, Dark={StaticResource M3DarkError}}" />
    </Style>

    <Style TargetType="Button" x:Key="DenseChromeButton" BasedOn="{StaticResource CompactChromeButton}">
        <Setter Property="HeightRequest" Value="36" />
        <Setter Property="MinimumHeightRequest" Value="36" />
    </Style>

    <Style TargetType="Button" x:Key="DenseDestructiveChromeButton" BasedOn="{StaticResource DenseChromeButton}">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightError}, Dark={StaticResource M3DarkError}}" />
        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource M3LightError}, Dark={StaticResource M3DarkError}}" />
    </Style>

