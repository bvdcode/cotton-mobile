<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.PdfViewerPage"
             x:DataType="viewModels:PdfViewerViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource M3DarkSurface}">

    <Grid RowDefinitions="Auto,*"
          BackgroundColor="{StaticResource M3DarkSurface}">
        <controls:TopAppBar TitleText="{Binding Title}"
                                  UseDarkTheme="True"
                                  PrimaryIconData="{x:Static controls:IconPathData.Share}"
                                  PrimaryCommand="{Binding ShareCommand}"
                                  PrimaryDescription="Share PDF"
                                  SecondaryIconData="{x:Static controls:IconPathData.OpenInNew}"
                                  SecondaryCommand="{Binding OpenExternallyCommand}"
                                  SecondaryDescription="Open PDF" />

        <Grid Grid.Row="1"
              RowDefinitions="Auto,*"
              BackgroundColor="{StaticResource M3DarkSurface}">
            <VerticalStackLayout Padding="16,12"
                                 Spacing="2">
                <Label Text="{Binding Details}"
                       Style="{StaticResource M3DarkSupporting}"
                       MaxLines="1"
                       LineBreakMode="TailTruncation" />

                <Label Text="{Binding Status}"
                       IsVisible="{Binding IsStatusVisible}"
                       Style="{StaticResource M3DarkSupporting}"
                       MaxLines="1"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Pages}"
                            IsVisible="{Binding IsPreviewVisible}"
                            BackgroundColor="{StaticResource M3DarkSurface}"
                            ItemSizingStrategy="MeasureAllItems">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical"
                                       ItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:PdfPreviewPageSnapshot">
                        <Grid Padding="12,0">
                            <Border Stroke="{StaticResource M3DarkOutline}"
                                    StrokeThickness="1"
                                    BackgroundColor="{StaticResource White}"
                                    HorizontalOptions="Fill">
                                <Image Source="{Binding ImageSource}"
                                       Aspect="AspectFit"
                                       HeightRequest="{Binding DisplayHeight}"
                                       BackgroundColor="{StaticResource White}"
                                       HorizontalOptions="Fill" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid Grid.Row="1"
                  IsVisible="{Binding IsEmptyVisible}"
                  Padding="24">
                <Label Text="{Binding EmptyText}"
                       Style="{StaticResource M3DarkBodyMedium}"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
