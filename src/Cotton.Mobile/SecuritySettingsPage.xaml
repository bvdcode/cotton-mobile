<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:Cotton.Mobile.Behaviors"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.SecuritySettingsPage"
             x:DataType="viewModels:SecuritySettingsViewModel"
             Shell.NavBarIsVisible="False"
             Title="Security">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh security" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Style="{StaticResource M3ScreenContentStack}">
            <Grid ColumnDefinitions="*,Auto"
                  Style="{StaticResource M3ScreenHeaderGrid}">
                <VerticalStackLayout Style="{StaticResource M3ScreenHeaderTextStack}">
                    <Label Text="Security"
                           Style="{StaticResource M3ScreenTitle}" />

                    <Label Text="{Binding SummaryText}"
                           Style="{StaticResource M3ScreenHeaderSupporting}" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Style="{StaticResource M3ScreenHeaderActivityIndicator}" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   Style="{StaticResource M3ScreenStatus}" />

            <Border Style="{StaticResource M3ContentCard}">
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto,Auto"
                      Style="{StaticResource M3SettingsSummaryGrid}">
                    <Label Text="{Binding AppLockTitle}"
                           Style="{StaticResource M3CardTitle}" />

                    <Label Grid.Column="1"
                           Text="{Binding AppLockStatusText}"
                           Style="{StaticResource M3CardSupportingLine}" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding AppLockDetailText}"
                           Style="{StaticResource M3CardSupportingBlock}" />

                    <controls:ToggleSwitch Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           HorizontalOptions="End"
                                           VerticalOptions="Center"
                                           IsEnabled="{Binding CanToggleAppLock}"
                                           IsToggled="{Binding IsAppLockEnabled, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto,Auto"
                      Style="{StaticResource M3SettingsSummaryGrid}">
                    <Label Text="{Binding DeviceUnlockTitle}"
                           Style="{StaticResource M3CardTitle}" />

                    <Label Grid.Column="1"
                           Text="{Binding DeviceUnlockStatusText}"
                           Style="{StaticResource M3CardSupportingLine}" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding DeviceUnlockDetailText}"
                           Style="{StaticResource M3CardSupportingBlock}" />

                    <Grid Grid.Row="2"
                          Grid.ColumnSpan="2"
                          ColumnDefinitions="Auto,*,Auto"
                          IsVisible="{Binding IsDeviceUnlockActionVisible}"
                          Style="{StaticResource M3SettingsListItemGrid}">
                        <controls:IconFrame IconData="{x:Static controls:IconPathData.Device}"
                                            Style="{StaticResource M3SecurityThumbnailFrame}"
                                            VerticalOptions="Start" />

                        <Label Grid.Column="1"
                               Text="{Binding DeviceUnlockActionText}"
                               Style="{StaticResource M3CardSupportingStrongLine}"
                               VerticalOptions="Center" />

                        <Grid Grid.ColumnSpan="3"
                              IsEnabled="{Binding CanVerifyDeviceUnlock}"
                              Style="{StaticResource M3ListItemTouchSurface}">
                            <Grid.Behaviors>
                                <behaviors:LongPressBehavior TapCommand="{Binding VerifyDeviceUnlockCommand}" />
                            </Grid.Behaviors>
                        </Grid>

                        <controls:IconButton Grid.Column="2"
                                             IconData="{x:Static controls:IconPathData.Check}"
                                             Command="{Binding VerifyDeviceUnlockCommand}"
                                             IsEnabled="{Binding CanVerifyDeviceUnlock}"
                                             Style="{StaticResource M3PrimaryFileChromeIconButton}"
                                             SemanticProperties.Description="{Binding DeviceUnlockActionText}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}"
                    IsVisible="{Binding IsPermissionLedgerVisible}">
                <VerticalStackLayout Style="{StaticResource M3SettingsSectionStack}">
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto"
                          Style="{StaticResource M3SettingsSummaryGrid}">
                        <Label Text="{Binding PermissionLedgerTitle}"
                               Style="{StaticResource M3CardTitle}" />

                        <Label Grid.Column="1"
                               Text="{Binding PermissionLedgerStatusText}"
                               Style="{StaticResource M3CardSupportingLine}" />

                        <Label Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="{Binding PermissionLedgerDetailText}"
                               Style="{StaticResource M3CardSupportingBlock}" />
                    </Grid>

                    <VerticalStackLayout Style="{StaticResource M3SettingsSectionStack}"
                                         BindableLayout.ItemsSource="{Binding PermissionLedgerItems}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="services:CottonPermissionLedgerItem">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      RowDefinitions="Auto,Auto"
                                      Style="{StaticResource M3SettingsListItemGrid}">
                                    <controls:IconFrame Grid.RowSpan="2"
                                                        IconData="{x:Static controls:IconPathData.Check}"
                                                        Style="{StaticResource M3SecurityThumbnailFrame}"
                                                        VerticalOptions="Start">
                                        <controls:IconFrame.Triggers>
                                            <DataTrigger TargetType="controls:IconFrame"
                                                         Binding="{Binding NeedsAttention}"
                                                         Value="True">
                                                <Setter Property="IconData"
                                                        Value="{x:Static controls:IconPathData.Error}" />
                                                <Setter Property="IconColor"
                                                        Value="{AppThemeBinding Light={StaticResource M3LightError}, Dark={StaticResource M3DarkError}}" />
                                            </DataTrigger>
                                        </controls:IconFrame.Triggers>
                                    </controls:IconFrame>

                                    <Label Grid.Column="1"
                                           Text="{Binding Title}"
                                           Style="{StaticResource M3CardSupportingStrongLine}" />

                                    <Border Grid.Column="2"
                                            Style="{StaticResource M3NeutralChip}"
                                            HorizontalOptions="End">
                                        <Label Text="{Binding StatusText}"
                                               Style="{StaticResource M3ChipLabel}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding NeedsAttention}"
                                                             Value="True">
                                                    <Setter Property="TextColor"
                                                            Value="{AppThemeBinding Light={StaticResource M3LightError}, Dark={StaticResource M3DarkError}}" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>

                                    <Label Grid.Row="1"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding DetailText}"
                                           Style="{StaticResource M3CardSupportingBlock}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <VerticalStackLayout Style="{StaticResource M3SettingsSectionStack}">
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto"
                          Style="{StaticResource M3SettingsSummaryGrid}">
                        <Label Text="{Binding AccountSessionsTitle}"
                               Style="{StaticResource M3CardTitle}" />

                        <Label Grid.Column="1"
                               Text="{Binding AccountSessionsStatusText}"
                               Style="{StaticResource M3CardSupportingLine}" />

                        <Label Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="{Binding AccountSessionsDetailText}"
                               Style="{StaticResource M3CardSupportingBlock}" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*,Auto"
                          IsVisible="{Binding IsRevokeCurrentSessionVisible}"
                          Style="{StaticResource M3SettingsListItemGrid}">
                        <controls:IconFrame IconData="{x:Static controls:IconPathData.Device}"
                                            Style="{StaticResource M3SecurityThumbnailFrame}"
                                            VerticalOptions="Start" />

                        <Label Grid.Column="1"
                               Text="{Binding RevokeCurrentSessionActionText}"
                               Style="{StaticResource M3CardSupportingStrongLine}"
                               VerticalOptions="Center" />

                        <Grid Grid.ColumnSpan="3"
                              IsEnabled="{Binding CanRevokeCurrentSession}"
                              Style="{StaticResource M3ListItemTouchSurface}">
                            <Grid.Behaviors>
                                <behaviors:LongPressBehavior TapCommand="{Binding RevokeCurrentSessionCommand}" />
                            </Grid.Behaviors>
                        </Grid>

                        <controls:IconButton Grid.Column="2"
                                             IconData="{x:Static controls:IconPathData.Delete}"
                                             Command="{Binding RevokeCurrentSessionCommand}"
                                             IsEnabled="{Binding CanRevokeCurrentSession}"
                                             Style="{StaticResource M3DestructiveFileChromeIconButton}"
                                             SemanticProperties.Description="{Binding RevokeCurrentSessionActionText}" />
                    </Grid>

                    <VerticalStackLayout Style="{StaticResource M3SettingsDenseStack}"
                                         IsVisible="{Binding IsAccountSessionsEmptyVisible}">
                        <Label Text="{Binding AccountSessionsEmptyTitle}"
                               Style="{StaticResource M3CardSupportingStrongLine}" />

                        <Label Text="{Binding AccountSessionsEmptyDetails}"
                               Style="{StaticResource M3CardSupportingBlock}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Style="{StaticResource M3SettingsSectionStack}"
                                         IsVisible="{Binding IsAccountSessionsListVisible}"
                                         BindableLayout.ItemsSource="{Binding AccountSessions}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="services:CottonAccountSessionListItem">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      RowDefinitions="Auto,Auto,Auto,Auto"
                                      Style="{StaticResource M3SettingsListItemGrid}">
                                    <controls:IconFrame Grid.RowSpan="4"
                                                        IconData="{x:Static controls:IconPathData.Device}"
                                                        Style="{StaticResource M3SecurityThumbnailFrame}"
                                                        VerticalOptions="Start" />

                                    <Label Grid.Column="1"
                                           Text="{Binding Title}"
                                           Style="{StaticResource M3CardSupportingStrongLine}" />

                                    <Border Grid.Column="2"
                                            Style="{StaticResource M3NeutralChip}"
                                            HorizontalOptions="End">
                                        <Label Text="{Binding BadgeText}"
                                               Style="{StaticResource M3ChipLabel}" />
                                    </Border>

                                    <Label Grid.Row="1"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding DetailText}"
                                           Style="{StaticResource M3CardSupportingLine}" />

                                    <Label Grid.Row="2"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding AccessText}"
                                           Style="{StaticResource M3CardSupportingLine}" />

                                    <Label Grid.Row="3"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding DurationText}"
                                           Style="{StaticResource M3CardSupportingLine}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto,Auto"
                      Style="{StaticResource M3SettingsSummaryGrid}">
                    <Label Text="{Binding LogoutCacheCleanupTitle}"
                           Style="{StaticResource M3CardTitle}" />

                    <Label Grid.Column="1"
                           Text="{Binding LogoutCacheCleanupStatusText}"
                           Style="{StaticResource M3CardSupportingLine}" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding LogoutCacheCleanupDetailText}"
                           Style="{StaticResource M3CardSupportingBlock}" />

                    <controls:ToggleSwitch Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           HorizontalOptions="End"
                                           VerticalOptions="Center"
                                           IsEnabled="{Binding CanToggleLogoutCacheCleanup}"
                                           IsToggled="{Binding IsLogoutCacheCleanupEnabled, Mode=TwoWay}" />
                </Grid>
            </Border>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
