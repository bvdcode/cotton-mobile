<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.TextViewerPage"
             x:DataType="viewModels:TextViewerViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar TitleText="{Binding Title}"
                                  PrimaryIconData="{x:Static controls:IconPathData.Share}"
                                  PrimaryCommand="{Binding ShareCommand}"
                                  PrimaryDescription="Share text"
                                  SecondaryIconData="{x:Static controls:IconPathData.MoreVertical}"
                                  SecondaryCommand="{Binding MoreCommand}"
                                  SecondaryDescription="More text actions" />

        <Grid Grid.Row="1"
              RowDefinitions="Auto,*"
              Style="{StaticResource M3TextViewerContentGrid}">
            <controls:ViewerInfoHeaderView Details="{Binding Details}"
                                           Status="{Binding Status}"
                                           IsStatusVisible="{Binding IsStatusVisible}" />

            <controls:ContentCardView Grid.Row="1"
                                      CardStyleResourceKey="M3TextViewerSurface">
                <controls:TextDocumentContentView Text="{Binding Content}" />
            </controls:ContentCardView>
        </Grid>
    </Grid>
</ContentPage>
