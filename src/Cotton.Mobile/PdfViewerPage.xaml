<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.PdfViewerPage"
             x:DataType="viewModels:PdfViewerViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding Title}"
             Style="{StaticResource M3DocumentViewerPage}">

    <Grid RowDefinitions="Auto,*"
          Style="{StaticResource M3DocumentViewerSurface}">
        <controls:TopAppBar TitleText="{Binding Title}"
                            PrimaryIconData="{x:Static controls:IconPathData.Share}"
                            PrimaryCommand="{Binding ShareCommand}"
                            PrimaryDescription="Share PDF"
                            SecondaryIconData="{x:Static controls:IconPathData.OpenInNew}"
                            SecondaryCommand="{Binding OpenExternallyCommand}"
                            SecondaryDescription="Open PDF" />

        <Grid Grid.Row="1"
              RowDefinitions="Auto,*"
              Style="{StaticResource M3DocumentViewerSurface}">
            <VerticalStackLayout Style="{StaticResource M3PdfHeaderStack}">
                <Label Text="{Binding Details}"
                       Style="{StaticResource M3CardSupportingLine}" />

                <Label Text="{Binding Status}"
                       IsVisible="{Binding IsStatusVisible}"
                       Style="{StaticResource M3CardSupportingLine}" />
            </VerticalStackLayout>

            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Pages}"
                            IsVisible="{Binding IsPreviewVisible}"
                            Style="{StaticResource M3DocumentViewerCollection}"
                            ItemSizingStrategy="MeasureAllItems"
                            ItemsLayout="{StaticResource M3PdfPreviewItemsLayout}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:PdfPreviewPageSnapshot">
                        <Grid Style="{StaticResource M3PdfPageContainerGrid}">
                            <Border Style="{StaticResource M3PdfPageSurface}">
                                <Image Source="{Binding ImageSource}"
                                       HeightRequest="{Binding DisplayHeight}"
                                       Style="{StaticResource M3PdfPageImage}" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid Grid.Row="1"
                  IsVisible="{Binding IsEmptyVisible}"
                  Style="{StaticResource M3PdfEmptyStateLayer}">
                <Border Style="{StaticResource M3CenteredPdfEmptyStateCard}">
                    <VerticalStackLayout Style="{StaticResource M3EmptyStateStack}">
                        <Border Style="{StaticResource M3PdfEmptyStateIconFrame}">
                            <controls:IconView IconData="{x:Static controls:IconPathData.File}"
                                               Style="{StaticResource M3EmptyStateIcon}" />
                        </Border>

                        <Label Text="{Binding EmptyText}"
                               Style="{StaticResource M3EmptyTitle}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
