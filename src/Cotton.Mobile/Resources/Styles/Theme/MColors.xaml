<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="M3Accent">#C6FF00</Color>
    <Color x:Key="M3OnAccent">#151900</Color>
    <Color x:Key="M3Primary">#C6FF00</Color>
    <Color x:Key="M3OnPrimary">#151900</Color>
    <Color x:Key="M3DocumentSurface">#FFFFFF</Color>
    <Color x:Key="M3Transparent">Transparent</Color>
    <Color x:Key="M3Shadow">#000000</Color>

    <Color x:Key="M3LightPrimary">#4F6200</Color>
    <Color x:Key="M3LightPrimaryPressed">#405100</Color>
    <Color x:Key="M3LightOnPrimary">#FFFFFF</Color>
    <Color x:Key="M3LightPrimaryContainer">#DDE7B2</Color>
