<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.DiagnosticsPage"
             x:DataType="viewModels:DiagnosticsViewModel"
             Shell.NavBarIsVisible="False"
             Title="Diagnostics">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar PrimaryIconData="{x:Static controls:IconPathData.Copy}"
                            PrimaryCommand="{Binding CopyCommand}"
                            PrimaryDescription="Copy diagnostics"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh diagnostics" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Padding="18"
                             Spacing="16">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="{Binding HeaderTitleText}"
                           Style="{StaticResource M3ScreenTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Text="{Binding HeaderVersionText}"
                           Style="{StaticResource M3BodyMedium}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   Style="{StaticResource M3BodyMedium}"
                   MaxLines="2"
                   LineBreakMode="TailTruncation" />

            <VerticalStackLayout Spacing="16"
                                 BindableLayout.ItemsSource="{Binding Sections}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:DiagnosticsSectionViewModel">
                        <Border Style="{StaticResource M3SurfaceCard}"
                                Padding="16">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="{Binding Title}"
                                       Style="{StaticResource M3CardTitle}" />

                                <VerticalStackLayout Spacing="7"
                                                     BindableLayout.ItemsSource="{Binding Items}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="viewModels:DiagnosticsItemViewModel">
                                            <Grid ColumnDefinitions="96,*"
                                                  ColumnSpacing="12">
                                                <Label Text="{Binding Label}"
                                                       Style="{StaticResource M3CardSupporting}" />

                                                <Label Grid.Column="1"
                                                       Text="{Binding Value}"
                                                       Style="{StaticResource M3CardSupportingPrimary}"
                                                       MaxLines="2"
                                                       LineBreakMode="TailTruncation" />
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
