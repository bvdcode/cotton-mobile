<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.TextViewerPage"
             x:DataType="viewModels:TextViewerViewModel"
             Shell.NavBarIsVisible="True"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Share"
                     Command="{Binding ShareCommand}" />
        <ToolbarItem Text="More"
                     Command="{Binding MoreCommand}" />
    </ContentPage.ToolbarItems>

    <Grid Padding="18"
          RowDefinitions="Auto,*"
          RowSpacing="12">
        <VerticalStackLayout Spacing="2">
            <Label Text="{Binding Details}"
                   FontSize="12"
                   MaxLines="1"
                   LineBreakMode="TailTruncation"
                   TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   FontSize="12"
                   MaxLines="1"
                   LineBreakMode="TailTruncation"
                   TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
        </VerticalStackLayout>

        <Editor Grid.Row="1"
                Text="{Binding Content}"
                IsReadOnly="True"
                AutoSize="Disabled"
                FontSize="15"
                HorizontalOptions="Fill"
                VerticalOptions="Fill"
                TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}"
                BackgroundColor="Transparent" />
    </Grid>
</ContentPage>
