<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.NotificationSettingsPage"
             x:DataType="viewModels:NotificationSettingsViewModel"
             Shell.NavBarIsVisible="False"
             Title="Notifications">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh notifications" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Padding="{StaticResource M3ScreenPadding}"
                             Spacing="{StaticResource Space16}">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="{StaticResource Space12}">
                <VerticalStackLayout Spacing="{StaticResource Space2}">
                    <Label Text="Notifications"
                           Style="{StaticResource M3ScreenTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Text="{Binding EnabledCategoriesText}"
                           Style="{StaticResource M3BodyMedium}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </Grid>

            <Border IsVisible="{Binding IsAttentionStatusVisible}"
                    Style="{StaticResource M3AttentionStatusPanel}">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="{StaticResource Space12}">
                    <controls:IconView IconData="{x:Static controls:IconPathData.Error}"
                                       IconColor="{AppThemeBinding Light={StaticResource M3LightError}, Dark={StaticResource M3DarkError}}"
                                       IconSize="{StaticResource M3InlineStatusIconSize}"
                                       VerticalOptions="Center" />

                    <Label Grid.Column="1"
                           Text="{Binding Status}"
                           Style="{StaticResource M3LabelLarge}"
                           MaxLines="2"
                           LineBreakMode="TailTruncation"
                           VerticalOptions="Center" />

                    <Button Grid.Column="2"
                            Text="Retry"
                            Command="{Binding LoadCommand}"
                            Style="{StaticResource DenseChromeButton}"
                            MinimumWidthRequest="{StaticResource M3InlineStatusActionMinWidth}"
                            VerticalOptions="Center" />
                </Grid>
            </Border>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsNeutralStatusVisible}"
                   Style="{StaticResource M3BodyMedium}"
                   MaxLines="2"
                   LineBreakMode="TailTruncation" />

            <Border Style="{StaticResource M3ContentCard}">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="{StaticResource Space8}"
                      ColumnSpacing="{StaticResource Space12}">
                    <Label Text="{Binding PermissionTitle}"
                           Style="{StaticResource M3CardTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Grid.Column="1"
                           Text="{Binding PermissionStatusText}"
                           Style="{StaticResource M3CardTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding PermissionDetailText}"
                           Style="{StaticResource M3CardSupporting}"
                           MaxLines="2"
                           LineBreakMode="TailTruncation" />

                    <Button Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Text="{Binding PermissionActionText}"
                            Command="{Binding PermissionActionCommand}"
                            IsVisible="{Binding IsPermissionActionVisible}"
                            Style="{StaticResource FileChromeButton}"
                            HorizontalOptions="Fill" />
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <VerticalStackLayout Spacing="{StaticResource Space12}">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="{StaticResource Space12}">
                        <Label Text="Server push"
                               Style="{StaticResource M3CardTitle}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />

                        <Label Grid.Column="1"
                               Text="{Binding RemotePushStatusText}"
                               IsVisible="{Binding IsRemotePushStatusVisible}"
                               Style="{StaticResource M3CardSupporting}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />
                    </Grid>

                    <Grid IsVisible="{Binding IsRemotePushUnavailable}"
                          ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="{StaticResource Space12}"
                          RowSpacing="{StaticResource Space8}">
                        <controls:IconView IconData="{x:Static controls:IconPathData.Error}"
                                           IconColor="{AppThemeBinding Light={StaticResource M3LightError}, Dark={StaticResource M3DarkError}}"
                                           IconSize="{StaticResource M3InlineStatusIconSize}"
                                           VerticalOptions="Start" />

                        <Label Grid.Column="1"
                               Text="{Binding RemotePushUnavailableTitle}"
                               Style="{StaticResource M3CardTitle}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />

                        <Label Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="{Binding RemotePushUnavailableDetail}"
                               Style="{StaticResource M3CardSupporting}"
                               MaxLines="2"
                               LineBreakMode="TailTruncation" />

                        <Button Grid.Row="2"
                                Grid.ColumnSpan="2"
                                Text="Retry"
                                Command="{Binding LoadCommand}"
                                Style="{StaticResource PanelChromeButton}"
                                HorizontalOptions="Fill" />
                    </Grid>

                    <VerticalStackLayout Spacing="{StaticResource Space12}"
                                         IsVisible="{Binding HasRemotePushPreferences}"
                                         BindableLayout.ItemsSource="{Binding RemotePushPreferences}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:RemotePushPreferenceItemViewModel">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="{StaticResource Space12}">
                                    <VerticalStackLayout Spacing="{StaticResource Space2}">
                                        <Label Text="{Binding Title}"
                                               Style="{StaticResource M3LabelLarge}"
                                               MaxLines="1"
                                               LineBreakMode="TailTruncation" />

                                        <Label Text="{Binding DetailText}"
                                               Style="{StaticResource M3CardSupporting}"
                                               MaxLines="2"
                                               LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>

                                    <Switch Grid.Column="1"
                                            VerticalOptions="Center"
                                            IsEnabled="{Binding CanToggle}"
                                            IsToggled="{Binding IsEnabled, Mode=TwoWay}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
