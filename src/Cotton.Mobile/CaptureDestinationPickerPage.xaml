<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.CaptureDestinationPickerPage"
             x:DataType="viewModels:CaptureDestinationPickerViewModel"
             Shell.NavBarIsVisible="False"
             Title="Choose Destination">

    <controls:ScreenShellView>
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh destinations" />

        <controls:ScreenScrollBodyView Grid.Row="1">
            <controls:ScreenHeaderView Title="{Binding CurrentFolderName}"
                                       SupportingText="{Binding PathText}"
                                       IsSupportingTextVisible="{Binding IsPathTextVisible}"
                                       IsSupportingTextMultiline="True"
                                       IsBusy="{Binding IsBusy}" />

            <controls:ScreenStatusView Text="{Binding Status}"
                                       IsVisible="{Binding IsStatusVisible}" />

            <controls:SettingsActionHeaderCardView LeadingIconData="{x:Static controls:IconPathData.Folder}"
                                                   LeadingIconFrameStyleResourceKey="M3FolderThumbnailFrame"
                                                   Title="Current folder"
                                                   PrimaryDetailText="{Binding SummaryText}"
                                                   PrimaryActionIconData="{x:Static controls:IconPathData.ArrowUp}"
                                                   PrimaryActionCommand="{Binding UpCommand}"
                                                   PrimaryActionSemanticDescription="Go to parent folder"
                                                   SecondaryActionIconData="{x:Static controls:IconPathData.Check}"
                                                   SecondaryActionCommand="{Binding ChooseCommand}"
                                                   SecondaryActionIconButtonStyleResourceKey="M3PrimaryFileChromeIconButton"
                                                   SecondaryActionSemanticDescription="Choose current folder" />

            <controls:FileListSkeletonView IsVisible="{Binding IsLoadingPlaceholderVisible}"
                                           Style="{StaticResource M3FileListSkeletonView}" />

            <controls:EmptyStateView IsVisible="{Binding IsEmpty}"
                                     IconData="{x:Static controls:IconPathData.Folder}"
                                     Title="No subfolders here" />

            <controls:StackedItemsView IsVisible="{Binding IsListVisible}"
                                       ItemsSource="{Binding Folders}">
                <controls:StackedItemsView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:CaptureDestinationFolderItemViewModel">
                        <controls:ContentCardView>
                            <controls:ActionListItemView Text="{Binding DisplayName}"
                                                         LeadingIconData="{x:Static controls:IconPathData.Folder}"
                                                         IsLeadingIconVisible="True"
                                                         LeadingIconFrameStyleResourceKey="M3FolderThumbnailFrame"
                                                         ActionIconData="{x:Static controls:IconPathData.ChevronRight}"
                                                         Command="{Binding OpenCommand}"
                                                         GridStyleResourceKey="M3SettingsListItemGrid"
                                                         TextStyleResourceKey="M3SingleLineListItemTitle"
                                                         SemanticDescription="{Binding DisplayName, StringFormat='Open {0}'}" />
                        </controls:ContentCardView>
                    </DataTemplate>
                </controls:StackedItemsView.ItemTemplate>
            </controls:StackedItemsView>
        </controls:ScreenScrollBodyView>
    </controls:ScreenShellView>
</ContentPage>
