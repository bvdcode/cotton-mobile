<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.SyncSettingsPage"
             x:Name="SyncPageRoot"
             x:DataType="viewModels:SyncSettingsViewModel"
             Shell.NavBarIsVisible="True"
             Title="Sync"
             BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Run all"
                     Command="{Binding RunAllCommand}" />
        <ToolbarItem Text="Refresh"
                     Command="{Binding LoadCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="18"
                             Spacing="16">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Folders"
                           FontSize="28"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Label Text="{Binding SummaryText}"
                           IsVisible="{Binding IsSummaryVisible}"
                           FontSize="13"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   FontSize="13"
                   MaxLines="2"
                   LineBreakMode="TailTruncation"
                   TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

            <Border Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                    StrokeShape="RoundRectangle 18"
                    Padding="16"
                    IsVisible="{Binding IsEmptyVisible}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="No folders yet"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Label Text="Pick a folder in Files to enable sync."
                           FontSize="12"
                           MaxLines="2"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                    <Button Text="Choose folder"
                            Command="{Binding OpenFilesCommand}"
                            Margin="0,6,0,0"
                            HeightRequest="44" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="10"
                                 BindableLayout.ItemsSource="{Binding Roots}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonSyncRootListItem">
                        <Border Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                                StrokeShape="RoundRectangle 18"
                                Padding="16"
                                BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto,Auto,Auto"
                                  RowSpacing="4"
                                  ColumnSpacing="12">
                                <Label Text="{Binding Title}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation"
                                       TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                                <Label Grid.Column="1"
                                       Text="{Binding StatusText}"
                                       FontSize="12"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation"
                                       TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                                <Label Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding PathText}"
                                       FontSize="12"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation"
                                       TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                                <Label Grid.Row="2"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding DetailText}"
                                       FontSize="12"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation"
                                       TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                                <VerticalStackLayout Grid.Row="3"
                                                     Grid.ColumnSpan="2"
                                                     Spacing="8"
                                                     Margin="0,6,0,0">
                                    <Button Text="{Binding RunNowActionText}"
                                            Command="{Binding BindingContext.RunRootCommand, Source={x:Reference SyncPageRoot}}"
                                            CommandParameter="{Binding .}"
                                            IsEnabled="{Binding CanRunNow}"
                                            IsVisible="{Binding CanRunNow}"
                                            Style="{StaticResource FileChromeButton}"
                                            HeightRequest="40" />

                                    <Grid ColumnDefinitions="*,*"
                                          ColumnSpacing="8">
                                        <Button Text="{Binding PauseSyncActionText}"
                                                Command="{Binding BindingContext.PauseRootCommand, Source={x:Reference SyncPageRoot}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding CanPauseSync}"
                                                IsVisible="{Binding CanPauseSync}"
                                                Style="{StaticResource FileChromeButton}"
                                                HeightRequest="40" />

                                        <Button Text="{Binding ResumeSyncActionText}"
                                                Command="{Binding BindingContext.ResumeRootCommand, Source={x:Reference SyncPageRoot}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding CanResumeSync}"
                                                IsVisible="{Binding CanResumeSync}"
                                                Style="{StaticResource FileChromeButton}"
                                                HeightRequest="40" />

                                        <Button Grid.Column="1"
                                                Text="{Binding StopSyncActionText}"
                                                Command="{Binding BindingContext.StopRootCommand, Source={x:Reference SyncPageRoot}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding CanStopSync}"
                                                IsVisible="{Binding CanStopSync}"
                                                Style="{StaticResource DestructiveChromeButton}"
                                                HeightRequest="40" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
