<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.TrashPage"
             x:Name="TrashRoot"
             x:DataType="viewModels:TrashViewModel"
             Shell.NavBarIsVisible="False"
             Title="Trash">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar PrimaryIconData="{x:Static controls:IconPathData.Delete}"
                            PrimaryCommand="{Binding EmptyTrashCommand}"
                            PrimaryDescription="Empty trash"
                            SecondaryIconData="{x:Static controls:IconPathData.Check}"
                            SecondaryCommand="{Binding ToggleSelectionModeCommand}"
                            SecondaryDescription="{Binding SelectionToolbarText}"
                            IsTertiaryActionVisible="True"
                            TertiaryIconData="{x:Static controls:IconPathData.Refresh}"
                            TertiaryCommand="{Binding LoadCommand}"
                            TertiaryDescription="Refresh trash" />

        <Grid Grid.Row="1"
              Padding="16"
              RowDefinitions="Auto,Auto,Auto,Auto,*"
              RowSpacing="14">
        <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto"
              ColumnSpacing="8">
            <VerticalStackLayout Spacing="2">
                <Label Text="Trash"
                       Style="{StaticResource M3ScreenTitle}"
                       MaxLines="1"
                       LineBreakMode="TailTruncation" />

                <Label Text="{Binding SummaryText}"
                       Style="{StaticResource M3BodyMedium}"
                       MaxLines="1"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <Button Grid.Column="1"
                    Style="{StaticResource IconChromeButton}"
                    Text="{Binding SearchButtonText}"
                    Command="{Binding ToggleSearchCommand}"
                    VerticalOptions="Center"
                    SemanticProperties.Description="{Binding SearchButtonDescription}" />

            <Button Grid.Column="2"
                    Style="{StaticResource IconChromeButton}"
                    Text="{Binding SortButtonText}"
                    Command="{Binding ShowSortActionsCommand}"
                    IsVisible="{Binding IsSortButtonVisible}"
                    VerticalOptions="Center"
                    SemanticProperties.Description="Sort trash" />

            <Button Grid.Column="3"
                    Style="{StaticResource IconChromeButton}"
                    Text="{Binding ViewButtonText}"
                    Command="{Binding ShowViewActionsCommand}"
                    IsVisible="{Binding IsViewButtonVisible}"
                    VerticalOptions="Center"
                    SemanticProperties.Description="Change trash view" />

            <ActivityIndicator Grid.Column="4"
                               IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               VerticalOptions="Center" />
        </Grid>

        <SearchBar Grid.Row="1"
                   Text="{Binding SearchText, Mode=TwoWay}"
                   IsVisible="{Binding IsSearchVisible}"
                   Placeholder="Search trash" />

        <Label Grid.Row="2"
               Text="{Binding Status}"
               IsVisible="{Binding IsStatusVisible}"
               Style="{StaticResource M3BodyMedium}"
               MaxLines="2"
               LineBreakMode="TailTruncation" />

        <Border Grid.Row="3"
                IsVisible="{Binding IsSelectionBarVisible}"
                Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                StrokeShape="RoundRectangle 18"
                Padding="10,8"
                BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainer}, Dark={StaticResource M3DarkSurfaceContainer}}">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                  ColumnSpacing="8">
                <VerticalStackLayout Spacing="1"
                                     VerticalOptions="Center">
                    <Label Text="{Binding SelectionTitleText}"
                           Style="{StaticResource M3CardSupportingStrong}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Text="{Binding SelectionDetailText}"
                           Style="{StaticResource M3CardMeta}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Restore"
                        Command="{Binding RestoreSelectionCommand}"
                        IsEnabled="{Binding IsBulkActionEnabled}"
                        Style="{StaticResource DenseChromeButton}"
                        VerticalOptions="Center" />

                <Button Grid.Column="2"
                        Text="Delete forever"
                        Command="{Binding DeleteForeverSelectionCommand}"
                        IsEnabled="{Binding IsBulkActionEnabled}"
                        Style="{StaticResource DenseDestructiveChromeButton}"
                        VerticalOptions="Center" />

                <Button Grid.Column="3"
                        Text="Cancel"
                        Command="{Binding CancelSelectionCommand}"
                        Style="{StaticResource DenseChromeButton}"
                        VerticalOptions="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Border IsVisible="{Binding IsEmpty}"
                    Style="{StaticResource M3EmptyStateCard}">
                <VerticalStackLayout Spacing="8"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <Label Text="{Binding EmptyMessage}"
                           Style="{StaticResource M3EmptyTitle}"
                           HorizontalTextAlignment="Center" />

                    <Label Text="{Binding EmptyDetails}"
                           Style="{StaticResource M3CardSupporting}"
                           MaxLines="2"
                           LineBreakMode="WordWrap"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <CollectionView ItemsSource="{Binding Items}"
                            IsVisible="{Binding IsListVisible}"
                            SelectionMode="None"
                            ItemSizingStrategy="MeasureFirstItem">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical"
                                       ItemSpacing="10" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonFileBrowserEntry">
                        <Border Style="{StaticResource M3ContentCard}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsSelected}"
                                             Value="True">
                                    <Setter Property="Stroke"
                                            Value="{StaticResource M3Accent}" />
                                    <Setter Property="StrokeThickness"
                                            Value="1" />
                                    <Setter Property="BackgroundColor"
                                            Value="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerHigh}, Dark={StaticResource M3DarkSurfaceContainerHigh}}" />
                                </DataTrigger>
                            </Border.Triggers>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BindingContext.ToggleSelectionCommand, Source={x:Reference TrashRoot}}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid RowDefinitions="Auto,Auto"
                                  ColumnDefinitions="*,Auto"
                                  RowSpacing="8"
                                  ColumnSpacing="10">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Name}"
                                           Style="{StaticResource M3CardTitle}"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation" />

                                    <Label Text="{Binding DisplayDetails}"
                                           Style="{StaticResource M3CardSupporting}"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        Style="{StaticResource M3NeutralChip}">
                                    <Label Text="{Binding BadgeText}"
                                           Style="{StaticResource M3ChipLabel}"
                                           MaxLines="1"
                                           LineBreakMode="NoWrap" />
                                </Border>

                                <Border Grid.Column="1"
                                        IsVisible="{Binding IsSelected}"
                                        WidthRequest="20"
                                        HeightRequest="20"
                                        Stroke="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}"
                                        HorizontalOptions="End"
                                        VerticalOptions="End">
                                    <controls:IconView IconData="{x:Static controls:IconPathData.Check}"
                                                       IconColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}"
                                                       IconSize="12"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                </Border>

                                <HorizontalStackLayout Grid.Row="1"
                                                       Grid.ColumnSpan="2"
                                                       Spacing="8"
                                                       HorizontalOptions="End"
                                                       IsVisible="{Binding BindingContext.IsTrashEntryActionsVisible, Source={x:Reference TrashRoot}}">
                                    <Button Text="Delete forever"
                                            Command="{Binding BindingContext.DeleteForeverCommand, Source={x:Reference TrashRoot}}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource DenseDestructiveChromeButton}" />

                                    <Button Text="Restore"
                                            Command="{Binding BindingContext.RestoreCommand, Source={x:Reference TrashRoot}}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource DenseChromeButton}" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <CollectionView ItemsSource="{Binding Items}"
                            IsVisible="{Binding IsTileVisible}"
                            SelectionMode="None"
                            ItemSizingStrategy="MeasureFirstItem">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="2"
                                     HorizontalItemSpacing="10"
                                     VerticalItemSpacing="10" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonFileBrowserEntry">
                        <Border Style="{StaticResource M3SurfaceCard}"
                                Padding="12"
                                HeightRequest="190">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsSelected}"
                                             Value="True">
                                    <Setter Property="Stroke"
                                            Value="{StaticResource M3Accent}" />
                                    <Setter Property="StrokeThickness"
                                            Value="1" />
                                    <Setter Property="BackgroundColor"
                                            Value="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerHigh}, Dark={StaticResource M3DarkSurfaceContainerHigh}}" />
                                </DataTrigger>
                            </Border.Triggers>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BindingContext.ToggleSelectionCommand, Source={x:Reference TrashRoot}}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid RowDefinitions="Auto,Auto,*,Auto"
                                  RowSpacing="6">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">
                                    <Label Text="{Binding Name}"
                                           Style="{StaticResource M3CardTitle}"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation" />

                                    <Border Grid.Column="1"
                                            Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                                            StrokeShape="RoundRectangle 18"
                                            Padding="6,2"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerHigh}, Dark={StaticResource M3DarkSurfaceContainerHigh}}"
                                            VerticalOptions="Start">
                                        <Label Text="{Binding BadgeText}"
                                               Style="{StaticResource M3ChipLabel}"
                                               MaxLines="1"
                                               LineBreakMode="NoWrap" />
                                    </Border>

                                    <Border Grid.Column="1"
                                            IsVisible="{Binding IsSelected}"
                                            WidthRequest="20"
                                            HeightRequest="20"
                                            Stroke="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 10"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}"
                                            HorizontalOptions="End"
                                            VerticalOptions="End">
                                        <controls:IconView IconData="{x:Static controls:IconPathData.Check}"
                                                           IconColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}"
                                                           IconSize="12"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center" />
                                    </Border>
                                </Grid>

                                <Label Grid.Row="1"
                                       Text="{Binding DisplayDetails}"
                                       Style="{StaticResource M3CardMeta}"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation" />

                                <VerticalStackLayout Grid.Row="3"
                                                     Spacing="6"
                                                     IsVisible="{Binding BindingContext.IsTrashEntryActionsVisible, Source={x:Reference TrashRoot}}">
                                    <Button Text="Delete forever"
                                            Command="{Binding BindingContext.DeleteForeverCommand, Source={x:Reference TrashRoot}}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource CompactDestructiveChromeButton}"
                                            HeightRequest="34" />

                                    <Button Text="Restore"
                                            Command="{Binding BindingContext.RestoreCommand, Source={x:Reference TrashRoot}}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource CompactChromeButton}"
                                            HeightRequest="34" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
        </Grid>
    </Grid>
</ContentPage>
