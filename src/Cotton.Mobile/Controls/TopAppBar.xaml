<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             x:Class="Cotton.Mobile.Controls.TopAppBar"
             x:Name="Root"
             Style="{StaticResource M3TopAppBarSurface}">
    <ContentView.Triggers>
        <DataTrigger TargetType="ContentView"
                     Binding="{Binding Source={x:Reference Root}, Path=UseDarkTheme}"
                     Value="True">
            <Setter Property="BackgroundColor"
                    Value="{StaticResource M3DarkSurface}" />
        </DataTrigger>
    </ContentView.Triggers>

    <Grid ColumnSpacing="{StaticResource Space4}"
          HeightRequest="{StaticResource TouchTarget}"
          VerticalOptions="Center">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource TouchTarget}" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <controls:IconButton IconData="{x:Static controls:IconPathData.ArrowBack}"
                             Style="{StaticResource M3TopAppBarIconButton}"
                             Clicked="OnBackClicked"
                             SemanticProperties.Description="Back">
            <controls:IconButton.Triggers>
                <DataTrigger TargetType="controls:IconButton"
                             Binding="{Binding Source={x:Reference Root}, Path=UseDarkTheme}"
                             Value="True">
                    <Setter Property="Style"
                            Value="{StaticResource M3DarkTopAppBarIconButton}" />
                </DataTrigger>
            </controls:IconButton.Triggers>
        </controls:IconButton>

        <Label Grid.Column="1"
               Text="{Binding Source={x:Reference Root}, Path=TitleText}"
               Style="{StaticResource M3AppBarTitleLine}"
               VerticalOptions="Center">
            <Label.Triggers>
                <DataTrigger TargetType="Label"
                             Binding="{Binding Source={x:Reference Root}, Path=UseDarkTheme}"
                             Value="True">
                    <Setter Property="TextColor"
                            Value="{StaticResource M3DarkOnSurface}" />
                </DataTrigger>
            </Label.Triggers>
        </Label>

        <HorizontalStackLayout Grid.Column="2"
                               Spacing="{StaticResource Space4}"
                               HorizontalOptions="End"
                               VerticalOptions="Center">
            <controls:IconButton IconData="{Binding Source={x:Reference Root}, Path=PrimaryIconData}"
                                 Style="{StaticResource M3TopAppBarIconButton}"
                                 Command="{Binding Source={x:Reference Root}, Path=PrimaryCommand}"
                                 IsVisible="{Binding Source={x:Reference Root}, Path=IsPrimaryActionVisible}"
                                 SemanticProperties.Description="{Binding Source={x:Reference Root}, Path=PrimaryDescription}">
                <controls:IconButton.Triggers>
                    <DataTrigger TargetType="controls:IconButton"
                                 Binding="{Binding Source={x:Reference Root}, Path=UseDarkTheme}"
                                 Value="True">
                        <Setter Property="Style"
                                Value="{StaticResource M3DarkTopAppBarIconButton}" />
                    </DataTrigger>
                </controls:IconButton.Triggers>
            </controls:IconButton>

            <controls:IconButton IconData="{Binding Source={x:Reference Root}, Path=SecondaryIconData}"
                                 Style="{StaticResource M3TopAppBarIconButton}"
                                 Command="{Binding Source={x:Reference Root}, Path=SecondaryCommand}"
                                 IsVisible="{Binding Source={x:Reference Root}, Path=IsSecondaryActionVisible}"
                                 SemanticProperties.Description="{Binding Source={x:Reference Root}, Path=SecondaryDescription}">
                <controls:IconButton.Triggers>
                    <DataTrigger TargetType="controls:IconButton"
                                 Binding="{Binding Source={x:Reference Root}, Path=UseDarkTheme}"
                                 Value="True">
                        <Setter Property="Style"
                                Value="{StaticResource M3DarkTopAppBarIconButton}" />
                    </DataTrigger>
                </controls:IconButton.Triggers>
            </controls:IconButton>

            <controls:IconButton IconData="{Binding Source={x:Reference Root}, Path=TertiaryIconData}"
                                 Style="{StaticResource M3TopAppBarIconButton}"
                                 Command="{Binding Source={x:Reference Root}, Path=TertiaryCommand}"
                                 IsVisible="{Binding Source={x:Reference Root}, Path=IsTertiaryActionVisible}"
                                 SemanticProperties.Description="{Binding Source={x:Reference Root}, Path=TertiaryDescription}">
                <controls:IconButton.Triggers>
                    <DataTrigger TargetType="controls:IconButton"
                                 Binding="{Binding Source={x:Reference Root}, Path=UseDarkTheme}"
                                 Value="True">
                        <Setter Property="Style"
                                Value="{StaticResource M3DarkTopAppBarIconButton}" />
                    </DataTrigger>
                </controls:IconButton.Triggers>
            </controls:IconButton>
        </HorizontalStackLayout>
    </Grid>
</ContentView>
