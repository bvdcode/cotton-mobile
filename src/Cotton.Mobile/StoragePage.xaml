<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.StoragePage"
             x:DataType="viewModels:StorageSettingsViewModel"
             Shell.NavBarIsVisible="False"
             Title="Storage">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh storage" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Style="{StaticResource M3ScreenContentStack}">
            <controls:ScreenHeaderView Title="{Binding TotalSizeText}"
                                       TitleStyleResourceKey="M3ScreenMetric"
                                       SupportingText="{Binding TotalFileCountText}"
                                       DetailText="Files saved on this device"
                                       DetailTextStyleResourceKey="M3CardSupportingLine"
                                       IsBusy="{Binding IsBusy}" />

            <controls:ScreenStatusView Text="{Binding Status}"
                                       IsVisible="{Binding IsStatusVisible}" />

            <controls:SettingsCardView>
                <Grid RowDefinitions="Auto,Auto"
                      ColumnDefinitions="Auto,*,Auto"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <controls:IconFrame Grid.RowSpan="2"
                                        IconData="{x:Static controls:IconPathData.Cloud}"
                                        Style="{StaticResource M3CardUtilityThumbnailFrame}" />

                    <VerticalStackLayout Grid.Column="1"
                                         Grid.ColumnSpan="2"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="{Binding CloudQuotaTitle}"
                               Style="{StaticResource M3CardTitle}" />

                        <Label Text="{Binding CloudQuotaSummaryText}"
                               Style="{StaticResource M3CardSupportingStrongLine}" />

                        <Label Text="{Binding CloudQuotaDetailText}"
                               Style="{StaticResource M3CardSupportingBlock}" />
                    </VerticalStackLayout>

                    <controls:LinearProgressView Grid.Row="1"
                                                 Grid.Column="1"
                                                 Grid.ColumnSpan="2"
                                                 Progress="{Binding CloudQuotaUsageFraction}"
                                                 IsVisible="{Binding IsCloudQuotaProgressVisible}" />
                </Grid>
            </controls:SettingsCardView>

            <controls:SettingsCardView>
                <Label Text="Free up storage"
                       Style="{StaticResource M3CardTitle}" />

                <controls:ActionListItemView Text="Free space"
                                             SupportingText="Remove evictable local copies while keeping offline files."
                                             LeadingIconData="{x:Static controls:IconPathData.Download}"
                                             IsLeadingIconVisible="True"
                                             LeadingIconFrameStyleResourceKey="M3CardUtilityThumbnailFrame"
                                             ActionIconData="{x:Static controls:IconPathData.Download}"
                                             Command="{Binding FreeDeviceSpaceCommand}"
                                             GridStyleResourceKey="M3SettingsListItemGrid"
                                             TextStyleResourceKey="M3CardSupportingStrongLine"
                                             SemanticDescription="Free device storage" />

                <controls:ActionListItemView Text="Clear all cached files"
                                             SupportingText="Clear thumbnails, folder listings, downloads, and recents."
                                             LeadingIconData="{x:Static controls:IconPathData.Delete}"
                                             IsLeadingIconVisible="True"
                                             LeadingIconFrameStyleResourceKey="M3CardUtilityThumbnailFrame"
                                             ActionIconData="{x:Static controls:IconPathData.Delete}"
                                             Command="{Binding ClearAllCommand}"
                                             GridStyleResourceKey="M3SettingsListItemGrid"
                                             TextStyleResourceKey="M3CardSupportingStrongLine"
                                             ActionIconButtonStyleResourceKey="M3DestructiveFileChromeIconButton"
                                             SemanticDescription="Clear all cached files" />
            </controls:SettingsCardView>

            <controls:SettingsCardView>
                <Grid ColumnDefinitions="Auto,*"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <controls:IconFrame IconData="{x:Static controls:IconPathData.Device}"
                                        Style="{StaticResource M3CardUtilityThumbnailFrame}" />

                    <VerticalStackLayout Grid.Column="1"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="Files on this device"
                               Style="{StaticResource M3CardTitle}" />

                        <Label Text="{Binding OnDeviceSummaryText}"
                               Style="{StaticResource M3CardSupportingBlock}" />
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Style="{StaticResource M3SettingsItemListStack}"
                                     BindableLayout.ItemsSource="{Binding OnDeviceBuckets}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="services:CottonOnDeviceStorageBucketSnapshot">
                            <controls:StorageBucketItemView IsVisible="{Binding IsVisible}"
                                                            LeadingIconData="{x:Static controls:IconPathData.File}"
                                                            Title="{Binding Title}"
                                                            PrimaryMetricText="{Binding SizeText}"
                                                            DetailText="{Binding DetailText}"
                                                            SecondaryMetricText="{Binding CountText}" />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </controls:SettingsCardView>

            <controls:SettingsCardView>
                <Grid ColumnDefinitions="Auto,*"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <controls:IconFrame IconData="{x:Static controls:IconPathData.Transfer}"
                                        Style="{StaticResource M3CardTransferThumbnailFrame}" />

                    <VerticalStackLayout Grid.Column="1"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="Temporary files"
                               Style="{StaticResource M3CardTitle}" />

                        <Label Text="{Binding StorageBudgetSummaryText}"
                               Style="{StaticResource M3CardSupportingBlock}" />

                        <Label Text="{Binding ProtectedOfflineText}"
                               Style="{StaticResource M3CardSupportingBlock}" />
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Style="{StaticResource M3SettingsItemListStack}"
                                     BindableLayout.ItemsSource="{Binding StorageBudgetBuckets}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="services:CottonStorageBudgetBucketSnapshot">
                            <controls:StorageBucketItemView IsVisible="{Binding IsVisible}"
                                                            LeadingIconData="{x:Static controls:IconPathData.File}"
                                                            Title="{Binding Title}"
                                                            PrimaryMetricText="{Binding UsageText}"
                                                            DetailText="{Binding DetailText}"
                                                            SecondaryMetricText="{Binding StatusText}"
                                                            Progress="{Binding UsageFraction}"
                                                            IsProgressVisible="True" />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </controls:SettingsCardView>

        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
