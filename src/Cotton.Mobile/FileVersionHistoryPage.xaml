<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.FileVersionHistoryPage"
             x:DataType="viewModels:FileVersionHistoryViewModel"
             Shell.NavBarIsVisible="True"
             Title="Version history"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Refresh"
                     Command="{Binding LoadCommand}" />
    </ContentPage.ToolbarItems>

    <Grid Padding="16"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="14">
        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="12">
            <VerticalStackLayout Spacing="2">
                <Label Text="Version history"
                       FontSize="28"
                       FontAttributes="Bold"
                       MaxLines="1"
                       LineBreakMode="TailTruncation"
                       TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                <Label Text="{Binding FileName}"
                       FontSize="15"
                       FontAttributes="Bold"
                       MaxLines="1"
                       LineBreakMode="TailTruncation"
                       TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                <Label Text="{Binding SummaryText}"
                       FontSize="13"
                       MaxLines="2"
                       LineBreakMode="TailTruncation"
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
            </VerticalStackLayout>

            <ActivityIndicator Grid.Column="1"
                               IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               VerticalOptions="Center" />
        </Grid>

        <Label Grid.Row="1"
               Text="{Binding Status}"
               IsVisible="{Binding IsStatusVisible}"
               FontSize="13"
               MaxLines="2"
               LineBreakMode="TailTruncation"
               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

        <Grid Grid.Row="2">
            <Border IsVisible="{Binding IsEmpty}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="24,34"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                <VerticalStackLayout Spacing="8"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <Label Text="{Binding EmptyMessage}"
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                    <Label Text="{Binding EmptyDetails}"
                           FontSize="12"
                           MaxLines="2"
                           LineBreakMode="WordWrap"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </VerticalStackLayout>
            </Border>

            <CollectionView ItemsSource="{Binding Items}"
                            IsVisible="{Binding IsListVisible}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonFileVersionItemSnapshot">
                        <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                StrokeShape="RoundRectangle 8"
                                Padding="14"
                                Margin="0,0,0,10"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  ColumnDefinitions="*,Auto"
                                  RowSpacing="6"
                                  ColumnSpacing="10">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding VersionText}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                                    <Label Text="{Binding Name}"
                                           FontSize="12"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="8,3"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                                        VerticalOptions="Start">
                                    <Label Text="{Binding KindText}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           MaxLines="1"
                                           LineBreakMode="NoWrap"
                                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />
                                </Border>

                                <Label Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding DetailText}"
                                       FontSize="12"
                                       MaxLines="2"
                                       LineBreakMode="WordWrap"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                                <Label Grid.Row="2"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding ContentTypeText}"
                                       FontSize="11"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
