    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Cotton.Mobile.Controls">

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource M3Accent}" />
    </Style>

    <Style TargetType="IndicatorView">
        <Setter Property="IndicatorColor" Value="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}" />
        <Setter Property="SelectedIndicatorColor" Value="{StaticResource M3Accent}" />
    </Style>

    <Style TargetType="Border">
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="StrokeThickness" Value="1" />
    </Style>

    <Style TargetType="Border" x:Key="M3SurfaceCard">
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource M3LightSurfaceContainer}, Dark={StaticResource M3DarkSurfaceContainer}}" />
    </Style>

    <Style TargetType="Border" x:Key="M3ContentCard" BasedOn="{StaticResource M3SurfaceCard}">
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style TargetType="Border" x:Key="M3EmptyStateCard" BasedOn="{StaticResource M3SurfaceCard}">
        <Setter Property="Padding" Value="28,36" />
    </Style>

    <Style TargetType="Border" x:Key="M3TonalPanel">
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource M3LightSurfaceContainer}, Dark={StaticResource M3DarkSurfaceContainer}}" />
    </Style>

    <Style TargetType="Border" x:Key="M3AuthPanel">
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape" Value="RoundRectangle 28" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}" />
        <Setter Property="Shadow" Value="{StaticResource M3ShadowSoft}" />
    </Style>

    <Style TargetType="Border" x:Key="M3OutlinedInputField">
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="14,4" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLowest}, Dark={StaticResource M3DarkSurfaceContainer}}" />
