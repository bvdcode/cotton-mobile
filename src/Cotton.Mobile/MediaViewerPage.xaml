<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.MediaViewerPage"
             x:Name="RootPage"
             x:DataType="viewModels:MediaViewerViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding Title}"
             Style="{StaticResource M3DarkViewerPage}">

    <Grid RowDefinitions="Auto,*"
          Style="{StaticResource M3DarkViewerSurface}">
        <controls:TopAppBar TitleText="{Binding Title}"
                            UseDarkTheme="True"
                            PrimaryIconData="{x:Static controls:IconPathData.Share}"
                            PrimaryCommand="{Binding ShareCommand}"
                            PrimaryDescription="Share media"
                            SecondaryIconData="{x:Static controls:IconPathData.OpenInNew}"
                            SecondaryCommand="{Binding OpenExternallyCommand}"
                            SecondaryDescription="Open media" />

        <Grid Grid.Row="1"
              Style="{StaticResource M3DarkViewerSurface}">
            <Grid Style="{StaticResource M3DarkViewerSurface}">
                <toolkit:MediaElement x:Name="MediaPlayer"
                                      Aspect="AspectFit"
                                      ShouldAutoPlay="False"
                                      ShouldLoopPlayback="False"
                                      ShouldShowPlaybackControls="True"
                                      Style="{StaticResource M3ViewerMediaElement}" />

                <VerticalStackLayout x:Name="StartOverlay"
                                     Style="{StaticResource M3ViewerCenteredOverlay}">
                    <controls:IconButton IconData="{x:Static controls:IconPathData.Play}"
                                         Style="{StaticResource M3ViewerCenteredPlayIconButton}"
                                         Command="{Binding Source={x:Reference RootPage}, Path=PlayMediaCommand}"
                                         SemanticProperties.Description="Play media" />
                </VerticalStackLayout>

            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   Style="{StaticResource M3ViewerOverlayStatus}" />
        </Grid>
    </Grid>
</ContentPage>
