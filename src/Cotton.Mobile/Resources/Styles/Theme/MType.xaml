<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Label" x:Key="M3HeadlineLarge">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="LineHeight" Value="1.12" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>

    <Style TargetType="Label" x:Key="M3HeadlineMedium">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="LineHeight" Value="1.14" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>

    <Style TargetType="Label" x:Key="M3ScreenMetric" BasedOn="{StaticResource M3HeadlineLarge}">
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style TargetType="Label" x:Key="M3ScreenTitle" BasedOn="{StaticResource M3HeadlineMedium}">
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style TargetType="Label" x:Key="M3TitleLarge">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="LineHeight" Value="1.27" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>

    <Style TargetType="Label" x:Key="M3TitleMedium">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="LineHeight" Value="1.5" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>

    <Style TargetType="Label" x:Key="M3PanelTitle" BasedOn="{StaticResource M3TitleMedium}">
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style TargetType="Label" x:Key="M3EmptyTitle" BasedOn="{StaticResource M3PanelTitle}" />

    <Style TargetType="Label" x:Key="M3BrowserTitle">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.25" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>

    <Style TargetType="Label" x:Key="M3AppBarTitle">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.33" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>

    <Style TargetType="Label" x:Key="M3BodyMedium">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="1.43" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>

    <Style TargetType="Label" x:Key="M3DarkBodyMedium">
        <Setter Property="TextColor" Value="{StaticResource M3DarkOnSurfaceVariant}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="1.43" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>

    <Style TargetType="Label" x:Key="M3LabelLarge">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="1.43" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>

    <Style TargetType="Label" x:Key="M3CardTitle" BasedOn="{StaticResource M3LabelLarge}">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.33" />
    </Style>

    <Style TargetType="Label" x:Key="M3LabelMedium">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="1.33" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>

    <Style TargetType="Label" x:Key="M3DarkSupporting">
        <Setter Property="TextColor" Value="{StaticResource M3DarkOnSurfaceVariant}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="1.33" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>

    <Style TargetType="Label" x:Key="M3CardSupporting" BasedOn="{StaticResource M3LabelMedium}" />

    <Style TargetType="Label" x:Key="M3CardSupportingPrimary" BasedOn="{StaticResource M3LabelMedium}">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />
    </Style>

    <Style TargetType="Label" x:Key="M3CardSupportingStrong" BasedOn="{StaticResource M3LabelMedium}">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style TargetType="Label" x:Key="M3LabelSmall">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="LineHeight" Value="1.27" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>

    <Style TargetType="Label" x:Key="M3CardMeta" BasedOn="{StaticResource M3LabelSmall}" />

    <Style TargetType="Label" x:Key="M3ChipLabel">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.27" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>

    <Style TargetType="Label" x:Key="M3ThumbnailPlaceholder">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3Accent}}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>

    <Style TargetType="Label" x:Key="M3AccentChipLabel">
        <Setter Property="TextColor" Value="{StaticResource M3OnAccent}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.27" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>

    <Style TargetType="Label" x:Key="M3ErrorChipLabel">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightError}, Dark={StaticResource M3DarkError}}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.27" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>

    <Style TargetType="Label" x:Key="M3ErrorSupporting" BasedOn="{StaticResource M3CardSupporting}">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource M3LightError}, Dark={StaticResource M3DarkError}}" />
    </Style>

    <Style TargetType="Label" x:Key="M3NavigationSelectedLabel">
        <Setter Property="TextColor" Value="{StaticResource M3OnAccent}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.33" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>
</ResourceDictionary>
