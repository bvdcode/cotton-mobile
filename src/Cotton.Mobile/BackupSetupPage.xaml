<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.BackupSetupPage"
             x:DataType="viewModels:BackupSetupViewModel"
             Shell.NavBarIsVisible="False"
             Title="Camera Backup">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Save}"
                            SecondaryCommand="{Binding SaveCommand}"
                            SecondaryDescription="Save camera backup" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Padding="{StaticResource M3ScreenPadding}"
                             Spacing="{StaticResource Space16}">
            <Grid ColumnDefinitions="*,Auto"
                  Style="{StaticResource M3ScreenHeaderGrid}">
                <VerticalStackLayout Style="{StaticResource M3ScreenHeaderTextStack}">
                    <Label Text="Camera Backup"
                           Style="{StaticResource M3ScreenTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Text="{Binding ExecutionStatusText}"
                           Style="{StaticResource M3BodyMedium}"
                           MaxLines="2"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   Style="{StaticResource M3BodyMedium}"
                   MaxLines="2"
                   LineBreakMode="TailTruncation" />

            <Border Style="{StaticResource M3ContentCard}">
                <Grid RowDefinitions="Auto,Auto"
                      ColumnDefinitions="Auto,*,Auto"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <Border Grid.RowSpan="2"
                            Style="{StaticResource M3FileThumbnailSurface}"
                            VerticalOptions="Start">
                        <controls:IconView IconData="{x:Static controls:IconPathData.Folder}"
                                           Style="{StaticResource M3FolderThumbnailIcon}" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="Destination"
                               Style="{StaticResource M3CardTitle}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />

                        <Label Text="{Binding DestinationText}"
                               Style="{StaticResource M3CardSupporting}"
                               MaxLines="2"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>

                    <controls:IconButton Grid.Column="2"
                                         IconData="{x:Static controls:IconPathData.Folder}"
                                         Command="{Binding ChooseDestinationCommand}"
                                         Style="{StaticResource M3FileChromeIconButton}"
                                         VerticalOptions="Center"
                                         SemanticProperties.Description="Choose backup destination" />

                    <VerticalStackLayout Grid.Row="1"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="2"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="{Binding PolicySummaryText}"
                               Style="{StaticResource M3CardSupporting}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />

                        <Label Text="{Binding DestinationStorageEstimateTitle}"
                               Style="{StaticResource M3CardSupportingStrong}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />

                        <Label Text="{Binding DestinationStorageEstimateText}"
                               Style="{StaticResource M3CardSupporting}"
                               MaxLines="2"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="Auto,*,Auto"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <Border Grid.RowSpan="2"
                            Style="{StaticResource M3FileThumbnailSurface}"
                            VerticalOptions="Start">
                        <controls:IconView IconData="{x:Static controls:IconPathData.Image}"
                                           Style="{StaticResource M3CaptureThumbnailIcon}" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="{Binding MediaAccessTitle}"
                               Style="{StaticResource M3CardTitle}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />

                        <Label Text="{Binding MediaAccessDetailText}"
                               Style="{StaticResource M3CardSupporting}"
                               MaxLines="2"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>

                    <Border Grid.Column="2"
                            Style="{StaticResource M3NeutralChip}">
                        <Label Text="{Binding MediaAccessStatusText}"
                               Style="{StaticResource M3ChipLabel}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />
                    </Border>

                    <Button Grid.Row="2"
                            Grid.Column="1"
                            Grid.ColumnSpan="2"
                            Text="{Binding MediaAccessActionText}"
                            IsVisible="{Binding IsMediaAccessActionVisible}"
                            Command="{Binding MediaAccessActionCommand}"
                            Style="{StaticResource PanelChromeButton}"
                            HorizontalOptions="Start" />
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <Border Style="{StaticResource M3FileThumbnailSurface}"
                            VerticalOptions="Start">
                        <controls:IconView IconData="{x:Static controls:IconPathData.Activity}"
                                           Style="{StaticResource M3ActivityThumbnailIcon}" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="{Binding HealthTitle}"
                               Style="{StaticResource M3CardTitle}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />

                        <Label Text="{Binding HealthCountsText}"
                               Style="{StaticResource M3CardSupportingStrong}"
                               MaxLines="2"
                               LineBreakMode="TailTruncation" />

                        <Label Text="{Binding HealthStatusText}"
                               Style="{StaticResource M3CardSupporting}"
                               MaxLines="2"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>

                    <controls:IconButton Grid.Column="2"
                                         IconData="{x:Static controls:IconPathData.Play}"
                                         Command="{Binding QueueNowCommand}"
                                         Style="{StaticResource M3FileChromeIconButton}"
                                         VerticalOptions="Center"
                                         SemanticProperties.Description="Queue camera backup now" />
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="Auto,*,Auto"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <Border Grid.RowSpan="3"
                            Style="{StaticResource M3FileThumbnailSurface}"
                            VerticalOptions="Start">
                        <controls:IconView IconData="{x:Static controls:IconPathData.Backup}"
                                           Style="{StaticResource M3CaptureThumbnailIcon}" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="Backup running"
                               Style="{StaticResource M3CardTitle}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />

                        <Label Text="{Binding LocalMediaRetentionText}"
                               Style="{StaticResource M3CardSupporting}"
                               MaxLines="2"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>

                    <Switch Grid.Column="2"
                            IsEnabled="{Binding CanEnableBackup}"
                            IsToggled="{Binding IsBackupEnabled, Mode=OneWay}" />

                    <Label Grid.Row="1"
                           Grid.Column="1"
                           Text="Photos only"
                           Style="{StaticResource M3LabelLarge}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Switch Grid.Row="1"
                            Grid.Column="2"
                            IsToggled="{Binding PhotosOnly, Mode=TwoWay}" />

                    <Label Grid.Row="2"
                           Grid.Column="1"
                           Text="While charging"
                           Style="{StaticResource M3LabelLarge}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Switch Grid.Row="2"
                            Grid.Column="2"
                            IsToggled="{Binding ChargingOnly, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <Grid RowDefinitions="Auto,Auto"
                      ColumnDefinitions="Auto,*,Auto"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <Border Grid.RowSpan="2"
                            Style="{StaticResource M3FileThumbnailSurface}"
                            VerticalOptions="Start">
                        <controls:IconView IconData="{x:Static controls:IconPathData.Transfer}"
                                           Style="{StaticResource M3TransferThumbnailIcon}" />
                    </Border>

                    <Label Grid.Column="1"
                           Text="Wi-Fi only"
                           Style="{StaticResource M3LabelLarge}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Switch Grid.Column="2"
                            IsToggled="{Binding WifiOnly, Mode=TwoWay}" />

                    <Label Grid.Row="1"
                           Grid.Column="1"
                           Text="Allow cellular"
                           Style="{StaticResource M3LabelLarge}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Switch Grid.Row="1"
                            Grid.Column="2"
                            IsToggled="{Binding AllowCellular, Mode=TwoWay}" />
                </Grid>
            </Border>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
