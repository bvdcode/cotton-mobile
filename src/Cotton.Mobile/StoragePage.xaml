<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:Cotton.Mobile.Behaviors"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.StoragePage"
             x:DataType="viewModels:StorageSettingsViewModel"
             Shell.NavBarIsVisible="False"
             Title="Storage">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh storage" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Style="{StaticResource M3ScreenContentStack}">
            <Grid ColumnDefinitions="*,Auto"
                  Style="{StaticResource M3ScreenHeaderGrid}">
                <VerticalStackLayout Style="{StaticResource M3ScreenHeaderTextStack}">
                    <Label Text="{Binding TotalSizeText}"
                           Style="{StaticResource M3ScreenMetric}" />

                    <Label Text="{Binding TotalFileCountText}"
                           Style="{StaticResource M3ScreenHeaderSupporting}" />

                    <Label Text="Files saved on this device"
                           Style="{StaticResource M3CardSupportingLine}" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Style="{StaticResource M3ScreenHeaderActivityIndicator}" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   Style="{StaticResource M3ScreenStatus}" />

            <Border Style="{StaticResource M3ContentCard}">
                <Grid RowDefinitions="Auto,Auto"
                      ColumnDefinitions="Auto,*,Auto"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <controls:IconFrame Grid.RowSpan="2"
                                        IconData="{x:Static controls:IconPathData.Cloud}"
                                        Style="{StaticResource M3CardUtilityThumbnailFrame}" />

                    <VerticalStackLayout Grid.Column="1"
                                         Grid.ColumnSpan="2"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="{Binding CloudQuotaTitle}"
                               Style="{StaticResource M3CardTitle}" />

                        <Label Text="{Binding CloudQuotaSummaryText}"
                               Style="{StaticResource M3CardSupportingStrongLine}" />

                        <Label Text="{Binding CloudQuotaDetailText}"
                               Style="{StaticResource M3CardSupportingBlock}" />
                    </VerticalStackLayout>

                    <ProgressBar Grid.Row="1"
                                 Grid.Column="1"
                                 Grid.ColumnSpan="2"
                                 Progress="{Binding CloudQuotaUsageFraction}"
                                 IsVisible="{Binding IsCloudQuotaProgressVisible}"
                                 Style="{StaticResource M3LinearProgressBar}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <VerticalStackLayout Style="{StaticResource M3SettingsSectionStack}">
                    <Label Text="Free up storage"
                           Style="{StaticResource M3CardTitle}" />

                    <Grid ColumnDefinitions="Auto,*,Auto"
                          Style="{StaticResource M3SettingsListItemGrid}">
                        <controls:IconFrame IconData="{x:Static controls:IconPathData.Download}"
                                            Style="{StaticResource M3CardUtilityThumbnailFrame}" />

                        <VerticalStackLayout Grid.Column="1"
                                             Style="{StaticResource M3CardTextStack}">
                            <Label Text="Free space"
                                   Style="{StaticResource M3CardSupportingStrongLine}" />

                            <Label Text="Remove evictable local copies while keeping offline files."
                                   Style="{StaticResource M3CardSupportingBlock}" />
                        </VerticalStackLayout>

                        <Grid Grid.ColumnSpan="3"
                              Style="{StaticResource M3ListItemTouchSurface}">
                            <Grid.Behaviors>
                                <behaviors:LongPressBehavior TapCommand="{Binding FreeDeviceSpaceCommand}" />
                            </Grid.Behaviors>
                        </Grid>

                        <controls:IconButton Grid.Column="2"
                                             IconData="{x:Static controls:IconPathData.Download}"
                                             Command="{Binding FreeDeviceSpaceCommand}"
                                             Style="{StaticResource M3FileChromeIconButton}"
                                             SemanticProperties.Description="Free device storage" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*,Auto"
                          Style="{StaticResource M3SettingsListItemGrid}">
                        <controls:IconFrame IconData="{x:Static controls:IconPathData.Delete}"
                                            Style="{StaticResource M3CardUtilityThumbnailFrame}" />

                        <VerticalStackLayout Grid.Column="1"
                                             Style="{StaticResource M3CardTextStack}">
                            <Label Text="Clear all cached files"
                                   Style="{StaticResource M3CardSupportingStrongLine}" />

                            <Label Text="Clear thumbnails, folder listings, downloads, and recents."
                                   Style="{StaticResource M3CardSupportingBlock}" />
                        </VerticalStackLayout>

                        <Grid Grid.ColumnSpan="3"
                              Style="{StaticResource M3ListItemTouchSurface}">
                            <Grid.Behaviors>
                                <behaviors:LongPressBehavior TapCommand="{Binding ClearAllCommand}" />
                            </Grid.Behaviors>
                        </Grid>

                        <controls:IconButton Grid.Column="2"
                                             IconData="{x:Static controls:IconPathData.Delete}"
                                             Command="{Binding ClearAllCommand}"
                                             Style="{StaticResource M3DestructiveFileChromeIconButton}"
                                             SemanticProperties.Description="Clear all cached files" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <VerticalStackLayout Style="{StaticResource M3SettingsSectionStack}">
                    <Grid ColumnDefinitions="Auto,*"
                          Style="{StaticResource M3SettingsListItemGrid}">
                        <controls:IconFrame IconData="{x:Static controls:IconPathData.Device}"
                                            Style="{StaticResource M3CardUtilityThumbnailFrame}" />

                        <VerticalStackLayout Grid.Column="1"
                                             Style="{StaticResource M3CardTextStack}">
                            <Label Text="Files on this device"
                                   Style="{StaticResource M3CardTitle}" />

                            <Label Text="{Binding OnDeviceSummaryText}"
                                   Style="{StaticResource M3CardSupportingBlock}" />
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Style="{StaticResource M3SettingsItemListStack}"
                                         BindableLayout.ItemsSource="{Binding OnDeviceBuckets}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="services:CottonOnDeviceStorageBucketSnapshot">
                                <Grid RowDefinitions="Auto,Auto"
                                      ColumnDefinitions="Auto,*,Auto"
                                      Style="{StaticResource M3SettingsListItemGrid}"
                                      IsVisible="{Binding IsVisible}">
                                    <controls:IconFrame Grid.RowSpan="2"
                                                        IconData="{x:Static controls:IconPathData.File}"
                                                        Style="{StaticResource M3CardFileThumbnailFrame}" />

                                    <Label Grid.Column="1"
                                           Text="{Binding Title}"
                                           Style="{StaticResource M3CardSupportingStrongLine}" />

                                    <Label Grid.Column="2"
                                           Text="{Binding SizeText}"
                                           Style="{StaticResource M3CardSupportingStrongLine}" />

                                    <Label Grid.Row="1"
                                           Grid.Column="1"
                                           Text="{Binding DetailText}"
                                           Style="{StaticResource M3CardSupportingLine}" />

                                    <Label Grid.Row="1"
                                           Grid.Column="2"
                                           Text="{Binding CountText}"
                                           Style="{StaticResource M3CardSupportingLine}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <VerticalStackLayout Style="{StaticResource M3SettingsSectionStack}">
                    <Grid ColumnDefinitions="Auto,*"
                          Style="{StaticResource M3SettingsListItemGrid}">
                        <controls:IconFrame IconData="{x:Static controls:IconPathData.Transfer}"
                                            Style="{StaticResource M3CardTransferThumbnailFrame}" />

                        <VerticalStackLayout Grid.Column="1"
                                             Style="{StaticResource M3CardTextStack}">
                            <Label Text="Temporary files"
                                   Style="{StaticResource M3CardTitle}" />

                            <Label Text="{Binding StorageBudgetSummaryText}"
                                   Style="{StaticResource M3CardSupportingBlock}" />

                            <Label Text="{Binding ProtectedOfflineText}"
                                   Style="{StaticResource M3CardSupportingBlock}" />
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Style="{StaticResource M3SettingsItemListStack}"
                                         BindableLayout.ItemsSource="{Binding StorageBudgetBuckets}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="services:CottonStorageBudgetBucketSnapshot">
                                <Grid RowDefinitions="Auto,Auto,Auto"
                                      ColumnDefinitions="Auto,*,Auto"
                                      Style="{StaticResource M3SettingsListItemGrid}"
                                      IsVisible="{Binding IsVisible}">
                                    <controls:IconFrame Grid.RowSpan="3"
                                                        IconData="{x:Static controls:IconPathData.File}"
                                                        Style="{StaticResource M3CardFileThumbnailFrame}" />

                                    <Label Grid.Column="1"
                                           Text="{Binding Title}"
                                           Style="{StaticResource M3CardSupportingStrongLine}" />

                                    <Label Grid.Column="2"
                                           Text="{Binding UsageText}"
                                           Style="{StaticResource M3CardSupportingStrongLine}" />

                                    <Label Grid.Row="1"
                                           Grid.Column="1"
                                           Text="{Binding DetailText}"
                                           Style="{StaticResource M3CardSupportingLine}" />

                                    <Label Grid.Row="1"
                                           Grid.Column="2"
                                           Text="{Binding StatusText}"
                                           Style="{StaticResource M3CardSupportingLine}" />

                                    <ProgressBar Grid.Row="2"
                                                 Grid.Column="1"
                                                 Grid.ColumnSpan="2"
                                                 Progress="{Binding UsageFraction}"
                                                 Style="{StaticResource M3LinearProgressBar}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
