<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.TransfersPage"
             x:DataType="viewModels:TransfersViewModel"
             Shell.NavBarIsVisible="False"
             Title="Transfers">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar PrimaryIconData="{x:Static controls:IconPathData.Play}"
                            PrimaryCommand="{Binding RunWaitingCommand}"
                            PrimaryDescription="Run waiting transfers"
                            SecondaryIconData="{x:Static controls:IconPathData.Delete}"
                            SecondaryCommand="{Binding ClearHistoryCommand}"
                            SecondaryDescription="Clear transfer history"
                            IsTertiaryActionVisible="True"
                            TertiaryIconData="{x:Static controls:IconPathData.Refresh}"
                            TertiaryCommand="{Binding LoadCommand}"
                            TertiaryDescription="Refresh transfers" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Style="{StaticResource M3ScreenContentStack}">
            <controls:ScreenHeaderView Title="{Binding SummaryText}"
                                       IsBusy="{Binding IsBusy}" />

            <controls:ScreenStatusView Text="{Binding Status}"
                                       IsVisible="{Binding IsStatusVisible}" />

            <controls:MetadataListSkeletonView IsVisible="{Binding IsLoadingPlaceholderVisible}"
                                               Style="{StaticResource M3MetadataListSkeletonView}" />

            <controls:EmptyStateView IsVisible="{Binding IsEmpty}"
                                     IconData="{x:Static controls:IconPathData.Transfer}"
                                     Title="{Binding EmptyMessage}"
                                     Body="{Binding EmptyDetails}" />

            <VerticalStackLayout Style="{StaticResource M3SettingsSectionStack}"
                                 IsVisible="{Binding IsListVisible}"
                                 BindableLayout.ItemsSource="{Binding Items}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonTransferListItem">
                        <controls:MetadataCardView LeadingIconData="{x:Static controls:IconPathData.Transfer}"
                                                   LeadingIconFrameStyleResourceKey="M3CardTransferThumbnailFrame"
                                                   Title="{Binding DisplayName}"
                                                   SupportingText="{Binding DetailText}"
                                                   TrailingText="{Binding StatusText}">
                            <VerticalStackLayout Style="{StaticResource M3MetadataCardBodyStack}">
                                <controls:LinearProgressView Progress="{Binding ProgressFraction}"
                                                             IsVisible="{Binding IsProgressVisible}" />

                                <Label Text="{Binding ProgressText}"
                                       Style="{StaticResource M3CardSupportingLine}" />

                                <Label Text="{Binding FailureMessage}"
                                       IsVisible="{Binding IsFailureVisible}"
                                       Style="{StaticResource M3ErrorSupportingWrap}" />
                            </VerticalStackLayout>
                        </controls:MetadataCardView>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
