<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.TrashPage"
             x:Name="TrashRoot"
             x:DataType="viewModels:TrashViewModel"
             Shell.NavBarIsVisible="False"
             Title="Trash">

    <controls:ScreenShellView>
        <controls:TopAppBar PrimaryIconData="{x:Static controls:IconPathData.Delete}"
                            PrimaryCommand="{Binding EmptyTrashCommand}"
                            PrimaryDescription="Empty trash"
                            SecondaryIconData="{x:Static controls:IconPathData.Check}"
                            SecondaryCommand="{Binding ToggleSelectionModeCommand}"
                            SecondaryDescription="{Binding SelectionToolbarText}"
                            IsTertiaryActionVisible="True"
                            TertiaryIconData="{x:Static controls:IconPathData.Refresh}"
                            TertiaryCommand="{Binding LoadCommand}"
                            TertiaryDescription="Refresh trash" />

        <controls:ScreenContentGridView Grid.Row="1"
                                        ExtraAutoRows="2">
        <controls:ScreenHeaderView Title="Trash"
                                   SupportingText="{Binding SummaryText}"
                                   IsBusy="{Binding IsBusy}">
            <controls:ScreenHeaderView.ActionContent>
                <controls:ActionClusterView ClusterStyleResourceKey="M3ScreenHeaderActionCluster"
                                            PrimaryActionIconData="{x:Static controls:IconPathData.Search}"
                                            PrimaryActionCommand="{Binding ToggleSearchCommand}"
                                            PrimaryActionSemanticDescription="{Binding SearchButtonDescription}"
                                            SecondaryActionIconData="{x:Static controls:IconPathData.Sort}"
                                            SecondaryActionCommand="{Binding ShowSortActionsCommand}"
                                            SecondaryActionSemanticDescription="Sort trash"
                                            IsSecondaryActionVisible="{Binding IsSortButtonVisible}"
                                            TertiaryActionIconData="{x:Static controls:IconPathData.ViewTiles}"
                                            TertiaryActionCommand="{Binding ShowViewActionsCommand}"
                                            TertiaryActionSemanticDescription="Change trash view"
                                            IsTertiaryActionVisible="{Binding IsViewButtonVisible}">
                    <controls:ActionClusterView.Triggers>
                        <DataTrigger TargetType="controls:ActionClusterView"
                                     Binding="{Binding IsSearchVisible}"
                                     Value="True">
                            <Setter Property="PrimaryActionIconData"
                                    Value="{x:Static controls:IconPathData.Close}" />
                        </DataTrigger>
                    </controls:ActionClusterView.Triggers>
                </controls:ActionClusterView>
            </controls:ScreenHeaderView.ActionContent>
        </controls:ScreenHeaderView>

        <controls:OutlinedInputField Grid.Row="1"
                                     Text="{Binding SearchText, Mode=TwoWay}"
                                     IsFieldVisible="{Binding IsSearchVisible}"
                                     Placeholder="Search trash"
                                     IconData="{x:Static controls:IconPathData.Search}"
                                     ReturnType="Search"
                                     ClearButtonVisibility="WhileEditing"
                                     SemanticHint="Search deleted files and folders" />

        <controls:ScreenStatusView Grid.Row="2"
                                   Text="{Binding Status}"
                                   IsStatusVisible="{Binding IsStatusVisible}" />

        <controls:SelectionBarView Grid.Row="3"
                                   IsBarVisible="{Binding IsSelectionBarVisible}"
                                   TitleText="{Binding SelectionTitleText}"
                                   DetailText="{Binding SelectionDetailText}"
                                   PrimaryActionIconData="{x:Static controls:IconPathData.Reset}"
                                   PrimaryActionCommand="{Binding RestoreSelectionCommand}"
                                   PrimaryActionIsEnabled="{Binding IsBulkActionEnabled}"
                                   PrimaryActionSemanticDescription="Restore selected items"
                                   SecondaryActionIconData="{x:Static controls:IconPathData.Delete}"
                                   SecondaryActionCommand="{Binding DeleteForeverSelectionCommand}"
                                   SecondaryActionIsEnabled="{Binding IsBulkActionEnabled}"
                                   SecondaryActionSemanticDescription="Delete selected items forever"
                                   SecondaryActionIconButtonStyleResourceKey="M3DestructiveFileChromeIconButton"
                                   TertiaryActionIconData="{x:Static controls:IconPathData.Close}"
                                   TertiaryActionCommand="{Binding CancelSelectionCommand}"
                                   TertiaryActionSemanticDescription="Cancel selection" />

        <controls:LayeredContentView Grid.Row="4">
            <controls:EmptyStateView IsStateVisible="{Binding IsEmpty}"
                                     IconData="{x:Static controls:IconPathData.Delete}"
                                     Title="{Binding EmptyMessage}"
                                     Body="{Binding EmptyDetails}" />

            <controls:MaterialCollectionView ItemsSource="{Binding Items}"
                                             IsVisible="{Binding IsListVisible}"
                                             ItemSizingStrategy="MeasureFirstItem"
                                             ItemsLayout="{StaticResource M3VerticalCardListItemsLayout}">
                <controls:MaterialCollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonFileBrowserEntry">
                        <controls:TrashListEntryCardView Title="{Binding Name}"
                                                         Detail="{Binding DisplayDetails}"
                                                         BadgeText="{Binding BadgeText}"
                                                         ThumbnailSource="{Binding Thumbnail.Source}"
                                                         IsPreviewImageVisible="{Binding IsPreviewImageVisible}"
                                                         IsFolderThumbnailVisible="{Binding IsFolderThumbnailVisible}"
                                                         IsLoading="{Binding Thumbnail.IsLoading}"
                                                         PlaceholderText="{Binding Thumbnail.PlaceholderText}"
                                                         IsPlaceholderTextVisible="{Binding IsPlaceholderTextVisible}"
                                                         IsSelected="{Binding IsSelected}"
                                                         ToggleSelectionCommand="{Binding BindingContext.ToggleSelectionCommand, Source={x:Reference TrashRoot}}"
                                                         CommandParameter="{Binding .}"
                                                         IsEntryActionsVisible="{Binding BindingContext.IsTrashEntryActionsVisible, Source={x:Reference TrashRoot}}"
                                                         DeleteForeverCommand="{Binding BindingContext.DeleteForeverCommand, Source={x:Reference TrashRoot}}"
                                                         RestoreCommand="{Binding BindingContext.RestoreCommand, Source={x:Reference TrashRoot}}" />
                    </DataTemplate>
                </controls:MaterialCollectionView.ItemTemplate>
            </controls:MaterialCollectionView>

            <controls:MaterialCollectionView ItemsSource="{Binding Items}"
                                             IsVisible="{Binding IsTileVisible}"
                                             ItemSizingStrategy="MeasureFirstItem"
                                             ItemsLayout="{StaticResource M3TrashTileItemsLayout}">
                <controls:MaterialCollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonFileBrowserEntry">
                        <controls:TrashTileEntryCardView Title="{Binding Name}"
                                                         Detail="{Binding DisplayDetails}"
                                                         BadgeText="{Binding BadgeText}"
                                                         ThumbnailSource="{Binding Thumbnail.Source}"
                                                         IsPreviewImageVisible="{Binding IsPreviewImageVisible}"
                                                         IsFolderThumbnailVisible="{Binding IsFolderThumbnailVisible}"
                                                         IsLoading="{Binding Thumbnail.IsLoading}"
                                                         PlaceholderText="{Binding Thumbnail.PlaceholderText}"
                                                         IsPlaceholderTextVisible="{Binding IsPlaceholderTextVisible}"
                                                         IsSelected="{Binding IsSelected}"
                                                         ToggleSelectionCommand="{Binding BindingContext.ToggleSelectionCommand, Source={x:Reference TrashRoot}}"
                                                         CommandParameter="{Binding .}"
                                                         IsEntryActionsVisible="{Binding BindingContext.IsTrashEntryActionsVisible, Source={x:Reference TrashRoot}}"
                                                         DeleteForeverCommand="{Binding BindingContext.DeleteForeverCommand, Source={x:Reference TrashRoot}}"
                                                         RestoreCommand="{Binding BindingContext.RestoreCommand, Source={x:Reference TrashRoot}}" />
                    </DataTemplate>
                </controls:MaterialCollectionView.ItemTemplate>
            </controls:MaterialCollectionView>
        </controls:LayeredContentView>
        </controls:ScreenContentGridView>
    </controls:ScreenShellView>
</ContentPage>
