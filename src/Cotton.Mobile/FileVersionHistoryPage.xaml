<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.FileVersionHistoryPage"
             x:DataType="viewModels:FileVersionHistoryViewModel"
             Shell.NavBarIsVisible="False"
             Title="Version history"
             BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">

    <Grid RowDefinitions="Auto,*"
          BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh versions" />

        <Grid Grid.Row="1"
              Padding="16"
              RowDefinitions="Auto,Auto,*"
              RowSpacing="14">
        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="12">
            <VerticalStackLayout Spacing="2">
                <Label Text="Version history"
                       Style="{StaticResource M3ScreenTitle}"
                       MaxLines="1"
                       LineBreakMode="TailTruncation" />

                <Label Text="{Binding FileName}"
                       Style="{StaticResource M3CardTitle}"
                       MaxLines="1"
                       LineBreakMode="TailTruncation" />

                <Label Text="{Binding SummaryText}"
                       Style="{StaticResource M3BodyMedium}"
                       MaxLines="2"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <ActivityIndicator Grid.Column="1"
                               IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               VerticalOptions="Center" />
        </Grid>

        <Label Grid.Row="1"
               Text="{Binding Status}"
               IsVisible="{Binding IsStatusVisible}"
               Style="{StaticResource M3BodyMedium}"
               MaxLines="2"
               LineBreakMode="TailTruncation" />

            <Grid Grid.Row="2">
                <Border IsVisible="{Binding IsEmpty}"
                        Style="{StaticResource M3SurfaceCard}"
                        Padding="28,36">
                    <VerticalStackLayout Spacing="8"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">
                        <Label Text="{Binding EmptyMessage}"
                               Style="{StaticResource M3EmptyTitle}"
                               HorizontalTextAlignment="Center" />

                        <Label Text="{Binding EmptyDetails}"
                               Style="{StaticResource M3CardSupporting}"
                               MaxLines="2"
                               LineBreakMode="WordWrap"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <CollectionView ItemsSource="{Binding Items}"
                                IsVisible="{Binding IsListVisible}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="services:CottonFileVersionItemSnapshot">
                            <Border Style="{StaticResource M3SurfaceCard}"
                                    Padding="16"
                                    Margin="0,0,0,10">
                                <Grid RowDefinitions="Auto,Auto,Auto"
                                      ColumnDefinitions="*,Auto"
                                      RowSpacing="6"
                                      ColumnSpacing="10">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding VersionText}"
                                               Style="{StaticResource M3CardTitle}"
                                               MaxLines="1"
                                               LineBreakMode="TailTruncation" />

                                        <Label Text="{Binding Name}"
                                               Style="{StaticResource M3CardSupporting}"
                                               MaxLines="1"
                                               LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>

                                    <Border Grid.Column="1"
                                            Style="{StaticResource M3NeutralChip}">
                                        <Label Text="{Binding KindText}"
                                               Style="{StaticResource M3ChipLabel}"
                                               MaxLines="1"
                                               LineBreakMode="NoWrap" />
                                    </Border>

                                    <Label Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding DetailText}"
                                           Style="{StaticResource M3CardSupporting}"
                                           MaxLines="2"
                                           LineBreakMode="WordWrap" />

                                    <Label Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding ContentTypeText}"
                                           Style="{StaticResource M3CardMeta}"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
