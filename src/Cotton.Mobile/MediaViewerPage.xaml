<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.MediaViewerPage"
             x:DataType="viewModels:MediaViewerViewModel"
             Shell.NavBarIsVisible="True"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource OffBlack}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Share"
                     Command="{Binding ShareCommand}" />
        <ToolbarItem Text="Open"
                     Command="{Binding OpenExternallyCommand}" />
    </ContentPage.ToolbarItems>

    <Grid BackgroundColor="{StaticResource OffBlack}">
        <Grid BackgroundColor="{StaticResource OffBlack}">
            <toolkit:MediaElement x:Name="MediaPlayer"
                                  Source="{Binding MediaSourcePath}"
                                  Aspect="AspectFit"
                                  ShouldAutoPlay="False"
                                  ShouldLoopPlayback="False"
                                  ShouldShowPlaybackControls="True"
                                  HorizontalOptions="Fill"
                                  VerticalOptions="Fill" />

            <VerticalStackLayout x:Name="StartOverlay"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Button Text="▶"
                        Clicked="OnPlayClicked"
                        WidthRequest="60"
                        HeightRequest="60"
                        MinimumWidthRequest="60"
                        MinimumHeightRequest="60"
                        CornerRadius="30"
                        Padding="0"
                        FontSize="22"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        SemanticProperties.Description="Play media" />
            </VerticalStackLayout>

        </Grid>

        <Label Text="{Binding Status}"
               IsVisible="{Binding IsStatusVisible}"
               Margin="16"
               FontSize="12"
               MaxLines="1"
               LineBreakMode="TailTruncation"
               TextColor="{StaticResource Gray200}"
               HorizontalOptions="Start"
               VerticalOptions="End" />
    </Grid>
</ContentPage>
