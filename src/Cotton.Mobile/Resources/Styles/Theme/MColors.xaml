<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="M3Accent">#C6FF00</Color>
    <Color x:Key="M3OnAccent">#151900</Color>
    <Color x:Key="M3DocumentSurface">#FFFFFF</Color>

    <Color x:Key="M3LightSurface">#FAFBF5</Color>
    <Color x:Key="M3LightOnSurface">#191D16</Color>
    <Color x:Key="M3LightOnSurfaceVariant">#44483F</Color>
    <Color x:Key="M3LightSurfaceContainerLowest">#FFFFFF</Color>
    <Color x:Key="M3LightSurfaceContainerLow">#F3F5EC</Color>
    <Color x:Key="M3LightSurfaceContainer">#EDF0E6</Color>
    <Color x:Key="M3LightSurfaceContainerHigh">#E7EADF</Color>
    <Color x:Key="M3LightSurfaceContainerHighest">#E1E4D9</Color>
    <Color x:Key="M3LightOutline">#74796D</Color>
    <Color x:Key="M3LightOutlineVariant">#C4C8BC</Color>
    <Color x:Key="M3LightError">#BA1A1A</Color>

    <Color x:Key="M3DarkSurface">#0D1117</Color>
    <Color x:Key="M3DarkOnSurface">#E6EAE0</Color>
    <Color x:Key="M3DarkOnSurfaceVariant">#C4C8BC</Color>
    <Color x:Key="M3DarkSurfaceContainerLowest">#070A0E</Color>
    <Color x:Key="M3DarkSurfaceContainerLow">#151A20</Color>
    <Color x:Key="M3DarkSurfaceContainer">#1A2027</Color>
    <Color x:Key="M3DarkSurfaceContainerHigh">#242B33</Color>
    <Color x:Key="M3DarkSurfaceContainerHighest">#2F3741</Color>
    <Color x:Key="M3DarkOutline">#8E9287</Color>
    <Color x:Key="M3DarkOutlineVariant">#44483F</Color>
    <Color x:Key="M3DarkError">#FFB4AB</Color>

    <SolidColorBrush x:Key="M3AccentBrush" Color="{StaticResource M3Accent}" />
</ResourceDictionary>
