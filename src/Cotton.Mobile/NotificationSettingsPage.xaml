<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.NotificationSettingsPage"
             x:DataType="viewModels:NotificationSettingsViewModel"
             Shell.NavBarIsVisible="False"
             Title="Notifications">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh notifications" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Style="{StaticResource M3ScreenContentStack}">
            <controls:ScreenHeaderView Title="Notifications"
                                       SupportingText="{Binding EnabledCategoriesText}"
                                       IsBusy="{Binding IsBusy}" />

            <controls:AttentionStatusView IsVisible="{Binding IsAttentionStatusVisible}"
                                          Message="{Binding Status}"
                                          IconData="{x:Static controls:IconPathData.Error}"
                                          ActionIconData="{x:Static controls:IconPathData.Refresh}"
                                          ActionCommand="{Binding LoadCommand}"
                                          IsRowTapEnabled="True"
                                          GridStyleResourceKey="M3ActionListItemGrid"
                                          ActionSemanticDescription="Retry notifications" />

            <controls:ScreenStatusView Text="{Binding Status}"
                                       IsVisible="{Binding IsNeutralStatusVisible}" />

            <Border Style="{StaticResource M3ContentCard}">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      Style="{StaticResource M3SettingsSummaryGrid}">
                    <Label Text="{Binding PermissionTitle}"
                           Style="{StaticResource M3CardTitle}" />

                    <Label Grid.Column="1"
                           Text="{Binding PermissionStatusText}"
                           Style="{StaticResource M3CardTitle}" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding PermissionDetailText}"
                           Style="{StaticResource M3CardSupportingBlock}" />

                    <controls:ActionListItemView Grid.Row="2"
                                                 Grid.ColumnSpan="2"
                                                 Text="{Binding PermissionActionText}"
                                                 LeadingIconData="{x:Static controls:IconPathData.Activity}"
                                                 IsLeadingIconVisible="True"
                                                 LeadingIconFrameStyleResourceKey="M3CardActivityThumbnailFrame"
                                                 ActionIconData="{x:Static controls:IconPathData.OpenInNew}"
                                                 Command="{Binding PermissionActionCommand}"
                                                 IsVisible="{Binding IsPermissionActionVisible}"
                                                 GridStyleResourceKey="M3SettingsListItemGrid"
                                                 ActionIconButtonStyleResourceKey="M3PrimaryFileChromeIconButton"
                                                 SemanticDescription="{Binding PermissionActionText}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <VerticalStackLayout Style="{StaticResource M3SettingsSectionStack}">
                    <controls:SettingsSummaryHeaderView Title="Server push"
                                                        StatusText="{Binding RemotePushStatusText}"
                                                        IsStatusVisible="{Binding IsRemotePushStatusVisible}"
                                                        IsDetailVisible="False" />

                    <Grid IsVisible="{Binding IsRemotePushUnavailable}"
                          ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto,Auto"
                          Style="{StaticResource M3SettingsSummaryGrid}">
                        <controls:IconView IconData="{x:Static controls:IconPathData.Error}"
                                           Style="{StaticResource M3AttentionStatusIconTop}" />

                        <Label Grid.Column="1"
                               Text="{Binding RemotePushUnavailableTitle}"
                               Style="{StaticResource M3CardTitle}" />

                        <Label Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="{Binding RemotePushUnavailableDetail}"
                               Style="{StaticResource M3CardSupportingBlock}" />

                        <controls:ActionListItemView Grid.Row="2"
                                                     Grid.ColumnSpan="2"
                                                     Text="Retry server push"
                                                     ActionIconData="{x:Static controls:IconPathData.Refresh}"
                                                     Command="{Binding LoadCommand}"
                                                     GridStyleResourceKey="M3SettingsListItemGrid"
                                                     SemanticDescription="Retry server push" />
                    </Grid>

                    <VerticalStackLayout Style="{StaticResource M3SettingsSectionStack}"
                                         IsVisible="{Binding HasRemotePushPreferences}"
                                         BindableLayout.ItemsSource="{Binding RemotePushPreferences}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:RemotePushPreferenceItemViewModel">
                                <Grid ColumnDefinitions="*,Auto"
                                      Style="{StaticResource M3SettingsSummaryGrid}">
                                    <VerticalStackLayout Style="{StaticResource M3CardTextStack}">
                                        <Label Text="{Binding Title}"
                                               Style="{StaticResource M3LabelLargeLine}" />

                                        <Label Text="{Binding DetailText}"
                                               Style="{StaticResource M3CardSupportingBlock}" />
                                    </VerticalStackLayout>

                                    <controls:ToggleSwitch Grid.Column="1"
                                                           IsEnabled="{Binding CanToggle}"
                                                           IsToggled="{Binding IsEnabled, Mode=TwoWay}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
