<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.ActivityFeedPage"
             x:DataType="viewModels:ActivityFeedViewModel"
             Shell.NavBarIsVisible="False"
             Title="Activity">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh activity" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Style="{StaticResource M3ScreenContentStack}">
            <controls:ScreenHeaderView Title="Activity"
                                       SupportingText="{Binding SummaryText}"
                                       IsBusy="{Binding IsBusy}" />

            <controls:ScreenStatusView Text="{Binding Status}"
                                       IsVisible="{Binding IsStatusVisible}" />

            <controls:MetadataListSkeletonView IsVisible="{Binding IsLoadingPlaceholderVisible}"
                                               Style="{StaticResource M3MetadataListSkeletonView}" />

            <controls:EmptyStateView IsVisible="{Binding IsEmpty}"
                                     IconData="{x:Static controls:IconPathData.Activity}"
                                     Title="{Binding EmptyMessage}"
                                     Body="{Binding EmptyDetails}" />

            <VerticalStackLayout Style="{StaticResource M3SettingsSectionStack}"
                                 IsVisible="{Binding IsListVisible}"
                                 BindableLayout.ItemsSource="{Binding Items}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonActivityFeedListItem">
                        <controls:MetadataCardView LeadingIconData="{x:Static controls:IconPathData.Activity}"
                                                   LeadingIconFrameStyleResourceKey="M3CardActivityThumbnailFrame"
                                                   Title="{Binding Title}"
                                                   SupportingText="{Binding DetailText}"
                                                   TrailingText="{Binding BadgeText}">
                            <Label Text="{Binding ContentText}"
                                   IsVisible="{Binding IsContentVisible}"
                                   Style="{StaticResource M3CardSupportingLongWrap}" />
                        </controls:MetadataCardView>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Border Style="{StaticResource M3ContentCard}"
                    IsVisible="{Binding IsLoadMoreVisible}">
                <controls:ActionListItemView Text="Load more"
                                             LeadingIconData="{x:Static controls:IconPathData.Activity}"
                                             IsLeadingIconVisible="True"
                                             ActionIconData="{x:Static controls:IconPathData.ArrowDown}"
                                             Command="{Binding LoadMoreCommand}"
                                             TextStyleResourceKey="M3ActionListItemTitle"
                                             ActionIconButtonStyleResourceKey="M3PrimaryFileChromeIconButton"
                                             SemanticDescription="Load more activity" />
            </Border>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
