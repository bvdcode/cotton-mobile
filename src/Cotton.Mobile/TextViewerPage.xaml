<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.TextViewerPage"
             x:DataType="viewModels:TextViewerViewModel"
             Shell.NavBarIsVisible="True"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Copy"
                     Command="{Binding CopyCommand}" />
        <ToolbarItem Text="Share"
                     Command="{Binding ShareCommand}" />
        <ToolbarItem Text="Open"
                     Command="{Binding OpenExternallyCommand}" />
    </ContentPage.ToolbarItems>

    <Grid Padding="16"
          RowDefinitions="Auto,*"
          RowSpacing="12">
        <VerticalStackLayout Spacing="2">
            <Label Text="{Binding Title}"
                   FontSize="16"
                   FontAttributes="Bold"
                   MaxLines="1"
                   LineBreakMode="TailTruncation"
                   TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

            <Label Text="{Binding Details}"
                   FontSize="12"
                   MaxLines="1"
                   LineBreakMode="TailTruncation"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   FontSize="12"
                   MaxLines="1"
                   LineBreakMode="TailTruncation"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
        </VerticalStackLayout>

        <Border Grid.Row="1"
                Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                StrokeShape="RoundRectangle 8"
                StrokeThickness="1"
                Padding="8"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
            <Editor Text="{Binding Content}"
                    IsReadOnly="True"
                    AutoSize="Disabled"
                    FontFamily="monospace"
                    FontSize="13"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill"
                    TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}"
                    BackgroundColor="Transparent" />
        </Border>
    </Grid>
</ContentPage>
