<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.DiagnosticsPage"
             x:DataType="viewModels:DiagnosticsViewModel"
             Shell.NavBarIsVisible="False"
             Title="Diagnostics">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar PrimaryIconData="{x:Static controls:IconPathData.Copy}"
                            PrimaryCommand="{Binding CopyCommand}"
                            PrimaryDescription="Copy diagnostics"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh diagnostics" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Style="{StaticResource M3ScreenContentStack}">
            <controls:ScreenHeaderView Title="{Binding HeaderTitleText}"
                                       SupportingText="{Binding HeaderVersionText}"
                                       IsBusy="{Binding IsBusy}" />

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   Style="{StaticResource M3ScreenStatus}" />

            <VerticalStackLayout Style="{StaticResource M3DiagnosticsSectionListStack}"
                                 BindableLayout.ItemsSource="{Binding Sections}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:DiagnosticsSectionViewModel">
                        <Border Style="{StaticResource M3ContentCard}">
                            <VerticalStackLayout Style="{StaticResource M3SettingsSectionStack}">
                                <Label Text="{Binding Title}"
                                       Style="{StaticResource M3CardTitle}" />

                                <VerticalStackLayout Style="{StaticResource M3DiagnosticsItemListStack}"
                                                     BindableLayout.ItemsSource="{Binding Items}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="viewModels:DiagnosticsItemViewModel">
                                            <Grid Style="{StaticResource M3DiagnosticsItemGrid}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="{StaticResource M3DiagnosticsLabelColumnWidth}" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Label Text="{Binding Label}"
                                                       Style="{StaticResource M3CardSupporting}" />

                                                <Label Grid.Column="1"
                                                       Text="{Binding Value}"
                                                       Style="{StaticResource M3CardSupportingPrimaryBlock}" />
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
