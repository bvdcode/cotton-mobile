<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.SyncSettingsPage"
             x:DataType="viewModels:SyncSettingsViewModel"
             Shell.NavBarIsVisible="True"
             Title="Sync"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Refresh"
                     Command="{Binding LoadCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="16"
                             Spacing="14">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Sync"
                           FontSize="28"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                    <Label Text="{Binding SummaryText}"
                           FontSize="13"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   FontSize="13"
                   MaxLines="2"
                   LineBreakMode="TailTruncation"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

            <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="14"
                    IsVisible="{Binding IsEmptyVisible}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                <VerticalStackLayout Spacing="4">
                    <Label Text="No synced folders"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                    <Label Text="Use Sync to this device from a folder."
                           FontSize="12"
                           MaxLines="2"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="10"
                                 BindableLayout.ItemsSource="{Binding Roots}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonSyncRootListItem">
                        <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                StrokeShape="RoundRectangle 8"
                                Padding="14"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto,Auto"
                                  RowSpacing="4"
                                  ColumnSpacing="12">
                                <Label Text="{Binding Title}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation"
                                       TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                                <Label Grid.Column="1"
                                       Text="{Binding StatusText}"
                                       FontSize="12"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                                <Label Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding PathText}"
                                       FontSize="12"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                                <Label Grid.Row="2"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding DetailText}"
                                       FontSize="12"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
