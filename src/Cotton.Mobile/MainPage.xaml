<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:Cotton.Mobile.Behaviors"
             x:Class="Cotton.Mobile.MainPage"
             x:Name="RootPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <Grid x:Name="RootLayout"
          Padding="12,0,12,14"
          RowDefinitions="*,Auto">
        <RefreshView Grid.Row="0"
                     Command="{Binding RefreshFilesCommand}"
                     IsRefreshing="{Binding Display.IsFilesRefreshing, Mode=TwoWay}">
        <ScrollView>
            <VerticalStackLayout Spacing="24"
                                 Padding="0,0,0,96"
                                 VerticalOptions="Start"
                                 HorizontalOptions="Fill">
                <Image Source="appiconfg.svg"
                       IsVisible="{Binding Display.IsBrandHeaderVisible}"
                       HeightRequest="92"
                       WidthRequest="92"
                       Margin="0,44,0,0"
                       Aspect="AspectFit"
                       HorizontalOptions="Start"
                       SemanticProperties.Description="Cotton Cloud" />

                <VerticalStackLayout IsVisible="{Binding Display.IsBrandHeaderVisible}"
                                     Spacing="8">
                    <Label Text="Cotton Cloud"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}"
                           SemanticProperties.HeadingLevel="Level1" />

                    <Label Text="Sign in to your Cotton instance"
                           FontSize="16"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding Display.IsLoadingVisible}"
                                     Spacing="12">
                    <ActivityIndicator IsRunning="{Binding Display.IsLoadingIndicatorRunning}"
                                       HorizontalOptions="Start" />

                    <Label Text="{Binding Display.LoadingMessage}"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding Display.IsSignInVisible}"
                                     Spacing="16"
                                     MaximumWidthRequest="520">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Instance URL"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                        <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8"
                                Padding="12,2"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                            <Entry Text="{Binding Display.InstanceUrl, Mode=TwoWay}"
                                   Keyboard="Url"
                                   ReturnType="Go"
                                   ClearButtonVisibility="WhileEditing"
                                   IsEnabled="{Binding Display.IsInputEnabled}"
                                   ReturnCommand="{Binding ConnectCommand}"
                                   SemanticProperties.Hint="Cotton instance URL" />
                        </Border>

                        <Label Text="{Binding Display.Status}"
                               IsVisible="{Binding Display.IsStatusVisible}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                    </VerticalStackLayout>

                    <Button Text="Connect"
                            Command="{Binding ConnectCommand}"
                            IsEnabled="{Binding Display.IsInputEnabled}"
                            HorizontalOptions="Fill" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding Display.IsAuthorizationProgressVisible}"
                                     Spacing="16"
                                     MaximumWidthRequest="520">
                    <ActivityIndicator IsRunning="{Binding Display.IsAuthorizationProgressIndicatorRunning}"
                                       HorizontalOptions="Start" />

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Waiting for browser approval"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                        <Label Text="{Binding Display.AuthorizationProgressMessage}"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                    </VerticalStackLayout>

                    <Button Text="Cancel"
                            Command="{Binding CancelAuthorizationCommand}"
                            IsEnabled="{Binding Display.IsCancelAuthorizationEnabled}"
                            HorizontalOptions="Fill" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding Display.IsProfileVisible}"
                                     Spacing="0"
                                     HorizontalOptions="Fill">
                        <VerticalStackLayout x:Name="FileBrowserContent"
                                             Spacing="8"
                                             HorizontalOptions="Fill">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto"
                                  ColumnSpacing="6">
                                <Button Grid.Column="0"
                                        Style="{StaticResource FileChromeButton}"
                                        Text="↑"
                                        Command="{Binding NavigateFilesUpCommand}"
                                        IsEnabled="{Binding Display.CanNavigateFilesUp}"
                                        IsVisible="{Binding Display.IsFileUpButtonVisible}"
                                        Opacity="{Binding Display.FileUpButtonOpacity}"
                                        Padding="0"
                                        FontSize="17"
                                        FontAttributes="Bold"
                                        VerticalOptions="Center"
                                        HeightRequest="44"
                                        MinimumHeightRequest="44"
                                        MinimumWidthRequest="44"
                                        WidthRequest="44"
                                        SemanticProperties.Description="Up" />

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="1"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Display.FilesTitle}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                                    <Label Text="{Binding Display.FilesPath}"
                                           IsVisible="{Binding Display.IsFilesPathVisible}"
                                           FontSize="10"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                                    <Label Text="{Binding Display.FilesStatus}"
                                           IsVisible="{Binding Display.IsFilesStatusVisible}"
                                           FontSize="11"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                                </VerticalStackLayout>

                                <Button Grid.Column="2"
                                        Style="{StaticResource FileChromeButton}"
                                        Text="{Binding Display.FileSearchButtonText}"
                                        Command="{Binding ToggleFileSearchCommand}"
                                        Padding="0"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        VerticalOptions="Center"
                                        HeightRequest="44"
                                        MinimumHeightRequest="44"
                                        MinimumWidthRequest="44"
                                        WidthRequest="44"
                                        SemanticProperties.Description="{Binding Display.FileSearchButtonDescription}" />

                                <Button Grid.Column="3"
                                        Style="{StaticResource FileChromeButton}"
                                        Text="{Binding Display.FileSortButtonText}"
                                        Command="{Binding ShowFileSortActionsCommand}"
                                        Padding="0"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        VerticalOptions="Center"
                                        HeightRequest="44"
                                        MinimumHeightRequest="44"
                                        MinimumWidthRequest="44"
                                        WidthRequest="44"
                                        SemanticProperties.Description="Sort files" />

                                <Button Grid.Column="4"
                                        Style="{StaticResource FileChromeButton}"
                                        Text="{Binding Display.FileViewButtonText}"
                                        Command="{Binding ShowFileViewActionsCommand}"
                                        Padding="0"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        VerticalOptions="Center"
                                        HeightRequest="44"
                                        MinimumHeightRequest="44"
                                        MinimumWidthRequest="44"
                                        WidthRequest="44"
                                        SemanticProperties.Description="Change file view" />

                                <Button Grid.Column="5"
                                        Style="{StaticResource FileChromeButton}"
                                        Text="↻"
                                        Command="{Binding RefreshFilesCommand}"
                                        Padding="0"
                                        FontSize="17"
                                        FontAttributes="Bold"
                                        VerticalOptions="Center"
                                        HeightRequest="44"
                                        MinimumHeightRequest="44"
                                        MinimumWidthRequest="44"
                                        WidthRequest="44"
                                        SemanticProperties.Description="Refresh" />

                                <Button Grid.Column="6"
                                        Style="{StaticResource FileChromeButton}"
                                        Text="{Binding Display.ProfileInitials}"
                                        Command="{Binding AccountCommand}"
                                        IsEnabled="{Binding Display.IsAccountActionEnabled}"
                                        Padding="0"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        VerticalOptions="Center"
                                        HeightRequest="44"
                                        MinimumHeightRequest="44"
                                        MinimumWidthRequest="44"
                                        WidthRequest="44"
                                        SemanticProperties.Description="Account" />
                            </Grid>

                            <Label Text="{Binding Display.ProfileStatus}"
                                   IsVisible="{Binding Display.IsProfileStatusVisible}"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                            <Border IsVisible="{Binding Display.IsFilesNoticeVisible}"
                                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="12"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}">
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="10">
                                    <Border WidthRequest="28"
                                            HeightRequest="28"
                                            Stroke="{StaticResource Danger}"
                                            StrokeShape="RoundRectangle 14"
                                            StrokeThickness="1"
                                            BackgroundColor="Transparent"
                                            VerticalOptions="Start">
                                        <Label Text="!"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               TextColor="{StaticResource Danger}" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="2">
                                        <Label Text="{Binding Display.FilesNoticeTitle}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                                        <Label Text="{Binding Display.FilesNoticeMessage}"
                                               FontSize="12"
                                               MaxLines="2"
                                               LineBreakMode="WordWrap"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>

                            <SearchBar x:Name="FileSearchBar"
                                       Text="{Binding Display.FileSearchText, Mode=TwoWay}"
                                       IsVisible="{Binding Display.IsFileSearchVisible}"
                                       Placeholder="Search"
                                       HeightRequest="40"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}"
                                       PlaceholderColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />

                            <HorizontalStackLayout Spacing="12"
                                                   IsVisible="{Binding Display.IsFilesLoading}">
                                <ActivityIndicator IsRunning="{Binding Display.IsFilesLoading}"
                                                   VerticalOptions="Center" />

                                <Button Text="Cancel"
                                        Command="{Binding CancelFileActionCommand}"
                                        IsEnabled="{Binding Display.CanCancelFileAction}"
                                        IsVisible="{Binding Display.CanCancelFileAction}"
                                        Style="{StaticResource FileChromeButton}"
                                        Padding="12,0"
                                        MinimumHeightRequest="36"
                                        MinimumWidthRequest="72" />
                            </HorizontalStackLayout>

                            <Button Text="Retry"
                                    Command="{Binding RetryFileActionCommand}"
                                    IsEnabled="{Binding Display.CanRetryFileAction}"
                                    IsVisible="{Binding Display.CanRetryFileAction}"
                                    HorizontalOptions="Start"
                                    Padding="10,0"
                                    MinimumHeightRequest="32"
                                    MinimumWidthRequest="64" />

                            <Border IsVisible="{Binding Display.IsFilesEmptyVisible}"
                                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="24,34"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                                <VerticalStackLayout Spacing="8"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Display.FilesEmptyMessage}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                                    <Label Text="{Binding Display.FilesEmptyDetails}"
                                           IsVisible="{Binding Display.IsFilesEmptyDetailsVisible}"
                                           FontSize="12"
                                           MaxLines="2"
                                           LineBreakMode="WordWrap"
                                           HorizontalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                                </VerticalStackLayout>
                            </Border>

                            <VerticalStackLayout Spacing="0"
                                                 IsVisible="{Binding Display.IsFileListViewVisible}"
                                                 BindableLayout.ItemsSource="{Binding Display.FileEntries}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,10"
                                              HeightRequest="64"
                                              ColumnDefinitions="44,*"
                                              ColumnSpacing="12">
                                            <Border WidthRequest="36"
                                                    HeightRequest="36"
                                                    VerticalOptions="Center"
                                                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="0"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                                                <Grid>
                                                    <Image Source="{Binding Thumbnail.Source}"
                                                           Aspect="AspectFill"
                                                           IsVisible="{Binding IsPreviewImageVisible}" />

                                                    <Image Source="folder.svg"
                                                           Aspect="AspectFit"
                                                           IsVisible="{Binding IsFolderThumbnailVisible}"
                                                           HeightRequest="28"
                                                           WidthRequest="28"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center" />

                                                    <ActivityIndicator IsRunning="{Binding Thumbnail.IsLoading}"
                                                                       IsVisible="{Binding Thumbnail.IsLoading}"
                                                                       HorizontalOptions="Center"
                                                                       VerticalOptions="Center" />

                                                    <Label Text="{Binding Thumbnail.PlaceholderText}"
                                                           IsVisible="{Binding IsPlaceholderTextVisible}"
                                                           FontSize="{Binding Thumbnail.PlaceholderFontSize}"
                                                           FontAttributes="Bold"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="Center"
                                                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />
                                                </Grid>
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 VerticalOptions="Center"
                                                                 Spacing="2">
                                                <Label Text="{Binding Name}"
                                                       FontSize="15"
                                                       FontAttributes="Bold"
                                                       MaxLines="1"
                                                       LineBreakMode="TailTruncation"
                                                       TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                                                <Label Text="{Binding DisplayDetails}"
                                                       FontSize="12"
                                                       MaxLines="1"
                                                       LineBreakMode="TailTruncation"
                                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                                            </VerticalStackLayout>

                                            <Grid x:Name="ListEntryTouchSurface"
                                                  Grid.ColumnSpan="2"
                                                  BackgroundColor="Transparent">
                                                <Grid.Behaviors>
                                                    <behaviors:LongPressBehavior Command="{Binding BindingContext.ShowFileBrowserEntryActionsCommand, Source={x:Reference RootPage}}"
                                                                                 CommandParameter="{Binding BindingContext, Source={x:Reference ListEntryTouchSurface}}"
                                                                                 TapCommand="{Binding BindingContext.ActivateFileBrowserEntryCommand, Source={x:Reference RootPage}}"
                                                                                 TapCommandParameter="{Binding BindingContext, Source={x:Reference ListEntryTouchSurface}}" />
                                                </Grid.Behaviors>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <FlexLayout IsVisible="{Binding Display.IsFileTileViewVisible}"
                                        BindableLayout.ItemsSource="{Binding Display.FileEntries}"
                                        Wrap="Wrap"
                                        AlignItems="Start"
                                        HorizontalOptions="Fill"
                                        JustifyContent="Start">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Grid WidthRequest="{Binding Source={x:Reference RootPage}, Path=FileTileSlotWidth}"
                                              Padding="3,3,3,5">
                                            <Border HeightRequest="{Binding Source={x:Reference RootPage}, Path=FileTileHeight}"
                                                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="3"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                                                <Grid RowSpacing="2">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="{Binding Source={x:Reference RootPage}, Path=FileTilePreviewHeight}" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>

                                                    <Border HeightRequest="{Binding Source={x:Reference RootPage}, Path=FileTilePreviewHeight}"
                                                            HorizontalOptions="Fill"
                                                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                                            StrokeShape="RoundRectangle 8"
                                                            Padding="0"
                                                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                                                        <Grid>
                                                            <Image Source="{Binding Thumbnail.Source}"
                                                                   Aspect="AspectFill"
                                                                   IsVisible="{Binding IsPreviewImageVisible}" />

                                                            <Image Source="folder.svg"
                                                                   Aspect="AspectFit"
                                                                   IsVisible="{Binding IsFolderThumbnailVisible}"
                                                                   HeightRequest="{Binding Source={x:Reference RootPage}, Path=FileTileFolderIconSize}"
                                                                   WidthRequest="{Binding Source={x:Reference RootPage}, Path=FileTileFolderIconSize}"
                                                                   HorizontalOptions="Center"
                                                                   VerticalOptions="Center" />

                                                            <ActivityIndicator IsRunning="{Binding Thumbnail.IsLoading}"
                                                                               IsVisible="{Binding Thumbnail.IsLoading}"
                                                                               HorizontalOptions="Center"
                                                                               VerticalOptions="Center" />

                                                            <Label Text="{Binding Thumbnail.PlaceholderText}"
                                                                   IsVisible="{Binding IsPlaceholderTextVisible}"
                                                                   FontSize="{Binding Thumbnail.PlaceholderFontSize}"
                                                                   FontAttributes="Bold"
                                                                   HorizontalTextAlignment="Center"
                                                                   VerticalTextAlignment="Center"
                                                                   TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />
                                                        </Grid>
                                                    </Border>
                                                    <VerticalStackLayout Grid.Row="1"
                                                                         Spacing="1">
                                                        <Label Text="{Binding Name}"
                                                               FontSize="12"
                                                               FontAttributes="Bold"
                                                               MaxLines="1"
                                                               LineBreakMode="TailTruncation"
                                                               TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                                                        <Grid ColumnDefinitions="*,Auto"
                                                              ColumnSpacing="6">
                                                            <Label Text="{Binding Details}"
                                                                   FontSize="11"
                                                                   MaxLines="1"
                                                                   LineBreakMode="TailTruncation"
                                                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                                                            <Border Grid.Column="1"
                                                                    IsVisible="{Binding HasLocalCopy}"
                                                                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                                                    StrokeShape="RoundRectangle 8"
                                                                    Padding="5,1"
                                                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                                                                <Label Text="{Binding LocalCopyStatus}"
                                                                       FontSize="9"
                                                                       FontAttributes="Bold"
                                                                       MaxLines="1"
                                                                       LineBreakMode="NoWrap"
                                                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                                                            </Border>
                                                        </Grid>
                                                    </VerticalStackLayout>

                                                    <Grid x:Name="TileEntryTouchSurface"
                                                          Grid.RowSpan="2"
                                                          BackgroundColor="Transparent">
                                                        <Grid.Behaviors>
                                                            <behaviors:LongPressBehavior Command="{Binding BindingContext.ShowFileBrowserEntryActionsCommand, Source={x:Reference RootPage}}"
                                                                                         CommandParameter="{Binding BindingContext, Source={x:Reference TileEntryTouchSurface}}"
                                                                                         TapCommand="{Binding BindingContext.ActivateFileBrowserEntryCommand, Source={x:Reference RootPage}}"
                                                                                         TapCommandParameter="{Binding BindingContext, Source={x:Reference TileEntryTouchSurface}}" />
                                                        </Grid.Behaviors>
                                                    </Grid>

                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                        </VerticalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
        </RefreshView>

        <HorizontalStackLayout Grid.Row="1"
                               Spacing="12"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               IsVisible="{Binding Display.IsLegalFooterVisible}">
            <Label Text="Vadim Belov / bvdcode"
                   FontSize="12"
                   VerticalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />

            <Button Text="Privacy"
                    Command="{Binding PrivacyPolicyCommand}"
                    BackgroundColor="Transparent"
                    Padding="8,0"
                    MinimumHeightRequest="32"
                    MinimumWidthRequest="44"
                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
        </HorizontalStackLayout>
    </Grid>

</ContentPage>
