<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.SyncSettingsPage"
             x:Name="SyncPageRoot"
             x:DataType="viewModels:SyncSettingsViewModel"
             Shell.NavBarIsVisible="False"
             Title="Sync">

    <controls:ScreenShellView>
        <controls:TopAppBar PrimaryIconData="{x:Static controls:IconPathData.Play}"
                            PrimaryCommand="{Binding RunAllCommand}"
                            PrimaryDescription="Run all sync roots"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh sync settings" />

        <controls:ScreenScrollBodyView Grid.Row="1">
            <controls:ScreenHeaderView Title="Folders"
                                       SupportingText="{Binding SummaryText}"
                                       IsSupportingTextVisible="{Binding IsSummaryVisible}"
                                       IsBusy="{Binding IsBusy}" />

            <controls:ScreenStatusView Text="{Binding Status}"
                                       IsStatusVisible="{Binding IsStatusVisible}" />

            <controls:EmptyStateView IsStateVisible="{Binding IsEmptyVisible}"
                                     IconData="{x:Static controls:IconPathData.Folder}"
                                     Title="No folders yet"
                                     Body="Pick a folder in Files to enable sync."
                                     ActionText="Choose folder"
                                     ActionIconData="{x:Static controls:IconPathData.Folder}"
                                     ActionCommand="{Binding OpenFilesCommand}"
                                     IsActionVisible="True"
                                     ActionIconButtonStyleResourceKey="M3PrimaryFileChromeIconButton"
                                     ActionSemanticDescription="Choose sync folder" />

            <controls:StackedItemsView ItemsSource="{Binding Roots}">
                <controls:StackedItemsView.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonSyncRootListItem">
                        <controls:ContentCardView>
                            <controls:StackedContentView StackStyleResourceKey="M3SettingsDenseStack">
                                <controls:SettingsInfoItemView LeadingIconData="{x:Static controls:IconPathData.Folder}"
                                                               AttentionLeadingIconData="{x:Static controls:IconPathData.Error}"
                                                               IsAttentionState="{Binding IsAttentionVisible}"
                                                               LeadingIconFrameStyleResourceKey="M3CardSyncThumbnailFrame"
                                                               Title="{Binding Title}"
                                                               TitleTextStyleResourceKey="M3CardTitle"
                                                               PrimaryDetailText="{Binding PathText}"
                                                               SecondaryDetailText="{Binding DetailText}"
                                                               TrailingText="{Binding StatusText}" />

                                <controls:ActionClusterView ClusterStyleResourceKey="M3PanelActionCluster"
                                                            PrimaryActionIconData="{x:Static controls:IconPathData.Play}"
                                                            PrimaryActionCommand="{Binding BindingContext.RunRootCommand, Source={x:Reference SyncPageRoot}}"
                                                            PrimaryActionCommandParameter="{Binding .}"
                                                            PrimaryActionSemanticDescription="{Binding RunNowActionText}"
                                                            IsPrimaryActionEnabled="{Binding CanRunNow}"
                                                            IsPrimaryActionVisible="{Binding CanRunNow}"
                                                            SecondaryActionIconData="{x:Static controls:IconPathData.Pause}"
                                                            SecondaryActionCommand="{Binding BindingContext.PauseRootCommand, Source={x:Reference SyncPageRoot}}"
                                                            SecondaryActionCommandParameter="{Binding .}"
                                                            SecondaryActionSemanticDescription="{Binding PauseSyncActionText}"
                                                            IsSecondaryActionEnabled="{Binding CanPauseSync}"
                                                            IsSecondaryActionVisible="{Binding CanPauseSync}"
                                                            TertiaryActionIconData="{x:Static controls:IconPathData.Play}"
                                                            TertiaryActionCommand="{Binding BindingContext.ResumeRootCommand, Source={x:Reference SyncPageRoot}}"
                                                            TertiaryActionCommandParameter="{Binding .}"
                                                            TertiaryActionSemanticDescription="{Binding ResumeSyncActionText}"
                                                            IsTertiaryActionEnabled="{Binding CanResumeSync}"
                                                            IsTertiaryActionVisible="{Binding CanResumeSync}"
                                                            QuaternaryActionIconData="{x:Static controls:IconPathData.Delete}"
                                                            QuaternaryActionCommand="{Binding BindingContext.StopRootCommand, Source={x:Reference SyncPageRoot}}"
                                                            QuaternaryActionCommandParameter="{Binding .}"
                                                            QuaternaryActionIconButtonStyleResourceKey="M3DestructiveFileChromeIconButton"
                                                            QuaternaryActionSemanticDescription="{Binding StopSyncActionText}"
                                                            IsQuaternaryActionEnabled="{Binding CanStopSync}"
                                                            IsQuaternaryActionVisible="{Binding CanStopSync}" />
                            </controls:StackedContentView>
                        </controls:ContentCardView>
                    </DataTemplate>
                </controls:StackedItemsView.ItemTemplate>
            </controls:StackedItemsView>
        </controls:ScreenScrollBodyView>
    </controls:ScreenShellView>
</ContentPage>
