<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.TrashPage"
             x:Name="TrashRoot"
             x:DataType="viewModels:TrashViewModel"
             Shell.NavBarIsVisible="True"
             Title="Trash"
             BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Refresh"
                     Command="{Binding LoadCommand}" />
        <ToolbarItem Text="{Binding SelectionToolbarText}"
                     Command="{Binding ToggleSelectionModeCommand}" />
        <ToolbarItem Text="Empty"
                     Order="Secondary"
                     Priority="10"
                     Command="{Binding EmptyTrashCommand}" />
    </ContentPage.ToolbarItems>

    <Grid Padding="16"
          RowDefinitions="Auto,Auto,Auto,Auto,*"
          RowSpacing="14">
        <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto"
              ColumnSpacing="8">
            <VerticalStackLayout Spacing="2">
                <Label Text="Trash"
                       FontSize="28"
                       FontAttributes="Bold"
                       MaxLines="1"
                       LineBreakMode="TailTruncation"
                       TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                <Label Text="{Binding SummaryText}"
                       FontSize="13"
                       MaxLines="1"
                       LineBreakMode="TailTruncation"
                       TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
            </VerticalStackLayout>

            <Button Grid.Column="1"
                    Style="{StaticResource FileChromeButton}"
                    Text="{Binding SearchButtonText}"
                    Command="{Binding ToggleSearchCommand}"
                    Padding="0"
                    FontSize="15"
                    FontAttributes="Bold"
                    HeightRequest="44"
                    MinimumHeightRequest="44"
                    MinimumWidthRequest="44"
                    WidthRequest="44"
                    VerticalOptions="Center"
                    SemanticProperties.Description="{Binding SearchButtonDescription}" />

            <Button Grid.Column="2"
                    Style="{StaticResource FileChromeButton}"
                    Text="{Binding SortButtonText}"
                    Command="{Binding ShowSortActionsCommand}"
                    IsVisible="{Binding IsSortButtonVisible}"
                    Padding="0"
                    FontSize="12"
                    FontAttributes="Bold"
                    HeightRequest="44"
                    MinimumHeightRequest="44"
                    MinimumWidthRequest="44"
                    WidthRequest="44"
                    VerticalOptions="Center"
                    SemanticProperties.Description="Sort trash" />

            <Button Grid.Column="3"
                    Style="{StaticResource FileChromeButton}"
                    Text="{Binding ViewButtonText}"
                    Command="{Binding ShowViewActionsCommand}"
                    IsVisible="{Binding IsViewButtonVisible}"
                    Padding="0"
                    FontSize="15"
                    FontAttributes="Bold"
                    HeightRequest="44"
                    MinimumHeightRequest="44"
                    MinimumWidthRequest="44"
                    WidthRequest="44"
                    VerticalOptions="Center"
                    SemanticProperties.Description="Change trash view" />

            <ActivityIndicator Grid.Column="4"
                               IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               VerticalOptions="Center" />
        </Grid>

        <SearchBar Grid.Row="1"
                   Text="{Binding SearchText, Mode=TwoWay}"
                   IsVisible="{Binding IsSearchVisible}"
                   Placeholder="Search trash"
                   HeightRequest="40"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}"
                   PlaceholderColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

        <Label Grid.Row="2"
               Text="{Binding Status}"
               IsVisible="{Binding IsStatusVisible}"
               FontSize="13"
               MaxLines="2"
               LineBreakMode="TailTruncation"
               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

        <Border Grid.Row="3"
                IsVisible="{Binding IsSelectionBarVisible}"
                Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                StrokeShape="RoundRectangle 18"
                Padding="10,8"
                BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainer}, Dark={StaticResource M3DarkSurfaceContainer}}">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                  ColumnSpacing="8">
                <VerticalStackLayout Spacing="1"
                                     VerticalOptions="Center">
                    <Label Text="{Binding SelectionTitleText}"
                           FontSize="13"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Label Text="{Binding SelectionDetailText}"
                           FontSize="11"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Restore"
                        Command="{Binding RestoreSelectionCommand}"
                        IsEnabled="{Binding IsBulkActionEnabled}"
                        FontSize="12"
                        Padding="12,0"
                        HeightRequest="36"
                        MinimumHeightRequest="36"
                        VerticalOptions="Center" />

                <Button Grid.Column="2"
                        Text="Delete forever"
                        Command="{Binding DeleteForeverSelectionCommand}"
                        IsEnabled="{Binding IsBulkActionEnabled}"
                        FontSize="12"
                        Padding="12,0"
                        HeightRequest="36"
                        MinimumHeightRequest="36"
                        VerticalOptions="Center" />

                <Button Grid.Column="3"
                        Text="Cancel"
                        Command="{Binding CancelSelectionCommand}"
                        FontSize="12"
                        Padding="12,0"
                        HeightRequest="36"
                        MinimumHeightRequest="36"
                        VerticalOptions="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Border IsVisible="{Binding IsEmpty}"
                    Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                    StrokeShape="RoundRectangle 18"
                    Padding="28,36"
                    BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                <VerticalStackLayout Spacing="8"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <Label Text="{Binding EmptyMessage}"
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Label Text="{Binding EmptyDetails}"
                           FontSize="12"
                           MaxLines="2"
                           LineBreakMode="WordWrap"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                </VerticalStackLayout>
            </Border>

            <CollectionView ItemsSource="{Binding Items}"
                            IsVisible="{Binding IsListVisible}"
                            SelectionMode="None"
                            ItemSizingStrategy="MeasureFirstItem">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical"
                                       ItemSpacing="10" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonFileBrowserEntry">
                        <Border Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                                StrokeShape="RoundRectangle 18"
                                Padding="16"
                                BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsSelected}"
                                             Value="True">
                                    <Setter Property="Stroke"
                                            Value="{StaticResource M3Accent}" />
                                    <Setter Property="BackgroundColor"
                                            Value="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerHigh}, Dark={StaticResource M3DarkSurfaceContainerHigh}}" />
                                </DataTrigger>
                            </Border.Triggers>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BindingContext.ToggleSelectionCommand, Source={x:Reference TrashRoot}}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid RowDefinitions="Auto,Auto"
                                  ColumnDefinitions="*,Auto"
                                  RowSpacing="8"
                                  ColumnSpacing="10">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Name}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                                    <Label Text="{Binding DisplayDetails}"
                                           FontSize="12"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                                        StrokeShape="RoundRectangle 18"
                                        Padding="8,3"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerHigh}, Dark={StaticResource M3DarkSurfaceContainerHigh}}"
                                        VerticalOptions="Start">
                                    <Label Text="{Binding BadgeText}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           MaxLines="1"
                                           LineBreakMode="NoWrap"
                                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />
                                </Border>

                                <Border Grid.Column="1"
                                        IsVisible="{Binding IsSelected}"
                                        WidthRequest="20"
                                        HeightRequest="20"
                                        Stroke="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}"
                                        HorizontalOptions="End"
                                        VerticalOptions="End">
                                    <Label Text="✓"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}" />
                                </Border>

                                <HorizontalStackLayout Grid.Row="1"
                                                       Grid.ColumnSpan="2"
                                                       Spacing="8"
                                                       HorizontalOptions="End"
                                                       IsVisible="{Binding BindingContext.IsTrashEntryActionsVisible, Source={x:Reference TrashRoot}}">
                                    <Button Text="Delete forever"
                                            Command="{Binding BindingContext.DeleteForeverCommand, Source={x:Reference TrashRoot}}"
                                            CommandParameter="{Binding .}"
                                            FontSize="13"
                                            Padding="14,6"
                                            HeightRequest="36" />

                                    <Button Text="Restore"
                                            Command="{Binding BindingContext.RestoreCommand, Source={x:Reference TrashRoot}}"
                                            CommandParameter="{Binding .}"
                                            FontSize="13"
                                            Padding="14,6"
                                            HeightRequest="36" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <CollectionView ItemsSource="{Binding Items}"
                            IsVisible="{Binding IsTileVisible}"
                            SelectionMode="None"
                            ItemSizingStrategy="MeasureFirstItem">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="2"
                                     HorizontalItemSpacing="10"
                                     VerticalItemSpacing="10" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonFileBrowserEntry">
                        <Border Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                                StrokeShape="RoundRectangle 18"
                                Padding="12"
                                HeightRequest="190"
                                BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsSelected}"
                                             Value="True">
                                    <Setter Property="Stroke"
                                            Value="{StaticResource M3Accent}" />
                                    <Setter Property="BackgroundColor"
                                            Value="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerHigh}, Dark={StaticResource M3DarkSurfaceContainerHigh}}" />
                                </DataTrigger>
                            </Border.Triggers>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BindingContext.ToggleSelectionCommand, Source={x:Reference TrashRoot}}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid RowDefinitions="Auto,Auto,*,Auto"
                                  RowSpacing="6">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">
                                    <Label Text="{Binding Name}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                                    <Border Grid.Column="1"
                                            Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                                            StrokeShape="RoundRectangle 18"
                                            Padding="6,2"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerHigh}, Dark={StaticResource M3DarkSurfaceContainerHigh}}"
                                            VerticalOptions="Start">
                                        <Label Text="{Binding BadgeText}"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               MaxLines="1"
                                               LineBreakMode="NoWrap"
                                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />
                                    </Border>

                                    <Border Grid.Column="1"
                                            IsVisible="{Binding IsSelected}"
                                            WidthRequest="20"
                                            HeightRequest="20"
                                            Stroke="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 10"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}"
                                            HorizontalOptions="End"
                                            VerticalOptions="End">
                                        <Label Text="✓"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}" />
                                    </Border>
                                </Grid>

                                <Label Grid.Row="1"
                                       Text="{Binding DisplayDetails}"
                                       FontSize="11"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation"
                                       TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                                <VerticalStackLayout Grid.Row="3"
                                                     Spacing="6"
                                                     IsVisible="{Binding BindingContext.IsTrashEntryActionsVisible, Source={x:Reference TrashRoot}}">
                                    <Button Text="Delete forever"
                                            Command="{Binding BindingContext.DeleteForeverCommand, Source={x:Reference TrashRoot}}"
                                            CommandParameter="{Binding .}"
                                            FontSize="12"
                                            Padding="10,0"
                                            HeightRequest="34" />

                                    <Button Text="Restore"
                                            Command="{Binding BindingContext.RestoreCommand, Source={x:Reference TrashRoot}}"
                                            CommandParameter="{Binding .}"
                                            FontSize="12"
                                            Padding="10,0"
                                            HeightRequest="34" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
