<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="M3Accent">#C6FF00</Color>
    <Color x:Key="M3OnAccent">#151900</Color>
    <Color x:Key="M3DocumentSurface">#FFFFFF</Color>
    <Color x:Key="M3Transparent">Transparent</Color>
    <Color x:Key="M3Shadow">#000000</Color>

    <Color x:Key="M3LightSurface">#F7F8F7</Color>
    <Color x:Key="M3LightOnSurface">#181C1A</Color>
    <Color x:Key="M3LightOnSurfaceVariant">#424947</Color>
    <Color x:Key="M3LightSurfaceContainerLowest">#FFFFFF</Color>
    <Color x:Key="M3LightSurfaceContainerLow">#F0F2F0</Color>
    <Color x:Key="M3LightSurfaceContainer">#E8EBE9</Color>
    <Color x:Key="M3LightSurfaceContainerHigh">#E1E4E2</Color>
    <Color x:Key="M3LightSurfaceContainerHighest">#DADEDB</Color>
    <Color x:Key="M3LightOutline">#737A77</Color>
    <Color x:Key="M3LightOutlineVariant">#C1C7C4</Color>
    <Color x:Key="M3LightError">#BA1A1A</Color>
    <Color x:Key="M3LightPressedStateLayer">#1F181C1A</Color>
    <Color x:Key="M3LightScrim">#66000000</Color>

    <Color x:Key="M3DarkSurface">#090B0A</Color>
    <Color x:Key="M3DarkOnSurface">#E4E8E6</Color>
    <Color x:Key="M3DarkOnSurfaceVariant">#BEC7C2</Color>
    <Color x:Key="M3DarkSurfaceContainerLowest">#040605</Color>
    <Color x:Key="M3DarkSurfaceContainerLow">#111413</Color>
    <Color x:Key="M3DarkSurfaceContainer">#171A19</Color>
    <Color x:Key="M3DarkSurfaceContainerHigh">#202423</Color>
    <Color x:Key="M3DarkSurfaceContainerHighest">#2A2F2D</Color>
    <Color x:Key="M3DarkOutline">#89928E</Color>
    <Color x:Key="M3DarkOutlineVariant">#3F4944</Color>
    <Color x:Key="M3DarkError">#FFB4AB</Color>
    <Color x:Key="M3DarkPressedStateLayer">#1FE4E8E6</Color>
    <Color x:Key="M3DarkScrim">#99000000</Color>

    <SolidColorBrush x:Key="M3AccentBrush" Color="{StaticResource M3Accent}" />
    <SolidColorBrush x:Key="M3ShadowBrush" Color="{StaticResource M3Shadow}" />
</ResourceDictionary>
