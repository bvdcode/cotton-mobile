<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.TransfersPage"
             x:DataType="viewModels:TransfersViewModel"
             Shell.NavBarIsVisible="False"
             Title="Transfers"
             BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">

    <Grid RowDefinitions="Auto,*"
          BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">
        <controls:TopAppBar PrimaryIconData="{x:Static controls:IconPathData.Play}"
                            PrimaryCommand="{Binding RunWaitingCommand}"
                            PrimaryDescription="Run waiting transfers"
                            SecondaryIconData="{x:Static controls:IconPathData.Delete}"
                            SecondaryCommand="{Binding ClearHistoryCommand}"
                            SecondaryDescription="Clear transfer history"
                            IsTertiaryActionVisible="True"
                            TertiaryIconData="{x:Static controls:IconPathData.Refresh}"
                            TertiaryCommand="{Binding LoadCommand}"
                            TertiaryDescription="Refresh transfers" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Padding="18"
                             Spacing="16">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="{Binding SummaryText}"
                           Style="{StaticResource M3ScreenTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   Style="{StaticResource M3BodyMedium}"
                   MaxLines="2"
                   LineBreakMode="TailTruncation" />

            <Border IsVisible="{Binding IsEmpty}"
                    Style="{StaticResource M3SurfaceCard}"
                    Padding="24,34">
                <VerticalStackLayout Spacing="8"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <Label Text="{Binding EmptyMessage}"
                           Style="{StaticResource M3EmptyTitle}"
                           HorizontalTextAlignment="Center" />

                    <Label Text="{Binding EmptyDetails}"
                           Style="{StaticResource M3CardSupporting}"
                           MaxLines="2"
                           LineBreakMode="WordWrap"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="10"
                                 IsVisible="{Binding IsListVisible}"
                                 BindableLayout.ItemsSource="{Binding Items}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonTransferListItem">
                        <Border Style="{StaticResource M3SurfaceCard}"
                                Padding="16">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                  ColumnDefinitions="*,Auto"
                                  RowSpacing="6"
                                  ColumnSpacing="10">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding DisplayName}"
                                           Style="{StaticResource M3CardTitle}"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation" />

                                    <Label Text="{Binding DetailText}"
                                           Style="{StaticResource M3CardSupporting}"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                                        StrokeShape="RoundRectangle 18"
                                        Padding="8,3"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerHigh}, Dark={StaticResource M3DarkSurfaceContainerHigh}}"
                                        VerticalOptions="Start">
                                    <Label Text="{Binding StatusText}"
                                           Style="{StaticResource M3ChipLabel}"
                                           MaxLines="1"
                                           LineBreakMode="NoWrap" />
                                </Border>

                                <ProgressBar Grid.Row="1"
                                             Grid.ColumnSpan="2"
                                             Progress="{Binding ProgressFraction}"
                                             IsVisible="{Binding IsProgressVisible}"
                                             HeightRequest="4"
                                             ProgressColor="{StaticResource M3Accent}" />

                                <Label Grid.Row="2"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding ProgressText}"
                                       Style="{StaticResource M3CardSupporting}"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation" />

                                <Label Grid.Row="3"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding FailureMessage}"
                                       IsVisible="{Binding IsFailureVisible}"
                                       Style="{StaticResource M3ErrorSupporting}"
                                       MaxLines="2"
                                       LineBreakMode="WordWrap" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
