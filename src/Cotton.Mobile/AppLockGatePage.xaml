<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.AppLockGatePage"
             x:DataType="viewModels:AppLockGateViewModel"
             Shell.NavBarIsVisible="False"
             Title="Cotton locked">

    <Grid RowDefinitions="*,Auto,*"
          Style="{StaticResource M3AppLockGateGrid}">
        <Border Grid.Row="1"
                Style="{StaticResource M3AppLockCard}">
            <VerticalStackLayout Style="{StaticResource M3AppLockContentStack}">
                <Border Style="{StaticResource M3EmptyStateIconFrame}">
                    <controls:IconView IconData="{x:Static controls:IconPathData.Device}"
                                       Style="{StaticResource M3EmptyStateIcon}" />
                </Border>

                <Label Text="{Binding Title}"
                       Style="{StaticResource M3EmptyTitle}" />

                <Label Text="{Binding StatusText}"
                       Style="{StaticResource M3CardSupportingCenteredLongWrap}" />

                <controls:LoadingIndicatorView IsVisible="{Binding IsBusy}"
                                               IsRunning="{Binding IsBusy}" />

                <controls:FilledButton Text="{Binding UnlockActionText}"
                                       Command="{Binding UnlockCommand}"
                                       IsEnabled="{Binding CanUnlock}"
                                       Style="{StaticResource M3PanelActionFilledButton}" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
