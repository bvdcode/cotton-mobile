<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.AppLockGatePage"
             x:DataType="viewModels:AppLockGateViewModel"
             Shell.NavBarIsVisible="False"
             Title="Cotton locked">

    <Grid RowDefinitions="*,Auto,*"
          Style="{StaticResource M3AppLockGateGrid}">
        <controls:EmptyStateView Grid.Row="1"
                                 IconData="{x:Static controls:IconPathData.Device}"
                                 Title="{Binding Title}"
                                 Body="{Binding StatusText}"
                                 IsBusy="{Binding IsBusy}"
                                 ActionText="{Binding UnlockActionText}"
                                 ActionCommand="{Binding UnlockCommand}"
                                 ActionSemanticDescription="{Binding UnlockActionText}"
                                 IsActionEnabled="{Binding CanUnlock}"
                                 IsActionVisible="True"
                                 IsFilledAction="True"
                                 CardStyleResourceKey="M3AppLockCard" />
    </Grid>
</ContentPage>
