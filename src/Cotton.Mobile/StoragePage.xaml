<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.StoragePage"
             x:DataType="viewModels:StorageSettingsViewModel"
             Shell.NavBarIsVisible="True"
             Title="Storage"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Refresh"
                     Command="{Binding LoadCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="16"
                             Spacing="14">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="{Binding TotalSizeText}"
                           FontSize="32"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                    <Label Text="{Binding TotalFileCountText}"
                           FontSize="13"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                    <Label Text="App cache, downloads, and offline data"
                           FontSize="12"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   FontSize="13"
                   MaxLines="2"
                   LineBreakMode="TailTruncation"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

            <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="14"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                <VerticalStackLayout Spacing="8">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="{Binding CloudQuotaTitle, FallbackValue=Account storage, TargetNullValue=Account storage}"
                               FontSize="15"
                               FontAttributes="Bold"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                        <Label Text="{Binding CloudQuotaSummaryText, FallbackValue=Account storage unavailable., TargetNullValue=Account storage unavailable.}"
                               FontSize="13"
                               FontAttributes="Bold"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                        <Label Text="{Binding CloudQuotaDetailText, FallbackValue=This server does not report account quota., TargetNullValue=This server does not report account quota.}"
                               FontSize="12"
                               MaxLines="2"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                    </VerticalStackLayout>

                    <ProgressBar Progress="{Binding CloudQuotaUsageFraction}"
                                 IsVisible="{Binding IsCloudQuotaProgressVisible}"
                                 HeightRequest="4"
                                 ProgressColor="{StaticResource Primary}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Cleanup"
                   FontSize="15"
                   FontAttributes="Bold"
                   MaxLines="1"
                   LineBreakMode="TailTruncation"
                   TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                  ColumnDefinitions="*,*"
                  RowSpacing="10"
                  ColumnSpacing="10">
                <Button Grid.ColumnSpan="2"
                        Text="Free space"
                        Command="{Binding FreeDeviceSpaceCommand}"
                        Style="{StaticResource FileChromeButton}"
                        HeightRequest="44" />

                <Button Grid.Row="1"
                        Text="Clear thumbnails"
                        Command="{Binding ClearThumbnailsCommand}"
                        Style="{StaticResource FileChromeButton}"
                        HeightRequest="44" />

                <Button Grid.Row="1"
                        Grid.Column="1"
                        Text="Clear downloads"
                        Command="{Binding ClearDownloadedFilesCommand}"
                        Style="{StaticResource FileChromeButton}"
                        HeightRequest="44" />

                <Button Grid.Row="2"
                        Text="Clear lists"
                        Command="{Binding ClearFolderListingsCommand}"
                        Style="{StaticResource FileChromeButton}"
                        HeightRequest="44" />

                <Button Grid.Row="2"
                        Grid.Column="1"
                        Text="Clear temp uploads"
                        Command="{Binding ClearTemporaryUploadsCommand}"
                        Style="{StaticResource FileChromeButton}"
                        HeightRequest="44" />

                <Button Grid.Row="3"
                        Grid.ColumnSpan="2"
                        Text="Clear all"
                        Command="{Binding ClearAllCommand}"
                        Style="{StaticResource DestructiveChromeButton}"
                        HeightRequest="44" />
            </Grid>

            <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="14"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="On device"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   MaxLines="1"
                                   LineBreakMode="TailTruncation"
                                   TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                            <Label Text="{Binding OnDeviceSummaryText}"
                                   FontSize="12"
                                   MaxLines="2"
                                   LineBreakMode="TailTruncation"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="8"
                                         BindableLayout.ItemsSource="{Binding OnDeviceBuckets}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="services:CottonOnDeviceStorageBucketSnapshot">
                                <Grid RowDefinitions="Auto,Auto"
                                      ColumnDefinitions="*,Auto"
                                      RowSpacing="2"
                                      ColumnSpacing="10"
                                      IsVisible="{Binding IsVisible}">
                                    <Label Text="{Binding Title}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                                    <Label Grid.Column="1"
                                           Text="{Binding SizeText}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                                    <Label Grid.Row="1"
                                           Text="{Binding DetailText}"
                                           FontSize="12"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                                    <Label Grid.Row="1"
                                           Grid.Column="1"
                                           Text="{Binding CountText}"
                                           FontSize="12"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="14"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                <VerticalStackLayout Spacing="12">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Budget"
                               FontSize="15"
                               FontAttributes="Bold"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                        <Label Text="{Binding StorageBudgetSummaryText}"
                               FontSize="12"
                               MaxLines="2"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                        <Label Text="{Binding ProtectedOfflineText}"
                               FontSize="12"
                               MaxLines="2"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8"
                                         BindableLayout.ItemsSource="{Binding StorageBudgetBuckets}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="services:CottonStorageBudgetBucketSnapshot">
                                <Grid RowDefinitions="Auto,Auto,Auto"
                                      ColumnDefinitions="*,Auto"
                                      RowSpacing="2"
                                      ColumnSpacing="10"
                                      IsVisible="{Binding IsVisible}">
                                    <Label Text="{Binding Title}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                                    <Label Grid.Column="1"
                                           Text="{Binding UsageText}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                                    <Label Grid.Row="1"
                                           Text="{Binding DetailText}"
                                           FontSize="12"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                                    <Label Grid.Row="1"
                                           Grid.Column="1"
                                           Text="{Binding StatusText}"
                                           FontSize="12"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                                    <ProgressBar Grid.Row="2"
                                                 Grid.ColumnSpan="2"
                                                 Progress="{Binding UsageFraction}"
                                                 HeightRequest="4"
                                                 ProgressColor="{StaticResource Primary}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="14"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                <Grid RowDefinitions="Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="4">
                    <Label Text="Thumbnails"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                    <Label Grid.Column="1"
                           Text="{Binding ThumbnailSizeText}"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                    <Label Grid.Row="1"
                           Text="{Binding ThumbnailFileCountText}"
                           FontSize="12"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </Grid>
            </Border>

            <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="14"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                <Grid RowDefinitions="Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="4">
                    <Label Text="Offline folder lists"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                    <Label Grid.Column="1"
                           Text="{Binding FolderListingSizeText}"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                    <Label Grid.Row="1"
                           Text="{Binding FolderListingFileCountText}"
                           FontSize="12"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </Grid>
            </Border>

            <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="14"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                <Grid RowDefinitions="Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="4">
                    <Label Text="Downloaded files"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                    <Label Grid.Column="1"
                           Text="{Binding DownloadedSizeText}"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                    <Label Grid.Row="1"
                           Text="{Binding DownloadedFileCountText}"
                           FontSize="12"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </Grid>
            </Border>

            <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="14"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                <Grid RowDefinitions="Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="4">
                    <Label Text="Pending uploads"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                    <Label Grid.Column="1"
                           Text="{Binding TransferStagingSizeText}"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                    <Label Grid.Row="1"
                           Text="{Binding TransferStagingFileCountText}"
                           FontSize="12"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
