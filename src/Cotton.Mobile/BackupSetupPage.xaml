<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:Cotton.Mobile.Behaviors"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.BackupSetupPage"
             x:DataType="viewModels:BackupSetupViewModel"
             Shell.NavBarIsVisible="False"
             Title="Camera Backup">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Save}"
                            SecondaryCommand="{Binding SaveCommand}"
                            SecondaryDescription="Save camera backup" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Padding="{StaticResource M3ScreenPadding}"
                             Spacing="{StaticResource Space16}">
            <Grid ColumnDefinitions="*,Auto"
                  Style="{StaticResource M3ScreenHeaderGrid}">
                <VerticalStackLayout Style="{StaticResource M3ScreenHeaderTextStack}">
                    <Label Text="Camera Backup"
                           Style="{StaticResource M3ScreenTitle}" />

                    <Label Text="{Binding ExecutionStatusText}"
                           Style="{StaticResource M3ScreenHeaderSupportingMultiline}" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Style="{StaticResource M3ScreenHeaderActivityIndicator}" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   Style="{StaticResource M3ScreenStatus}" />

            <Border Style="{StaticResource M3ContentCard}">
                <Grid RowDefinitions="Auto,Auto"
                      ColumnDefinitions="Auto,*,Auto"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <controls:IconFrame Grid.RowSpan="2"
                                        IconData="{x:Static controls:IconPathData.Folder}"
                                        Style="{StaticResource M3FolderThumbnailFrame}"
                                        VerticalOptions="Start" />

                    <VerticalStackLayout Grid.Column="1"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="Destination"
                               Style="{StaticResource M3CardTitle}" />

                        <Label Text="{Binding DestinationText}"
                               Style="{StaticResource M3CardSupportingBlock}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="1"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="2"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="{Binding PolicySummaryText}"
                               Style="{StaticResource M3CardSupportingLine}" />

                        <Label Text="{Binding DestinationStorageEstimateTitle}"
                               Style="{StaticResource M3CardSupportingStrongLine}" />

                        <Label Text="{Binding DestinationStorageEstimateText}"
                               Style="{StaticResource M3CardSupportingBlock}" />
                    </VerticalStackLayout>

                    <Grid Grid.RowSpan="2"
                          Grid.ColumnSpan="3"
                          Style="{StaticResource M3ListItemTouchSurface}">
                        <Grid.Behaviors>
                            <behaviors:LongPressBehavior TapCommand="{Binding ChooseDestinationCommand}" />
                        </Grid.Behaviors>
                    </Grid>

                    <controls:IconButton Grid.Column="2"
                                         IconData="{x:Static controls:IconPathData.Folder}"
                                         Command="{Binding ChooseDestinationCommand}"
                                         Style="{StaticResource M3FileChromeIconButton}"
                                         SemanticProperties.Description="Choose backup destination" />
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="Auto,*,Auto"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <controls:IconFrame Grid.RowSpan="2"
                                        IconData="{x:Static controls:IconPathData.Image}"
                                        Style="{StaticResource M3CaptureThumbnailFrame}"
                                        VerticalOptions="Start" />

                    <VerticalStackLayout Grid.Column="1"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="{Binding MediaAccessTitle}"
                               Style="{StaticResource M3CardTitle}" />

                        <Label Text="{Binding MediaAccessDetailText}"
                               Style="{StaticResource M3CardSupportingBlock}" />
                    </VerticalStackLayout>

                    <Border Grid.Column="2"
                            Style="{StaticResource M3NeutralChip}">
                        <Label Text="{Binding MediaAccessStatusText}"
                               Style="{StaticResource M3ChipLabel}" />
                    </Border>

                    <Grid Grid.Row="2"
                          Grid.Column="1"
                          Grid.ColumnSpan="2"
                          ColumnDefinitions="*,Auto"
                          IsVisible="{Binding IsMediaAccessActionVisible}"
                          ColumnSpacing="{StaticResource Space12}">
                        <Label Text="{Binding MediaAccessActionText}"
                               Style="{StaticResource M3CardSupportingStrongLine}"
                               VerticalOptions="Center" />

                        <Grid Grid.ColumnSpan="2"
                              Style="{StaticResource M3ListItemTouchSurface}">
                            <Grid.Behaviors>
                                <behaviors:LongPressBehavior TapCommand="{Binding MediaAccessActionCommand}" />
                            </Grid.Behaviors>
                        </Grid>

                        <controls:IconButton Grid.Column="1"
                                             IconData="{x:Static controls:IconPathData.OpenInNew}"
                                             Command="{Binding MediaAccessActionCommand}"
                                             Style="{StaticResource M3PrimaryFileChromeIconButton}"
                                             SemanticProperties.Description="{Binding MediaAccessActionText}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <controls:IconFrame IconData="{x:Static controls:IconPathData.Activity}"
                                        Style="{StaticResource M3ActivityThumbnailFrame}"
                                        VerticalOptions="Start" />

                    <VerticalStackLayout Grid.Column="1"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="{Binding HealthTitle}"
                               Style="{StaticResource M3CardTitle}" />

                        <Label Text="{Binding HealthCountsText}"
                               Style="{StaticResource M3CardSupportingStrongBlock}" />

                        <Label Text="{Binding HealthStatusText}"
                               Style="{StaticResource M3CardSupportingBlock}" />
                    </VerticalStackLayout>

                    <Grid Grid.ColumnSpan="3"
                          Style="{StaticResource M3ListItemTouchSurface}">
                        <Grid.Behaviors>
                            <behaviors:LongPressBehavior TapCommand="{Binding QueueNowCommand}" />
                        </Grid.Behaviors>
                    </Grid>

                    <controls:IconButton Grid.Column="2"
                                         IconData="{x:Static controls:IconPathData.Play}"
                                         Command="{Binding QueueNowCommand}"
                                         Style="{StaticResource M3FileChromeIconButton}"
                                         SemanticProperties.Description="Queue camera backup now" />
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="Auto,*,Auto"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <controls:IconFrame Grid.RowSpan="3"
                                        IconData="{x:Static controls:IconPathData.Backup}"
                                        Style="{StaticResource M3CaptureThumbnailFrame}"
                                        VerticalOptions="Start" />

                    <VerticalStackLayout Grid.Column="1"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="Backup running"
                               Style="{StaticResource M3CardTitle}" />

                        <Label Text="{Binding LocalMediaRetentionText}"
                               Style="{StaticResource M3CardSupportingBlock}" />
                    </VerticalStackLayout>

                    <controls:ToggleSwitch Grid.Column="2"
                                           VerticalOptions="Center"
                                           IsEnabled="{Binding CanEnableBackup}"
                                           IsToggled="{Binding IsBackupEnabled, Mode=OneWay}" />

                    <Label Grid.Row="1"
                           Grid.Column="1"
                           Text="Photos only"
                           Style="{StaticResource M3LabelLargeLine}" />

                    <controls:ToggleSwitch Grid.Row="1"
                                           Grid.Column="2"
                                           VerticalOptions="Center"
                                           IsToggled="{Binding PhotosOnly, Mode=TwoWay}" />

                    <Label Grid.Row="2"
                           Grid.Column="1"
                           Text="While charging"
                           Style="{StaticResource M3LabelLargeLine}" />

                    <controls:ToggleSwitch Grid.Row="2"
                                           Grid.Column="2"
                                           VerticalOptions="Center"
                                           IsToggled="{Binding ChargingOnly, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource M3ContentCard}">
                <Grid RowDefinitions="Auto,Auto"
                      ColumnDefinitions="Auto,*,Auto"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <controls:IconFrame Grid.RowSpan="2"
                                        IconData="{x:Static controls:IconPathData.Transfer}"
                                        Style="{StaticResource M3TransferThumbnailFrame}"
                                        VerticalOptions="Start" />

                    <Label Grid.Column="1"
                           Text="Wi-Fi only"
                           Style="{StaticResource M3LabelLargeLine}" />

                    <controls:ToggleSwitch Grid.Column="2"
                                           VerticalOptions="Center"
                                           IsToggled="{Binding WifiOnly, Mode=TwoWay}" />

                    <Label Grid.Row="1"
                           Grid.Column="1"
                           Text="Allow cellular"
                           Style="{StaticResource M3LabelLargeLine}" />

                    <controls:ToggleSwitch Grid.Row="1"
                                           Grid.Column="2"
                                           VerticalOptions="Center"
                                           IsToggled="{Binding AllowCellular, Mode=TwoWay}" />
                </Grid>
            </Border>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
