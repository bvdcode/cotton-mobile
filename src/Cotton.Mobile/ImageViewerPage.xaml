<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.ImageViewerPage"
             x:DataType="viewModels:ImageViewerViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource M3DarkSurface}">

    <Grid RowDefinitions="Auto,*"
          BackgroundColor="{StaticResource M3DarkSurface}">
        <controls:TopAppBar TitleText="{Binding Title}"
                                  UseDarkTheme="True"
                                  PrimaryIconData="{x:Static controls:IconPathData.Share}"
                                  PrimaryCommand="{Binding ShareCommand}"
                                  PrimaryDescription="Share image"
                                  SecondaryIconData="{x:Static controls:IconPathData.OpenInNew}"
                                  SecondaryCommand="{Binding OpenExternallyCommand}"
                                  SecondaryDescription="Open image" />

        <Grid Grid.Row="1"
              BackgroundColor="{StaticResource M3DarkSurface}">
            <Grid x:Name="ImageSurface"
                  BackgroundColor="{StaticResource M3DarkSurface}">
                <Image x:Name="PreviewImage"
                       Source="{Binding ImageSource}"
                       Aspect="AspectFit"
                       HorizontalOptions="Fill"
                       VerticalOptions="Fill">
                    <Image.GestureRecognizers>
                        <PinchGestureRecognizer PinchUpdated="OnImagePinchUpdated" />
                        <PanGestureRecognizer PanUpdated="OnImagePanUpdated" />
                        <TapGestureRecognizer NumberOfTapsRequired="2"
                                              Tapped="OnImageDoubleTapped" />
                    </Image.GestureRecognizers>
                </Image>
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   Margin="{StaticResource M3ViewerStatusWithTrailingActionMargin}"
                   Style="{StaticResource M3DarkSupporting}"
                   MaxLines="1"
                   LineBreakMode="TailTruncation"
                   HorizontalOptions="Start"
                   VerticalOptions="End" />

            <controls:IconButton x:Name="ResetButton"
                                 IconData="{x:Static controls:IconPathData.Reset}"
                                 Style="{StaticResource M3ViewerOverlayIconButton}"
                                 Clicked="OnResetClicked"
                                 IsVisible="False"
                                 Margin="{StaticResource M3ViewerOverlayMargin}"
                                 HorizontalOptions="End"
                                 VerticalOptions="End"
                                 SemanticProperties.Description="Reset image" />
        </Grid>
    </Grid>
</ContentPage>
