    <Style TargetType="controls:IconButton" x:Key="M3FileChromeIconButton">
        <Setter Property="ButtonSize" Value="{StaticResource M3FileActionSize}" />
        <Setter Property="IconSize" Value="{StaticResource M3FileActionIconSize}" />
