<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:Cotton.Mobile.Behaviors"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.TrashPage"
             x:Name="TrashRoot"
             x:DataType="viewModels:TrashViewModel"
             Shell.NavBarIsVisible="False"
             Title="Trash">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar PrimaryIconData="{x:Static controls:IconPathData.Delete}"
                            PrimaryCommand="{Binding EmptyTrashCommand}"
                            PrimaryDescription="Empty trash"
                            SecondaryIconData="{x:Static controls:IconPathData.Check}"
                            SecondaryCommand="{Binding ToggleSelectionModeCommand}"
                            SecondaryDescription="{Binding SelectionToolbarText}"
                            IsTertiaryActionVisible="True"
                            TertiaryIconData="{x:Static controls:IconPathData.Refresh}"
                            TertiaryCommand="{Binding LoadCommand}"
                            TertiaryDescription="Refresh trash" />

        <Grid Grid.Row="1"
              RowDefinitions="Auto,Auto,Auto,Auto,*"
              Style="{StaticResource M3ScreenContentGrid}">
        <Grid ColumnDefinitions="*,Auto"
              Style="{StaticResource M3ScreenHeaderGrid}">
            <VerticalStackLayout Style="{StaticResource M3ScreenHeaderTextStack}">
                <Label Text="Trash"
                       Style="{StaticResource M3ScreenTitle}" />

                <Label Text="{Binding SummaryText}"
                       Style="{StaticResource M3ScreenHeaderSupporting}" />
            </VerticalStackLayout>

            <HorizontalStackLayout Grid.Column="1"
                                   Style="{StaticResource M3ScreenHeaderActionCluster}">
                <controls:IconButton IconData="{x:Static controls:IconPathData.Search}"
                                     Style="{StaticResource M3FileChromeIconButton}"
                                     Command="{Binding ToggleSearchCommand}"
                                     SemanticProperties.Description="{Binding SearchButtonDescription}">
                    <controls:IconButton.Triggers>
                        <DataTrigger TargetType="controls:IconButton"
                                     Binding="{Binding IsSearchVisible}"
                                     Value="True">
                            <Setter Property="IconData"
                                    Value="{x:Static controls:IconPathData.Close}" />
                        </DataTrigger>
                    </controls:IconButton.Triggers>
                </controls:IconButton>

                <controls:IconButton IconData="{x:Static controls:IconPathData.Sort}"
                                     Style="{StaticResource M3FileChromeIconButton}"
                                     Command="{Binding ShowSortActionsCommand}"
                                     IsVisible="{Binding IsSortButtonVisible}"
                                     SemanticProperties.Description="Sort trash" />

                <controls:IconButton IconData="{x:Static controls:IconPathData.ViewTiles}"
                                     Style="{StaticResource M3FileChromeIconButton}"
                                     Command="{Binding ShowViewActionsCommand}"
                                     IsVisible="{Binding IsViewButtonVisible}"
                                     SemanticProperties.Description="Change trash view" />

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Style="{StaticResource M3ScreenHeaderActivityIndicator}" />
            </HorizontalStackLayout>
        </Grid>

        <controls:OutlinedInputField Grid.Row="1"
                                     Text="{Binding SearchText, Mode=TwoWay}"
                                     IsVisible="{Binding IsSearchVisible}"
                                     Placeholder="Search trash"
                                     IconData="{x:Static controls:IconPathData.Search}"
                                     ReturnType="Search"
                                     ClearButtonVisibility="WhileEditing"
                                     SemanticHint="Search deleted files and folders" />

        <Label Grid.Row="2"
               Text="{Binding Status}"
               IsVisible="{Binding IsStatusVisible}"
               Style="{StaticResource M3ScreenStatus}" />

        <Border Grid.Row="3"
                IsVisible="{Binding IsSelectionBarVisible}"
                Style="{StaticResource M3SelectionBar}">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                  Style="{StaticResource M3SelectionBarGrid}">
                <VerticalStackLayout Style="{StaticResource M3SelectionTextStack}">
                    <Label Text="{Binding SelectionTitleText}"
                           Style="{StaticResource M3SelectionTitleText}" />

                    <Label Text="{Binding SelectionDetailText}"
                           Style="{StaticResource M3SelectionDetailText}" />
                </VerticalStackLayout>

                <controls:IconButton Grid.Column="1"
                                     IconData="{x:Static controls:IconPathData.Reset}"
                                     Command="{Binding RestoreSelectionCommand}"
                                     IsEnabled="{Binding IsBulkActionEnabled}"
                                     Style="{StaticResource M3FileChromeIconButton}"
                                     SemanticProperties.Description="Restore selected items" />

                <controls:IconButton Grid.Column="2"
                                     IconData="{x:Static controls:IconPathData.Delete}"
                                     Command="{Binding DeleteForeverSelectionCommand}"
                                     IsEnabled="{Binding IsBulkActionEnabled}"
                                     Style="{StaticResource M3DestructiveFileChromeIconButton}"
                                     SemanticProperties.Description="Delete selected items forever" />

                <controls:IconButton Grid.Column="3"
                                     IconData="{x:Static controls:IconPathData.Close}"
                                     Command="{Binding CancelSelectionCommand}"
                                     Style="{StaticResource M3FileChromeIconButton}"
                                     SemanticProperties.Description="Cancel selection" />
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <controls:EmptyStateView IsVisible="{Binding IsEmpty}"
                                     IconData="{x:Static controls:IconPathData.Delete}"
                                     Title="{Binding EmptyMessage}"
                                     Body="{Binding EmptyDetails}" />

            <CollectionView ItemsSource="{Binding Items}"
                            IsVisible="{Binding IsListVisible}"
                            SelectionMode="None"
                            ItemSizingStrategy="MeasureFirstItem"
                            ItemsLayout="{StaticResource M3VerticalCardListItemsLayout}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonFileBrowserEntry">
                        <Border Style="{StaticResource M3SelectableContentCard}">
                            <Grid RowDefinitions="Auto,Auto"
                                  ColumnDefinitions="Auto,*,Auto"
                                  Style="{StaticResource M3MetadataCardGrid}">
                                <Border Grid.RowSpan="2"
                                        Style="{StaticResource M3MetadataFileThumbnailSurface}">
                                    <Grid>
                                        <Image Source="{Binding Thumbnail.Source}"
                                               Aspect="AspectFill"
                                               IsVisible="{Binding IsPreviewImageVisible}" />

                                        <controls:IconView IconData="{x:Static controls:IconPathData.Folder}"
                                                           IsVisible="{Binding IsFolderThumbnailVisible}"
                                                           Style="{StaticResource M3FolderThumbnailIcon}" />

                                        <ActivityIndicator IsRunning="{Binding Thumbnail.IsLoading}"
                                                           IsVisible="{Binding Thumbnail.IsLoading}"
                                                           Style="{StaticResource M3ThumbnailActivityIndicator}" />

                                        <Label Text="{Binding Thumbnail.PlaceholderText}"
                                               IsVisible="{Binding IsPlaceholderTextVisible}"
                                               Style="{StaticResource M3DynamicThumbnailPlaceholder}" />
                                    </Grid>
                                </Border>

                                <Border Grid.Column="0"
                                        IsVisible="{Binding IsSelected}"
                                        Style="{StaticResource M3FileListSelectionMark}">
                                    <controls:IconView IconData="{x:Static controls:IconPathData.Check}"
                                                       Style="{StaticResource M3FileSelectionCheckIcon}" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1"
                                                     Style="{StaticResource M3CardTextStack}">
                                    <Label Text="{Binding Name}"
                                           Style="{StaticResource M3CardTitle}" />

                                    <Label Text="{Binding DisplayDetails}"
                                           Style="{StaticResource M3CardSupportingLine}" />
                                </VerticalStackLayout>

                                <Border Grid.Column="2"
                                        Style="{StaticResource M3NeutralChip}">
                                    <Label Text="{Binding BadgeText}"
                                           Style="{StaticResource M3ChipLabel}" />
                                </Border>

                                <Grid Grid.ColumnSpan="2"
                                      Style="{StaticResource M3ListItemTouchSurface}">
                                    <Grid.Behaviors>
                                        <behaviors:LongPressBehavior TapCommand="{Binding BindingContext.ToggleSelectionCommand, Source={x:Reference TrashRoot}}"
                                                                     TapCommandParameter="{Binding .}" />
                                    </Grid.Behaviors>
                                </Grid>

                                <HorizontalStackLayout Grid.Row="1"
                                                       Grid.Column="1"
                                                       Grid.ColumnSpan="2"
                                                       Style="{StaticResource M3RowActionCluster}"
                                                       IsVisible="{Binding BindingContext.IsTrashEntryActionsVisible, Source={x:Reference TrashRoot}}">
                                    <controls:IconButton IconData="{x:Static controls:IconPathData.Delete}"
                                                         Command="{Binding BindingContext.DeleteForeverCommand, Source={x:Reference TrashRoot}}"
                                                         CommandParameter="{Binding .}"
                                                         Style="{StaticResource M3DestructiveFileChromeIconButton}"
                                                         SemanticProperties.Description="{Binding Name, StringFormat='Delete {0} forever'}" />

                                    <controls:IconButton IconData="{x:Static controls:IconPathData.Reset}"
                                                         Command="{Binding BindingContext.RestoreCommand, Source={x:Reference TrashRoot}}"
                                                         CommandParameter="{Binding .}"
                                                         Style="{StaticResource M3FileChromeIconButton}"
                                                         SemanticProperties.Description="{Binding Name, StringFormat='Restore {0}'}" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <CollectionView ItemsSource="{Binding Items}"
                            IsVisible="{Binding IsTileVisible}"
                            SelectionMode="None"
                            ItemSizingStrategy="MeasureFirstItem"
                            ItemsLayout="{StaticResource M3TrashTileItemsLayout}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonFileBrowserEntry">
                        <Border Style="{StaticResource M3SelectableTrashTileCard}">
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  Style="{StaticResource M3FileTileContentGrid}">
                                <Border Style="{StaticResource M3TrashTilePreviewSurface}">
                                    <Grid>
                                        <Image Source="{Binding Thumbnail.Source}"
                                               Aspect="AspectFill"
                                               IsVisible="{Binding IsPreviewImageVisible}" />

                                        <controls:IconView IconData="{x:Static controls:IconPathData.Folder}"
                                                           IsVisible="{Binding IsFolderThumbnailVisible}"
                                                           Style="{StaticResource M3FolderThumbnailIcon}" />

                                        <ActivityIndicator IsRunning="{Binding Thumbnail.IsLoading}"
                                                           IsVisible="{Binding Thumbnail.IsLoading}"
                                                           Style="{StaticResource M3ThumbnailActivityIndicator}" />

                                        <Label Text="{Binding Thumbnail.PlaceholderText}"
                                               IsVisible="{Binding IsPlaceholderTextVisible}"
                                               Style="{StaticResource M3DynamicThumbnailPlaceholder}" />

                                        <Border Style="{StaticResource M3FileTileOverlayChip}">
                                            <Label Text="{Binding BadgeText}"
                                                   Style="{StaticResource M3ChipLabel}" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="0"
                                        IsVisible="{Binding IsSelected}"
                                        Style="{StaticResource M3FileTileSelectionMark}">
                                    <controls:IconView IconData="{x:Static controls:IconPathData.Check}"
                                                       Style="{StaticResource M3FileSelectionCheckIcon}" />
                                </Border>

                                <VerticalStackLayout Grid.Row="1"
                                                     Style="{StaticResource M3FileTileTextStack}">
                                    <Label Text="{Binding Name}"
                                           Style="{StaticResource M3CardSupportingStrongLine}" />

                                    <Label Text="{Binding DisplayDetails}"
                                           Style="{StaticResource M3CardMetaLine}" />
                                </VerticalStackLayout>

                                <Grid Grid.RowSpan="2"
                                      Style="{StaticResource M3ListItemTouchSurface}">
                                    <Grid.Behaviors>
                                        <behaviors:LongPressBehavior TapCommand="{Binding BindingContext.ToggleSelectionCommand, Source={x:Reference TrashRoot}}"
                                                                     TapCommandParameter="{Binding .}" />
                                    </Grid.Behaviors>
                                </Grid>

                                <HorizontalStackLayout Grid.Row="2"
                                                       Style="{StaticResource M3RowActionCluster}"
                                                       IsVisible="{Binding BindingContext.IsTrashEntryActionsVisible, Source={x:Reference TrashRoot}}">
                                    <controls:IconButton IconData="{x:Static controls:IconPathData.Delete}"
                                                         Command="{Binding BindingContext.DeleteForeverCommand, Source={x:Reference TrashRoot}}"
                                                         CommandParameter="{Binding .}"
                                                         Style="{StaticResource M3DestructiveFileChromeIconButton}"
                                                         SemanticProperties.Description="{Binding Name, StringFormat='Delete {0} forever'}" />

                                    <controls:IconButton IconData="{x:Static controls:IconPathData.Reset}"
                                                         Command="{Binding BindingContext.RestoreCommand, Source={x:Reference TrashRoot}}"
                                                         CommandParameter="{Binding .}"
                                                         Style="{StaticResource M3FileChromeIconButton}"
                                                         SemanticProperties.Description="{Binding Name, StringFormat='Restore {0}'}" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
        </Grid>
    </Grid>
</ContentPage>
