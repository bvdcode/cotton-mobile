<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.RecentFilesPage"
             x:Name="RecentFilesRoot"
             x:DataType="viewModels:RecentFilesViewModel"
             Shell.NavBarIsVisible="False"
             Title="Recent files">

    <controls:ScreenShellView>
        <controls:TopAppBar PrimaryIconData="{x:Static controls:IconPathData.Delete}"
                            PrimaryCommand="{Binding ClearRecentFilesCommand}"
                            PrimaryDescription="Clear recent files"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh recent files" />

        <controls:ScreenContentGridView Grid.Row="1">
        <controls:ScreenHeaderView Title="Recent files"
                                   SupportingText="{Binding SummaryText}"
                                   IsBusy="{Binding IsBusy}" />

        <controls:ScreenStatusView Grid.Row="1"
                                   Text="{Binding Status}"
                                   IsStatusVisible="{Binding IsStatusVisible}" />

        <controls:MetadataListSkeletonView Grid.Row="2"
                                           IsSkeletonVisible="{Binding IsLoadingPlaceholderVisible}"
                                           IsBodyLineVisible="False" />

        <controls:EmptyStateView Grid.Row="2"
                                 IsStateVisible="{Binding IsEmpty}"
                                 IconData="{x:Static controls:IconPathData.File}"
                                 Title="{Binding EmptyMessage}"
                                 Body="{Binding EmptyDetails}" />

        <controls:MaterialCollectionView Grid.Row="2"
                                         ItemsSource="{Binding Items}"
                                         IsContentVisible="{Binding IsListVisible}"
                                         ItemSizingStrategy="MeasureFirstItem"
                                         ItemsLayout="{StaticResource M3VerticalCardListItemsLayout}">
            <controls:MaterialCollectionView.ItemTemplate>
                <DataTemplate x:DataType="services:CottonRecentFileListItem">
                    <controls:ContentCardView>
                        <controls:ActionListItemView Text="{Binding FileName}"
                                                     SupportingText="{Binding DetailText}"
                                                     TrailingText="{Binding BadgeText}"
                                                     LeadingIconData="{x:Static controls:IconPathData.File}"
                                                     IsLeadingIconVisible="True"
                                                     LeadingIconFrameStyleResourceKey="M3FileThumbnailFrame"
                                                     ActionIconData="{x:Static controls:IconPathData.Delete}"
                                                     Command="{Binding BindingContext.RemoveRecentFileCommand, Source={x:Reference RecentFilesRoot}}"
                                                     CommandParameter="{Binding .}"
                                                     RowTapCommand="{Binding BindingContext.OpenRecentFileCommand, Source={x:Reference RecentFilesRoot}}"
                                                     RowTapCommandParameter="{Binding .}"
                                                     GridStyleResourceKey="M3SecondaryFileListItemGrid"
                                                     TextStackStyleResourceKey="M3SecondaryFileListTextStack"
                                                     TextStyleResourceKey="M3CardTitle"
                                                     SupportingTextStyleResourceKey="M3CardSupportingLine"
                                                     ActionSemanticDescription="Remove recent file"
                                                     SemanticDescription="{Binding FileName, StringFormat='Open {0}'}" />
                    </controls:ContentCardView>
                </DataTemplate>
            </controls:MaterialCollectionView.ItemTemplate>
        </controls:MaterialCollectionView>
        </controls:ScreenContentGridView>
    </controls:ScreenShellView>
</ContentPage>
