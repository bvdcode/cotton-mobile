<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             x:Class="Cotton.Mobile.Controls.TopAppBar"
             x:Name="Root"
             Padding="8,8,8,8"
             HeightRequest="64"
             BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">
    <ContentView.Triggers>
        <DataTrigger TargetType="ContentView"
                     Binding="{Binding Source={x:Reference Root}, Path=UseDarkTheme}"
                     Value="True">
            <Setter Property="BackgroundColor"
                    Value="{StaticResource M3DarkSurface}" />
        </DataTrigger>
    </ContentView.Triggers>

    <Grid ColumnDefinitions="44,*,44,44"
          ColumnSpacing="4"
          HeightRequest="48"
          VerticalOptions="Center">
        <controls:IconButton IconData="{x:Static controls:IconPathData.ArrowBack}"
                             IconColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}"
                             ButtonBackgroundColor="Transparent"
                             BorderColor="Transparent"
                             Clicked="OnBackClicked"
                             SemanticProperties.Description="Back">
            <controls:IconButton.Triggers>
                <DataTrigger TargetType="controls:IconButton"
                             Binding="{Binding Source={x:Reference Root}, Path=UseDarkTheme}"
                             Value="True">
                    <Setter Property="IconColor"
                            Value="{StaticResource M3DarkOnSurface}" />
                </DataTrigger>
            </controls:IconButton.Triggers>
        </controls:IconButton>

        <Label Grid.Column="1"
               Text="{Binding Source={x:Reference Root}, Path=TitleText}"
               FontSize="18"
               FontAttributes="Bold"
               MaxLines="1"
               LineBreakMode="TailTruncation"
               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}"
               VerticalOptions="Center">
            <Label.Triggers>
                <DataTrigger TargetType="Label"
                             Binding="{Binding Source={x:Reference Root}, Path=UseDarkTheme}"
                             Value="True">
                    <Setter Property="TextColor"
                            Value="{StaticResource M3DarkOnSurface}" />
                </DataTrigger>
            </Label.Triggers>
        </Label>

        <controls:IconButton Grid.Column="2"
                             IconData="{Binding Source={x:Reference Root}, Path=PrimaryIconData}"
                             IconColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}"
                             ButtonBackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}"
                             BorderColor="Transparent"
                             Command="{Binding Source={x:Reference Root}, Path=PrimaryCommand}"
                             IsVisible="{Binding Source={x:Reference Root}, Path=IsPrimaryActionVisible}"
                             SemanticProperties.Description="{Binding Source={x:Reference Root}, Path=PrimaryDescription}">
            <controls:IconButton.Triggers>
                <DataTrigger TargetType="controls:IconButton"
                             Binding="{Binding Source={x:Reference Root}, Path=UseDarkTheme}"
                             Value="True">
                    <Setter Property="IconColor"
                            Value="{StaticResource M3DarkOnSurface}" />
                    <Setter Property="ButtonBackgroundColor"
                            Value="{StaticResource M3DarkSurfaceContainerLow}" />
                </DataTrigger>
            </controls:IconButton.Triggers>
        </controls:IconButton>

        <controls:IconButton Grid.Column="3"
                             IconData="{Binding Source={x:Reference Root}, Path=SecondaryIconData}"
                             IconColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}"
                             ButtonBackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}"
                             BorderColor="Transparent"
                             Command="{Binding Source={x:Reference Root}, Path=SecondaryCommand}"
                             IsVisible="{Binding Source={x:Reference Root}, Path=IsSecondaryActionVisible}"
                             SemanticProperties.Description="{Binding Source={x:Reference Root}, Path=SecondaryDescription}">
            <controls:IconButton.Triggers>
                <DataTrigger TargetType="controls:IconButton"
                             Binding="{Binding Source={x:Reference Root}, Path=UseDarkTheme}"
                             Value="True">
                    <Setter Property="IconColor"
                            Value="{StaticResource M3DarkOnSurface}" />
                    <Setter Property="ButtonBackgroundColor"
                            Value="{StaticResource M3DarkSurfaceContainerLow}" />
                </DataTrigger>
            </controls:IconButton.Triggers>
        </controls:IconButton>
    </Grid>
</ContentView>
