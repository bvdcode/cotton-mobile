<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.CaptureDestinationPickerPage"
             x:DataType="viewModels:CaptureDestinationPickerViewModel"
             Shell.NavBarIsVisible="False"
             Title="Choose Destination"
             BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">

    <Grid RowDefinitions="Auto,*"
          BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh destinations" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Padding="18"
                             Spacing="16">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="{Binding CurrentFolderName}"
                           Style="{StaticResource M3ScreenTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Text="{Binding PathText}"
                           IsVisible="{Binding IsPathTextVisible}"
                           FontSize="13"
                           MaxLines="2"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   FontSize="13"
                   MaxLines="2"
                   LineBreakMode="TailTruncation"
                   TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="10">
                <Button Text="Up"
                        Command="{Binding UpCommand}"
                        Style="{StaticResource FileChromeButton}"
                        HeightRequest="44"
                        MinimumWidthRequest="78"
                        VerticalOptions="Center" />

                <Button Grid.Column="1"
                        Text="Choose this folder"
                        Command="{Binding ChooseCommand}"
                        HeightRequest="44"
                        VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding SummaryText}"
                   FontSize="13"
                   MaxLines="1"
                   LineBreakMode="TailTruncation"
                   TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

            <Border IsVisible="{Binding IsEmpty}"
                    Style="{StaticResource M3SurfaceCard}"
                    Padding="28,36">
                <VerticalStackLayout Spacing="8"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <Label Text="No folders here"
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Label Text="Choose this folder or go back."
                           FontSize="12"
                           MaxLines="2"
                           LineBreakMode="WordWrap"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="10"
                                 IsVisible="{Binding IsListVisible}"
                                 BindableLayout.ItemsSource="{Binding Folders}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:CaptureDestinationFolderItemViewModel">
                        <Border Style="{StaticResource M3SurfaceCard}"
                                Padding="16">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenCommand}" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <Label Text="{Binding DisplayName}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                                <Button Grid.Column="1"
                                        Text="Open"
                                        Command="{Binding OpenCommand}"
                                        Style="{StaticResource FileChromeButton}"
                                        HeightRequest="40"
                                        MinimumWidthRequest="76"
                                        VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
