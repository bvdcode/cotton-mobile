<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.TextViewerPage"
             x:DataType="viewModels:TextViewerViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar TitleText="{Binding Title}"
                                  PrimaryIconData="{x:Static controls:IconPathData.Share}"
                                  PrimaryCommand="{Binding ShareCommand}"
                                  PrimaryDescription="Share text"
                                  SecondaryIconData="{x:Static controls:IconPathData.MoreVertical}"
                                  SecondaryCommand="{Binding MoreCommand}"
                                  SecondaryDescription="More text actions" />

        <Grid Grid.Row="1"
              Padding="{StaticResource M3ScreenPadding}"
              RowDefinitions="Auto,*"
              RowSpacing="{StaticResource Space12}">
            <VerticalStackLayout Style="{StaticResource M3ScreenHeaderTextStack}">
                <Label Text="{Binding Details}"
                       Style="{StaticResource M3CardSupporting}"
                       MaxLines="1"
                       LineBreakMode="TailTruncation" />

                <Label Text="{Binding Status}"
                       IsVisible="{Binding IsStatusVisible}"
                       Style="{StaticResource M3CardSupporting}"
                       MaxLines="1"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <Editor Grid.Row="1"
                    Text="{Binding Content}"
                    IsReadOnly="True"
                    AutoSize="Disabled"
                    Style="{StaticResource TextViewerContentEditor}"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill" />
        </Grid>
    </Grid>
</ContentPage>
