<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.SyncSettingsPage"
             x:Name="SyncPageRoot"
             x:DataType="viewModels:SyncSettingsViewModel"
             Shell.NavBarIsVisible="False"
             Title="Sync">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar PrimaryIconData="{x:Static controls:IconPathData.Play}"
                            PrimaryCommand="{Binding RunAllCommand}"
                            PrimaryDescription="Run all sync roots"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh sync settings" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Style="{StaticResource M3ScreenContentStack}">
            <controls:ScreenHeaderView Title="Folders"
                                       SupportingText="{Binding SummaryText}"
                                       IsSupportingTextVisible="{Binding IsSummaryVisible}"
                                       IsBusy="{Binding IsBusy}" />

            <controls:ScreenStatusView Text="{Binding Status}"
                                       IsVisible="{Binding IsStatusVisible}" />

            <controls:EmptyStateView IsVisible="{Binding IsEmptyVisible}"
                                     IconData="{x:Static controls:IconPathData.Folder}"
                                     Title="No folders yet"
                                     Body="Pick a folder in Files to enable sync."
                                     ActionText="Choose folder"
                                     ActionIconData="{x:Static controls:IconPathData.Folder}"
                                     ActionCommand="{Binding OpenFilesCommand}"
                                     IsActionVisible="True"
                                     ActionIconButtonStyleResourceKey="M3PrimaryFileChromeIconButton"
                                     ActionSemanticDescription="Choose sync folder" />

            <VerticalStackLayout Style="{StaticResource M3SettingsSectionStack}"
                                 BindableLayout.ItemsSource="{Binding Roots}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonSyncRootListItem">
                        <Border Style="{StaticResource M3ContentCard}">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  RowDefinitions="Auto,Auto,Auto,Auto"
                                  Style="{StaticResource M3SettingsListItemGrid}">
                                <controls:IconFrame Grid.RowSpan="4"
                                                    IconData="{x:Static controls:IconPathData.Folder}"
                                                    Style="{StaticResource M3CardSyncThumbnailFrame}">
                                    <controls:IconFrame.Triggers>
                                        <DataTrigger TargetType="controls:IconFrame"
                                                     Binding="{Binding IsAttentionVisible}"
                                                     Value="True">
                                            <Setter Property="IconData"
                                                    Value="{x:Static controls:IconPathData.Error}" />
                                            <Setter Property="Style"
                                                    Value="{StaticResource M3CardErrorThumbnailFrame}" />
                                        </DataTrigger>
                                    </controls:IconFrame.Triggers>
                                </controls:IconFrame>

                                <Label Grid.Column="1"
                                       Text="{Binding Title}"
                                       Style="{StaticResource M3CardTitle}" />

                                <Label Grid.Column="2"
                                       Text="{Binding StatusText}"
                                       Style="{StaticResource M3CardSupportingLine}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding IsAttentionVisible}"
                                                     Value="True">
                                            <Setter Property="Style"
                                                    Value="{StaticResource M3ErrorSupportingLine}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <Label Grid.Row="1"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding PathText}"
                                       Style="{StaticResource M3CardSupportingLine}" />

                                <Label Grid.Row="2"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding DetailText}"
                                       Style="{StaticResource M3CardSupportingLine}" />

                                <HorizontalStackLayout Grid.Row="3"
                                                       Grid.Column="1"
                                                       Grid.ColumnSpan="2"
                                                       Style="{StaticResource M3PanelActionCluster}">
                                    <controls:IconButton IconData="{x:Static controls:IconPathData.Play}"
                                                         Command="{Binding BindingContext.RunRootCommand, Source={x:Reference SyncPageRoot}}"
                                                         CommandParameter="{Binding .}"
                                                         IsEnabled="{Binding CanRunNow}"
                                                         IsVisible="{Binding CanRunNow}"
                                                         Style="{StaticResource M3FileChromeIconButton}"
                                                         SemanticProperties.Description="{Binding RunNowActionText}" />

                                    <controls:IconButton IconData="{x:Static controls:IconPathData.Pause}"
                                                         Command="{Binding BindingContext.PauseRootCommand, Source={x:Reference SyncPageRoot}}"
                                                         CommandParameter="{Binding .}"
                                                         IsEnabled="{Binding CanPauseSync}"
                                                         IsVisible="{Binding CanPauseSync}"
                                                         Style="{StaticResource M3FileChromeIconButton}"
                                                         SemanticProperties.Description="{Binding PauseSyncActionText}" />

                                    <controls:IconButton IconData="{x:Static controls:IconPathData.Play}"
                                                         Command="{Binding BindingContext.ResumeRootCommand, Source={x:Reference SyncPageRoot}}"
                                                         CommandParameter="{Binding .}"
                                                         IsEnabled="{Binding CanResumeSync}"
                                                         IsVisible="{Binding CanResumeSync}"
                                                         Style="{StaticResource M3FileChromeIconButton}"
                                                         SemanticProperties.Description="{Binding ResumeSyncActionText}" />

                                    <controls:IconButton IconData="{x:Static controls:IconPathData.Delete}"
                                                         Command="{Binding BindingContext.StopRootCommand, Source={x:Reference SyncPageRoot}}"
                                                         CommandParameter="{Binding .}"
                                                         IsEnabled="{Binding CanStopSync}"
                                                         IsVisible="{Binding CanStopSync}"
                                                         Style="{StaticResource M3DestructiveFileChromeIconButton}"
                                                         SemanticProperties.Description="{Binding StopSyncActionText}" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
