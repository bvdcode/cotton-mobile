<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.AppLockGatePage"
             x:DataType="viewModels:AppLockGateViewModel"
             Shell.NavBarIsVisible="False"
             Title="Cotton locked"
             BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">

    <Grid Padding="24"
          RowDefinitions="*,Auto,*">
        <VerticalStackLayout Grid.Row="1"
                             Spacing="16"
                             HorizontalOptions="Fill">
            <Label Text="{Binding Title}"
                   Style="{StaticResource M3ScreenTitle}"
                   HorizontalTextAlignment="Center" />

            <Label Text="{Binding StatusText}"
                   Style="{StaticResource M3BodyMedium}"
                   MaxLines="3"
                   LineBreakMode="WordWrap"
                   HorizontalTextAlignment="Center" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" />

            <Button Text="{Binding UnlockActionText}"
                    Command="{Binding UnlockCommand}"
                    IsEnabled="{Binding CanUnlock}"
                    Style="{StaticResource M3PrimaryButton}"
                    HorizontalOptions="Fill" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
