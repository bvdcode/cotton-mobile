<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Cotton.Mobile.MainPage"
             x:Name="RootPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <Grid Padding="24"
          RowDefinitions="*,Auto">
        <RefreshView Grid.Row="0"
                     Command="{Binding RefreshFilesCommand}"
                     IsEnabled="{Binding Display.IsProfileVisible}"
                     IsRefreshing="{Binding Display.IsFilesRefreshing, Mode=TwoWay}">
        <ScrollView>
            <VerticalStackLayout Spacing="24"
                                 VerticalOptions="Center"
                                 MaximumWidthRequest="520">
                <Image Source="appiconfg.svg"
                       HeightRequest="92"
                       WidthRequest="92"
                       Aspect="AspectFit"
                       HorizontalOptions="Start"
                       SemanticProperties.Description="Cotton Cloud" />

                <VerticalStackLayout Spacing="8">
                    <Label Text="Cotton Cloud"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}"
                           SemanticProperties.HeadingLevel="Level1" />

                    <Label Text="Sign in to your Cotton instance"
                           FontSize="16"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding Display.IsLoadingVisible}"
                                     Spacing="12">
                    <ActivityIndicator IsRunning="{Binding Display.IsLoadingIndicatorRunning}"
                                       HorizontalOptions="Start" />

                    <Label Text="{Binding Display.LoadingMessage}"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding Display.IsSignInVisible}"
                                     Spacing="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Instance URL"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                        <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8"
                                Padding="12,2"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                            <Entry Text="{Binding Display.InstanceUrl, Mode=TwoWay}"
                                   Keyboard="Url"
                                   ReturnType="Go"
                                   ClearButtonVisibility="WhileEditing"
                                   IsEnabled="{Binding Display.IsInputEnabled}"
                                   ReturnCommand="{Binding ConnectCommand}"
                                   SemanticProperties.Hint="Cotton instance URL" />
                        </Border>

                        <Label Text="{Binding Display.Status}"
                               IsVisible="{Binding Display.IsStatusVisible}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                    </VerticalStackLayout>

                    <Button Text="Connect"
                            Command="{Binding ConnectCommand}"
                            IsEnabled="{Binding Display.IsInputEnabled}"
                            HorizontalOptions="Fill" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding Display.IsAuthorizationProgressVisible}"
                                     Spacing="16">
                    <ActivityIndicator IsRunning="{Binding Display.IsAuthorizationProgressIndicatorRunning}"
                                       HorizontalOptions="Start" />

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Waiting for browser approval"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                        <Label Text="{Binding Display.AuthorizationProgressMessage}"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                    </VerticalStackLayout>

                    <Button Text="Cancel"
                            Command="{Binding CancelAuthorizationCommand}"
                            IsEnabled="{Binding Display.IsCancelAuthorizationEnabled}"
                            HorizontalOptions="Fill" />
                </VerticalStackLayout>

                <Border IsVisible="{Binding Display.IsProfileVisible}"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                    <VerticalStackLayout Spacing="16">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Signed in"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                            <Label Text="{Binding Display.ProfileName}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                            <Label Text="{Binding Display.ProfileEmail}"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                        </VerticalStackLayout>

                        <Label Text="{Binding Display.ProfileInstance}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                        <Label Text="{Binding Display.ProfileStatus}"
                               IsVisible="{Binding Display.IsProfileStatusVisible}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                        <BoxView HeightRequest="1"
                                 Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="8">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Display.FilesTitle}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                                    <Label Text="{Binding Display.FilesPath}"
                                           IsVisible="{Binding Display.IsFilesPathVisible}"
                                           FontSize="12"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                                    <Label Text="{Binding Display.FilesStatus}"
                                           IsVisible="{Binding Display.IsFilesStatusVisible}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                                </VerticalStackLayout>

                                <Button Grid.Column="1"
                                        Text="Up"
                                        Command="{Binding NavigateFilesUpCommand}"
                                        IsEnabled="{Binding Display.CanNavigateFilesUp}"
                                        Padding="10,0"
                                        MinimumHeightRequest="32"
                                        MinimumWidthRequest="44" />

                                <Button Grid.Column="2"
                                        Text="Refresh"
                                        Command="{Binding RefreshFilesCommand}"
                                        Padding="10,0"
                                        MinimumHeightRequest="32"
                                        MinimumWidthRequest="44" />
                            </Grid>

                            <SearchBar Text="{Binding Display.FileSearchText, Mode=TwoWay}"
                                       Placeholder="Search"
                                       HeightRequest="44"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}"
                                       PlaceholderColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />

                            <Grid ColumnDefinitions="*,*,*,Auto"
                                  ColumnSpacing="8">
                                <Button Text="Name"
                                        Command="{Binding SortFilesByNameCommand}"
                                        IsEnabled="{Binding Display.CanSortByName}"
                                        Padding="8,0"
                                        MinimumHeightRequest="32"
                                        MinimumWidthRequest="52" />

                                <Button Grid.Column="1"
                                        Text="Type"
                                        Command="{Binding SortFilesByTypeCommand}"
                                        IsEnabled="{Binding Display.CanSortByType}"
                                        Padding="8,0"
                                        MinimumHeightRequest="32"
                                        MinimumWidthRequest="52" />

                                <Button Grid.Column="2"
                                        Text="Size"
                                        Command="{Binding SortFilesBySizeCommand}"
                                        IsEnabled="{Binding Display.CanSortBySize}"
                                        Padding="8,0"
                                        MinimumHeightRequest="32"
                                        MinimumWidthRequest="52" />

                                <Button Grid.Column="3"
                                        Text="{Binding Display.FileViewToggleText}"
                                        Command="{Binding ToggleFileViewCommand}"
                                        Padding="8,0"
                                        MinimumHeightRequest="32"
                                        MinimumWidthRequest="60" />
                            </Grid>

                            <HorizontalStackLayout Spacing="12"
                                                   IsVisible="{Binding Display.IsFilesLoading}">
                                <ActivityIndicator IsRunning="{Binding Display.IsFilesLoading}"
                                                   VerticalOptions="Center" />

                                <Button Text="Cancel"
                                        Command="{Binding CancelFileActionCommand}"
                                        IsEnabled="{Binding Display.CanCancelFileAction}"
                                        IsVisible="{Binding Display.CanCancelFileAction}"
                                        Padding="10,0"
                                        MinimumHeightRequest="32"
                                        MinimumWidthRequest="64" />
                            </HorizontalStackLayout>

                            <Button Text="Retry"
                                    Command="{Binding RetryFileActionCommand}"
                                    IsEnabled="{Binding Display.CanRetryFileAction}"
                                    IsVisible="{Binding Display.CanRetryFileAction}"
                                    HorizontalOptions="Start"
                                    Padding="10,0"
                                    MinimumHeightRequest="32"
                                    MinimumWidthRequest="64" />

                            <Label Text="{Binding Display.FilesEmptyMessage}"
                                   IsVisible="{Binding Display.IsFilesEmptyVisible}"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                            <VerticalStackLayout Spacing="0"
                                                 IsVisible="{Binding Display.IsFileListViewVisible}"
                                                 BindableLayout.ItemsSource="{Binding Display.FileEntries}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,10"
                                              HeightRequest="64"
                                              ColumnDefinitions="44,*,Auto"
                                              ColumnSpacing="12">
                                            <Border WidthRequest="36"
                                                    HeightRequest="36"
                                                    VerticalOptions="Center"
                                                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="0"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                                                <Grid>
                                                    <Image Source="{Binding Thumbnail.LocalPath}"
                                                           Aspect="AspectFill"
                                                           IsVisible="{Binding Thumbnail.HasImage}" />

                                                    <ActivityIndicator IsRunning="{Binding Thumbnail.IsLoading}"
                                                                       IsVisible="{Binding Thumbnail.IsLoading}"
                                                                       HorizontalOptions="Center"
                                                                       VerticalOptions="Center" />

                                                    <Label Text="{Binding Thumbnail.PlaceholderText}"
                                                           IsVisible="{Binding Thumbnail.IsPlaceholderVisible}"
                                                           FontSize="10"
                                                           FontAttributes="Bold"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="Center"
                                                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />
                                                </Grid>
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 VerticalOptions="Center"
                                                                 Spacing="2">
                                                <Label Text="{Binding Name}"
                                                       FontSize="15"
                                                       FontAttributes="Bold"
                                                       MaxLines="1"
                                                       LineBreakMode="TailTruncation"
                                                       TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                                                <Label Text="{Binding Details}"
                                                       FontSize="12"
                                                       MaxLines="1"
                                                       LineBreakMode="TailTruncation"
                                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                                            </VerticalStackLayout>

                                            <Button Grid.Column="2"
                                                    Text="{Binding ActionLabel}"
                                                    Command="{Binding BindingContext.OpenFileBrowserEntryCommand, Source={x:Reference RootPage}}"
                                                    CommandParameter="{Binding .}"
                                                    VerticalOptions="Center"
                                                    Padding="10,0"
                                                    MinimumHeightRequest="32"
                                                    MinimumWidthRequest="44" />
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <FlexLayout IsVisible="{Binding Display.IsFileTileViewVisible}"
                                        BindableLayout.ItemsSource="{Binding Display.FileEntries}"
                                        Wrap="Wrap"
                                        AlignItems="Start"
                                        JustifyContent="Start">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border WidthRequest="150"
                                                HeightRequest="132"
                                                Margin="0,0,8,8"
                                                Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 8"
                                                Padding="12"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                                            <Grid RowDefinitions="Auto,*,Auto"
                                                  RowSpacing="8">
                                                <Border WidthRequest="44"
                                                        HeightRequest="30"
                                                        HorizontalOptions="Start"
                                                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                                        StrokeShape="RoundRectangle 8"
                                                        Padding="0"
                                                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                                                    <Grid>
                                                        <Image Source="{Binding Thumbnail.LocalPath}"
                                                               Aspect="AspectFill"
                                                               IsVisible="{Binding Thumbnail.HasImage}" />

                                                        <ActivityIndicator IsRunning="{Binding Thumbnail.IsLoading}"
                                                                           IsVisible="{Binding Thumbnail.IsLoading}"
                                                                           HorizontalOptions="Center"
                                                                           VerticalOptions="Center" />

                                                        <Label Text="{Binding Thumbnail.PlaceholderText}"
                                                               IsVisible="{Binding Thumbnail.IsPlaceholderVisible}"
                                                               FontSize="10"
                                                               FontAttributes="Bold"
                                                               HorizontalTextAlignment="Center"
                                                               VerticalTextAlignment="Center"
                                                               TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />
                                                    </Grid>
                                                </Border>

                                                <VerticalStackLayout Grid.Row="1"
                                                                     Spacing="2">
                                                    <Label Text="{Binding Name}"
                                                           FontSize="14"
                                                           FontAttributes="Bold"
                                                           MaxLines="2"
                                                           LineBreakMode="TailTruncation"
                                                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                                                    <Label Text="{Binding Details}"
                                                           FontSize="11"
                                                           MaxLines="1"
                                                           LineBreakMode="TailTruncation"
                                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                                                </VerticalStackLayout>

                                                <Button Grid.Row="2"
                                                        Text="{Binding ActionLabel}"
                                                        Command="{Binding BindingContext.OpenFileBrowserEntryCommand, Source={x:Reference RootPage}}"
                                                        CommandParameter="{Binding .}"
                                                        Padding="8,0"
                                                        MinimumHeightRequest="30"
                                                        MinimumWidthRequest="44" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                        </VerticalStackLayout>

                        <Button Text="Log out"
                                Command="{Binding LogoutCommand}"
                                IsEnabled="{Binding Display.IsLogoutEnabled}"
                                HorizontalOptions="Fill" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
        </RefreshView>

        <HorizontalStackLayout Grid.Row="1"
                               Spacing="12"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">
            <Label Text="Vadim Belov / bvdcode"
                   FontSize="12"
                   VerticalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />

            <Button Text="Privacy"
                    Command="{Binding PrivacyPolicyCommand}"
                    BackgroundColor="Transparent"
                    Padding="8,0"
                    MinimumHeightRequest="32"
                    MinimumWidthRequest="44"
                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
        </HorizontalStackLayout>
    </Grid>

</ContentPage>
