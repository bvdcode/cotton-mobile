<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.SyncSettingsPage"
             x:Name="SyncPageRoot"
             x:DataType="viewModels:SyncSettingsViewModel"
             Shell.NavBarIsVisible="False"
             Title="Sync">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar PrimaryIconData="{x:Static controls:IconPathData.Play}"
                            PrimaryCommand="{Binding RunAllCommand}"
                            PrimaryDescription="Run all sync roots"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh sync settings" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Padding="{StaticResource M3ScreenPadding}"
                             Spacing="16">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Folders"
                           Style="{StaticResource M3ScreenTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Text="{Binding SummaryText}"
                           IsVisible="{Binding IsSummaryVisible}"
                           Style="{StaticResource M3BodyMedium}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   Style="{StaticResource M3BodyMedium}"
                   MaxLines="2"
                   LineBreakMode="TailTruncation" />

            <Border Style="{StaticResource M3SurfaceCard}"
                    Padding="16"
                    IsVisible="{Binding IsEmptyVisible}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="No folders yet"
                           Style="{StaticResource M3CardTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Text="Pick a folder in Files to enable sync."
                           Style="{StaticResource M3CardSupporting}"
                           MaxLines="2"
                           LineBreakMode="TailTruncation" />

                    <Button Text="Choose folder"
                            Command="{Binding OpenFilesCommand}"
                            Style="{StaticResource M3PrimaryButton}"
                            Margin="0,6,0,0"
                            HeightRequest="44" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="10"
                                 BindableLayout.ItemsSource="{Binding Roots}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonSyncRootListItem">
                        <Border Style="{StaticResource M3SurfaceCard}"
                                Padding="16">
                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto,Auto,Auto"
                                  RowSpacing="4"
                                  ColumnSpacing="12">
                                <Label Text="{Binding Title}"
                                       Style="{StaticResource M3CardTitle}"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation" />

                                <Label Grid.Column="1"
                                       Text="{Binding StatusText}"
                                       Style="{StaticResource M3CardSupporting}"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation" />

                                <Label Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding PathText}"
                                       Style="{StaticResource M3CardSupporting}"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation" />

                                <Label Grid.Row="2"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding DetailText}"
                                       Style="{StaticResource M3CardSupporting}"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation" />

                                <VerticalStackLayout Grid.Row="3"
                                                     Grid.ColumnSpan="2"
                                                     Spacing="8"
                                                     Margin="0,6,0,0">
                                    <Button Text="{Binding RunNowActionText}"
                                            Command="{Binding BindingContext.RunRootCommand, Source={x:Reference SyncPageRoot}}"
                                            CommandParameter="{Binding .}"
                                            IsEnabled="{Binding CanRunNow}"
                                            IsVisible="{Binding CanRunNow}"
                                            Style="{StaticResource FileChromeButton}"
                                            HeightRequest="40" />

                                    <Grid ColumnDefinitions="*,*"
                                          ColumnSpacing="8">
                                        <Button Text="{Binding PauseSyncActionText}"
                                                Command="{Binding BindingContext.PauseRootCommand, Source={x:Reference SyncPageRoot}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding CanPauseSync}"
                                                IsVisible="{Binding CanPauseSync}"
                                                Style="{StaticResource FileChromeButton}"
                                                HeightRequest="40" />

                                        <Button Text="{Binding ResumeSyncActionText}"
                                                Command="{Binding BindingContext.ResumeRootCommand, Source={x:Reference SyncPageRoot}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding CanResumeSync}"
                                                IsVisible="{Binding CanResumeSync}"
                                                Style="{StaticResource FileChromeButton}"
                                                HeightRequest="40" />

                                        <Button Grid.Column="1"
                                                Text="{Binding StopSyncActionText}"
                                                Command="{Binding BindingContext.StopRootCommand, Source={x:Reference SyncPageRoot}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding CanStopSync}"
                                                IsVisible="{Binding CanStopSync}"
                                                Style="{StaticResource DestructiveChromeButton}"
                                                HeightRequest="40" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
