<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.NotificationSettingsPage"
             x:DataType="viewModels:NotificationSettingsViewModel"
             Shell.NavBarIsVisible="True"
             Title="Notifications"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Refresh"
                     Command="{Binding LoadCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="16"
                             Spacing="14">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Notifications"
                           FontSize="28"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                    <Label Text="{Binding EnabledCategoriesText}"
                           FontSize="13"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   FontSize="13"
                   MaxLines="2"
                   LineBreakMode="TailTruncation"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

            <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="14"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="6"
                      ColumnSpacing="12">
                    <Label Text="{Binding PermissionTitle}"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                    <Label Grid.Column="1"
                           Text="{Binding PermissionStatusText}"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding PermissionDetailText}"
                           FontSize="12"
                           MaxLines="2"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                    <Button Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Text="{Binding PermissionActionText}"
                            Command="{Binding PermissionActionCommand}"
                            IsVisible="{Binding IsPermissionActionVisible}"
                            Style="{StaticResource FileChromeButton}"
                            HeightRequest="44"
                            HorizontalOptions="Fill" />
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
