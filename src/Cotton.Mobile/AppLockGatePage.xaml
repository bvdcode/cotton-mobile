<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.AppLockGatePage"
             x:DataType="viewModels:AppLockGateViewModel"
             Shell.NavBarIsVisible="False"
             Title="Cotton locked">

    <Grid Padding="{StaticResource M3AppLockGatePadding}"
          RowDefinitions="*,Auto,*">
        <Border Grid.Row="1"
                Style="{StaticResource M3EmptyStateCard}"
                MaximumWidthRequest="{StaticResource M3AuthPanelMaxWidth}"
                HorizontalOptions="Fill">
            <VerticalStackLayout Spacing="{StaticResource Space16}"
                                 HorizontalOptions="Fill">
                <Border Style="{StaticResource M3EmptyStateIconFrame}">
                    <controls:IconView IconData="{x:Static controls:IconPathData.Device}"
                                       Style="{StaticResource M3EmptyStateIcon}" />
                </Border>

                <Label Text="{Binding Title}"
                       Style="{StaticResource M3EmptyTitle}" />

                <Label Text="{Binding StatusText}"
                       Style="{StaticResource M3CardSupporting}"
                       MaxLines="3"
                       LineBreakMode="WordWrap"
                       HorizontalTextAlignment="Center" />

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   HorizontalOptions="Center" />

                <controls:FilledButton Text="{Binding UnlockActionText}"
                                       Command="{Binding UnlockCommand}"
                                       IsEnabled="{Binding CanUnlock}"
                                       Style="{StaticResource M3AuthFilledButton}"
                                       HorizontalOptions="Fill"
                                       Margin="{StaticResource M3PanelActionTopMargin}" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
