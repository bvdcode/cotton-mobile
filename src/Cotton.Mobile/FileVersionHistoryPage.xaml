<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.FileVersionHistoryPage"
             x:DataType="viewModels:FileVersionHistoryViewModel"
             Shell.NavBarIsVisible="False"
             Title="Version history">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh versions" />

        <Grid Grid.Row="1"
              Padding="{StaticResource M3ScreenPadding}"
              RowDefinitions="Auto,Auto,*"
              RowSpacing="{StaticResource Space16}">
        <Grid ColumnDefinitions="*,Auto"
              Style="{StaticResource M3ScreenHeaderGrid}">
            <VerticalStackLayout Style="{StaticResource M3ScreenHeaderTextStack}">
                <Label Text="Version history"
                       Style="{StaticResource M3ScreenTitle}" />

                <Label Text="{Binding FileName}"
                       Style="{StaticResource M3CardTitle}" />

                <Label Text="{Binding SummaryText}"
                       Style="{StaticResource M3ScreenHeaderSupportingMultiline}" />
            </VerticalStackLayout>

            <ActivityIndicator Grid.Column="1"
                               IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Style="{StaticResource M3ScreenHeaderActivityIndicator}" />
        </Grid>

        <Label Grid.Row="1"
               Text="{Binding Status}"
               IsVisible="{Binding IsStatusVisible}"
               Style="{StaticResource M3ScreenStatus}" />

            <Grid Grid.Row="2">
                <Border IsVisible="{Binding IsEmpty}"
                        Style="{StaticResource M3EmptyStateCard}">
                    <VerticalStackLayout Style="{StaticResource M3EmptyStateStack}">
                        <Border Style="{StaticResource M3EmptyStateIconFrame}">
                            <controls:IconView IconData="{x:Static controls:IconPathData.File}"
                                               Style="{StaticResource M3EmptyStateIcon}" />
                        </Border>

                        <Label Text="{Binding EmptyMessage}"
                               Style="{StaticResource M3EmptyTitle}" />

                        <Label Text="{Binding EmptyDetails}"
                               Style="{StaticResource M3EmptyBody}" />
                    </VerticalStackLayout>
                </Border>

                <CollectionView ItemsSource="{Binding Items}"
                                IsVisible="{Binding IsListVisible}"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                           ItemSpacing="{StaticResource Space12}" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="services:CottonFileVersionItemSnapshot">
                            <Border Style="{StaticResource M3ContentCard}">
                                <Grid RowDefinitions="Auto,Auto,Auto"
                                      ColumnDefinitions="Auto,*,Auto"
                                      RowSpacing="{StaticResource Space8}"
                                      ColumnSpacing="{StaticResource Space12}">
                                    <controls:IconFrame Grid.RowSpan="3"
                                                        IconData="{x:Static controls:IconPathData.File}"
                                                        Style="{StaticResource M3FileThumbnailFrame}"
                                                        VerticalOptions="Start" />

                                    <VerticalStackLayout Grid.Column="1"
                                                         Style="{StaticResource M3CardTextStack}">
                                        <Label Text="{Binding VersionText}"
                                               Style="{StaticResource M3CardTitle}" />

                                        <Label Text="{Binding Name}"
                                               Style="{StaticResource M3CardSupporting}"
                                               MaxLines="1"
                                               LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>

                                    <Border Grid.Column="2"
                                            Style="{StaticResource M3NeutralChip}">
                                        <Label Text="{Binding KindText}"
                                               Style="{StaticResource M3ChipLabel}"
                                               MaxLines="1"
                                               LineBreakMode="NoWrap" />
                                    </Border>

                                    <Label Grid.Row="1"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding DetailText}"
                                           Style="{StaticResource M3CardSupporting}"
                                           MaxLines="2"
                                           LineBreakMode="WordWrap" />

                                    <Label Grid.Row="2"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding ContentTypeText}"
                                           Style="{StaticResource M3CardMeta}"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
