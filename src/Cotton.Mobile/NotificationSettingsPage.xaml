<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.NotificationSettingsPage"
             x:DataType="viewModels:NotificationSettingsViewModel"
             Shell.NavBarIsVisible="False"
             Title="Notifications">

    <controls:ScreenShellView>
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh notifications" />

        <controls:ScreenScrollBodyView Grid.Row="1">
            <controls:ScreenHeaderView Title="Notifications"
                                       SupportingText="{Binding EnabledCategoriesText}"
                                       IsBusy="{Binding IsBusy}" />

            <controls:AttentionStatusView IsStatusVisible="{Binding IsAttentionStatusVisible}"
                                          Message="{Binding Status}"
                                          IconData="{x:Static controls:IconPathData.Error}"
                                          ActionIconData="{x:Static controls:IconPathData.Refresh}"
                                          ActionCommand="{Binding LoadCommand}"
                                          IsRowTapEnabled="True"
                                          GridStyleResourceKey="M3ActionListItemGrid"
                                          ActionSemanticDescription="Retry notifications" />

            <controls:ScreenStatusView Text="{Binding Status}"
                                       IsStatusVisible="{Binding IsNeutralStatusVisible}" />

            <controls:SettingsCardView>
                <controls:SettingsSummaryHeaderView Title="On this device"
                                                    StatusText="{Binding PermissionStatusText}"
                                                    DetailText="{Binding PermissionDetailText}"
                                                    StatusStyleResourceKey="M3CardTitle" />

                <controls:ActionListItemView Text="{Binding PermissionActionText}"
                                             LeadingIconData="{x:Static controls:IconPathData.Activity}"
                                             IsLeadingIconVisible="True"
                                             LeadingIconFrameStyleResourceKey="M3CardActivityThumbnailFrame"
                                             ActionIconData="{x:Static controls:IconPathData.OpenInNew}"
                                             Command="{Binding PermissionActionCommand}"
                                             IsItemVisible="{Binding IsPermissionActionVisible}"
                                             GridStyleResourceKey="M3SettingsListItemGrid"
                                             ActionIconButtonStyleResourceKey="M3PrimaryIconButton"
                                             SemanticDescription="{Binding PermissionActionText}" />
            </controls:SettingsCardView>

            <controls:SettingsCardView>
                <controls:SettingsSummaryHeaderView Title="Cloud alerts"
                                                    StatusText="{Binding RemotePushStatusText}"
                                                    IsStatusVisible="{Binding IsRemotePushStatusVisible}"
                                                    IsDetailVisible="False" />

                <controls:ActionListItemView Text="{Binding RemotePushUnavailableTitle}"
                                             SupportingText="{Binding RemotePushUnavailableDetail}"
                                             IsItemVisible="{Binding IsRemotePushUnavailable}"
                                             LeadingIconData="{x:Static controls:IconPathData.Error}"
                                             IsLeadingIconVisible="True"
                                             LeadingIconFrameStyleResourceKey="M3AttentionActionListItemIconFrame"
                                             ActionIconData="{x:Static controls:IconPathData.Refresh}"
                                             Command="{Binding LoadCommand}"
                                             GridStyleResourceKey="M3SettingsListItemGrid"
                                             TextStyleResourceKey="M3CardTitle"
                                             ActionSemanticDescription="Retry cloud alerts" />

                <controls:StackedItemsView IsContentVisible="{Binding HasRemotePushPreferences}"
                                           ItemsSource="{Binding RemotePushPreferences}">
                    <controls:StackedItemsView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:RemotePushPreferenceItemViewModel">
                            <controls:SettingsToggleItemView Text="{Binding Title}"
                                                             SupportingText="{Binding DetailText}"
                                                             IsLeadingIconVisible="False"
                                                             SupportingTextStyleResourceKey="M3CardSupportingBlock"
                                                             IsEnabled="{Binding CanToggle}"
                                                             IsToggled="{Binding IsEnabled, Mode=TwoWay}" />
                        </DataTemplate>
                    </controls:StackedItemsView.ItemTemplate>
                </controls:StackedItemsView>
            </controls:SettingsCardView>
        </controls:ScreenScrollBodyView>
    </controls:ScreenShellView>
</ContentPage>
