<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.SyncSettingsPage"
             x:Name="SyncPageRoot"
             x:DataType="viewModels:SyncSettingsViewModel"
             Shell.NavBarIsVisible="False"
             Title="Sync">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar PrimaryIconData="{x:Static controls:IconPathData.Play}"
                            PrimaryCommand="{Binding RunAllCommand}"
                            PrimaryDescription="Run all sync roots"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh sync settings" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Padding="{StaticResource M3ScreenPadding}"
                             Spacing="{StaticResource Space16}">
            <Grid ColumnDefinitions="*,Auto"
                  Style="{StaticResource M3ScreenHeaderGrid}">
                <VerticalStackLayout Style="{StaticResource M3ScreenHeaderTextStack}">
                    <Label Text="Folders"
                           Style="{StaticResource M3ScreenTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Text="{Binding SummaryText}"
                           IsVisible="{Binding IsSummaryVisible}"
                           Style="{StaticResource M3BodyMedium}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Style="{StaticResource M3ScreenHeaderActivityIndicator}" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   Style="{StaticResource M3ScreenStatus}" />

            <Border Style="{StaticResource M3EmptyStateCard}"
                    IsVisible="{Binding IsEmptyVisible}">
                <VerticalStackLayout Style="{StaticResource M3EmptyStateStack}">
                    <Border Style="{StaticResource M3EmptyStateIconFrame}">
                        <controls:IconView IconData="{x:Static controls:IconPathData.Folder}"
                                           Style="{StaticResource M3EmptyStateIcon}" />
                    </Border>

                    <Label Text="No folders yet"
                           Style="{StaticResource M3CardTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           HorizontalTextAlignment="Center" />

                    <Label Text="Pick a folder in Files to enable sync."
                           Style="{StaticResource M3CardSupporting}"
                           MaxLines="2"
                           LineBreakMode="WordWrap"
                           HorizontalTextAlignment="Center" />

                    <Grid ColumnDefinitions="Auto,Auto"
                          ColumnSpacing="{StaticResource Space12}"
                          Margin="{StaticResource M3PanelActionTopMargin}">
                        <Label Text="Choose folder"
                               Style="{StaticResource M3CardSupportingStrong}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               VerticalOptions="Center" />

                        <controls:IconButton Grid.Column="1"
                                             IconData="{x:Static controls:IconPathData.Folder}"
                                             Command="{Binding OpenFilesCommand}"
                                             Style="{StaticResource M3PrimaryFileChromeIconButton}"
                                             SemanticProperties.Description="Choose sync folder" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="{StaticResource Space12}"
                                 BindableLayout.ItemsSource="{Binding Roots}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonSyncRootListItem">
                        <Border Style="{StaticResource M3ContentCard}">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  RowDefinitions="Auto,Auto,Auto,Auto"
                                  RowSpacing="{StaticResource Space4}"
                                  ColumnSpacing="{StaticResource Space12}">
                                <controls:IconFrame Grid.RowSpan="4"
                                                    IconData="{x:Static controls:IconPathData.Folder}"
                                                    Style="{StaticResource M3SyncThumbnailFrame}"
                                                    VerticalOptions="Start">
                                    <controls:IconFrame.Triggers>
                                        <DataTrigger TargetType="controls:IconFrame"
                                                     Binding="{Binding IsAttentionVisible}"
                                                     Value="True">
                                            <Setter Property="IconData"
                                                    Value="{x:Static controls:IconPathData.Error}" />
                                            <Setter Property="IconColor"
                                                    Value="{AppThemeBinding Light={StaticResource M3LightError}, Dark={StaticResource M3DarkError}}" />
                                        </DataTrigger>
                                    </controls:IconFrame.Triggers>
                                </controls:IconFrame>

                                <Label Grid.Column="1"
                                       Text="{Binding Title}"
                                       Style="{StaticResource M3CardTitle}"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation" />

                                <Label Grid.Column="2"
                                       Text="{Binding StatusText}"
                                       Style="{StaticResource M3CardSupporting}"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding IsAttentionVisible}"
                                                     Value="True">
                                            <Setter Property="TextColor"
                                                    Value="{AppThemeBinding Light={StaticResource M3LightError}, Dark={StaticResource M3DarkError}}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <Label Grid.Row="1"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding PathText}"
                                       Style="{StaticResource M3CardSupporting}"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation" />

                                <Label Grid.Row="2"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding DetailText}"
                                       Style="{StaticResource M3CardSupporting}"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation" />

                                <HorizontalStackLayout Grid.Row="3"
                                                       Grid.Column="1"
                                                       Grid.ColumnSpan="2"
                                                       Spacing="{StaticResource Space8}"
                                                       Margin="{StaticResource M3PanelActionTopMargin}"
                                                       HorizontalOptions="End">
                                    <controls:IconButton IconData="{x:Static controls:IconPathData.Play}"
                                                         Command="{Binding BindingContext.RunRootCommand, Source={x:Reference SyncPageRoot}}"
                                                         CommandParameter="{Binding .}"
                                                         IsEnabled="{Binding CanRunNow}"
                                                         IsVisible="{Binding CanRunNow}"
                                                         Style="{StaticResource M3FileChromeIconButton}"
                                                         SemanticProperties.Description="{Binding RunNowActionText}" />

                                    <controls:IconButton IconData="{x:Static controls:IconPathData.Pause}"
                                                         Command="{Binding BindingContext.PauseRootCommand, Source={x:Reference SyncPageRoot}}"
                                                         CommandParameter="{Binding .}"
                                                         IsEnabled="{Binding CanPauseSync}"
                                                         IsVisible="{Binding CanPauseSync}"
                                                         Style="{StaticResource M3FileChromeIconButton}"
                                                         SemanticProperties.Description="{Binding PauseSyncActionText}" />

                                    <controls:IconButton IconData="{x:Static controls:IconPathData.Play}"
                                                         Command="{Binding BindingContext.ResumeRootCommand, Source={x:Reference SyncPageRoot}}"
                                                         CommandParameter="{Binding .}"
                                                         IsEnabled="{Binding CanResumeSync}"
                                                         IsVisible="{Binding CanResumeSync}"
                                                         Style="{StaticResource M3FileChromeIconButton}"
                                                         SemanticProperties.Description="{Binding ResumeSyncActionText}" />

                                    <controls:IconButton IconData="{x:Static controls:IconPathData.Delete}"
                                                         Command="{Binding BindingContext.StopRootCommand, Source={x:Reference SyncPageRoot}}"
                                                         CommandParameter="{Binding .}"
                                                         IsEnabled="{Binding CanStopSync}"
                                                         IsVisible="{Binding CanStopSync}"
                                                         Style="{StaticResource M3DestructiveFileChromeIconButton}"
                                                         SemanticProperties.Description="{Binding StopSyncActionText}" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
