<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.PdfViewerPage"
             x:DataType="viewModels:PdfViewerViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource M3DarkSurface}">

    <Grid RowDefinitions="Auto,*"
          BackgroundColor="{StaticResource M3DarkSurface}">
        <controls:TopAppBar TitleText="{Binding Title}"
                                  UseDarkTheme="True"
                                  PrimaryIconData="{x:Static controls:IconPathData.Share}"
                                  PrimaryCommand="{Binding ShareCommand}"
                                  PrimaryDescription="Share PDF"
                                  SecondaryIconData="{x:Static controls:IconPathData.OpenInNew}"
                                  SecondaryCommand="{Binding OpenExternallyCommand}"
                                  SecondaryDescription="Open PDF" />

        <Grid Grid.Row="1"
              RowDefinitions="Auto,*"
              BackgroundColor="{StaticResource M3DarkSurface}">
            <VerticalStackLayout Padding="{StaticResource M3PdfHeaderPadding}"
                                 Style="{StaticResource M3ScreenHeaderTextStack}">
                <Label Text="{Binding Details}"
                       Style="{StaticResource M3DarkSupporting}"
                       MaxLines="1"
                       LineBreakMode="TailTruncation" />

                <Label Text="{Binding Status}"
                       IsVisible="{Binding IsStatusVisible}"
                       Style="{StaticResource M3DarkSupporting}"
                       MaxLines="1"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Pages}"
                            IsVisible="{Binding IsPreviewVisible}"
                            BackgroundColor="{StaticResource M3DarkSurface}"
                            ItemSizingStrategy="MeasureAllItems">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical"
                                       ItemSpacing="{StaticResource M3PdfPageSpacing}" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:PdfPreviewPageSnapshot">
                        <Grid Padding="{StaticResource M3PdfPagePadding}">
                            <Border Style="{StaticResource M3PdfPageSurface}">
                                <Image Source="{Binding ImageSource}"
                                       Aspect="AspectFit"
                                       HeightRequest="{Binding DisplayHeight}"
                                       BackgroundColor="{StaticResource M3DocumentSurface}"
                                       HorizontalOptions="Fill" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid Grid.Row="1"
                  IsVisible="{Binding IsEmptyVisible}"
                  Padding="{StaticResource M3PdfEmptyPadding}">
                <Border Style="{StaticResource M3ViewerEmptyStateCard}"
                        HorizontalOptions="Fill"
                        VerticalOptions="Center">
                    <VerticalStackLayout Style="{StaticResource M3EmptyStateStack}">
                        <Border Style="{StaticResource M3ViewerEmptyStateIconFrame}">
                            <controls:IconView IconData="{x:Static controls:IconPathData.File}"
                                               Style="{StaticResource M3EmptyStateIcon}" />
                        </Border>

                        <Label Text="{Binding EmptyText}"
                               Style="{StaticResource M3DarkEmptyTitle}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
