<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.BackupSetupPage"
             x:DataType="viewModels:BackupSetupViewModel"
             Shell.NavBarIsVisible="False"
             Title="Camera Backup">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Save}"
                            SecondaryCommand="{Binding SaveCommand}"
                            SecondaryDescription="Save camera backup" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Style="{StaticResource M3ScreenContentStack}">
            <controls:ScreenHeaderView Title="Camera Backup"
                                       SupportingText="{Binding ExecutionStatusText}"
                                       IsSupportingTextMultiline="True"
                                       IsBusy="{Binding IsBusy}" />

            <controls:ScreenStatusView Text="{Binding Status}"
                                       IsVisible="{Binding IsStatusVisible}" />

            <controls:SettingsCardView>
                <Grid RowDefinitions="Auto,Auto"
                      ColumnDefinitions="Auto,*,Auto"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <controls:IconFrame Grid.RowSpan="2"
                                        IconData="{x:Static controls:IconPathData.Folder}"
                                        Style="{StaticResource M3CardFolderThumbnailFrame}" />

                    <VerticalStackLayout Grid.Column="1"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="Destination"
                               Style="{StaticResource M3CardTitle}" />

                        <Label Text="{Binding DestinationText}"
                               Style="{StaticResource M3CardSupportingBlock}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="1"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="2"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="{Binding PolicySummaryText}"
                               Style="{StaticResource M3CardSupportingLine}" />

                        <Label Text="{Binding DestinationStorageEstimateTitle}"
                               Style="{StaticResource M3CardSupportingStrongLine}" />

                        <Label Text="{Binding DestinationStorageEstimateText}"
                               Style="{StaticResource M3CardSupportingBlock}" />
                    </VerticalStackLayout>

                    <controls:TouchSurfaceView Grid.RowSpan="2"
                                               Grid.ColumnSpan="3"
                                               TapCommand="{Binding ChooseDestinationCommand}" />

                    <controls:ActionClusterView Grid.Column="2"
                                                ClusterStyleResourceKey="M3InlineActionCluster"
                                                PrimaryActionIconData="{x:Static controls:IconPathData.Folder}"
                                                PrimaryActionCommand="{Binding ChooseDestinationCommand}"
                                                PrimaryActionSemanticDescription="Choose backup destination" />
                </Grid>
            </controls:SettingsCardView>

            <controls:SettingsCardView>
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="Auto,*,Auto"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <controls:IconFrame Grid.RowSpan="2"
                                        IconData="{x:Static controls:IconPathData.Image}"
                                        Style="{StaticResource M3CardCaptureThumbnailFrame}" />

                    <VerticalStackLayout Grid.Column="1"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="{Binding MediaAccessTitle}"
                               Style="{StaticResource M3CardTitle}" />

                        <Label Text="{Binding MediaAccessDetailText}"
                               Style="{StaticResource M3CardSupportingBlock}" />
                    </VerticalStackLayout>

                    <controls:ChipView Grid.Column="2"
                                       Text="{Binding MediaAccessStatusText}" />

                    <controls:ActionListItemView Grid.Row="2"
                                                 Grid.Column="1"
                                                 Grid.ColumnSpan="2"
                                                 Text="{Binding MediaAccessActionText}"
                                                 ActionIconData="{x:Static controls:IconPathData.OpenInNew}"
                                                 Command="{Binding MediaAccessActionCommand}"
                                                 IsVisible="{Binding IsMediaAccessActionVisible}"
                                                 ActionIconButtonStyleResourceKey="M3PrimaryFileChromeIconButton"
                                                 SemanticDescription="{Binding MediaAccessActionText}" />
                </Grid>
            </controls:SettingsCardView>

            <controls:SettingsCardView>
                <Grid ColumnDefinitions="Auto,*,Auto"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <controls:IconFrame IconData="{x:Static controls:IconPathData.Activity}"
                                        Style="{StaticResource M3CardActivityThumbnailFrame}" />

                    <VerticalStackLayout Grid.Column="1"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="{Binding HealthTitle}"
                               Style="{StaticResource M3CardTitle}" />

                        <Label Text="{Binding HealthCountsText}"
                               Style="{StaticResource M3CardSupportingStrongBlock}" />

                        <Label Text="{Binding HealthStatusText}"
                               Style="{StaticResource M3CardSupportingBlock}" />
                    </VerticalStackLayout>

                    <controls:TouchSurfaceView Grid.ColumnSpan="3"
                                               TapCommand="{Binding QueueNowCommand}" />

                    <controls:ActionClusterView Grid.Column="2"
                                                ClusterStyleResourceKey="M3InlineActionCluster"
                                                PrimaryActionIconData="{x:Static controls:IconPathData.Play}"
                                                PrimaryActionCommand="{Binding QueueNowCommand}"
                                                PrimaryActionSemanticDescription="Queue camera backup now" />
                </Grid>
            </controls:SettingsCardView>

            <controls:SettingsCardView>
                <controls:SettingsToggleItemView Text="Camera backup"
                                                 SupportingText="{Binding LocalMediaRetentionText}"
                                                 LeadingIconData="{x:Static controls:IconPathData.Backup}"
                                                 LeadingIconFrameStyleResourceKey="M3CardCaptureThumbnailFrame"
                                                 IsEnabled="{Binding CanEnableBackup}"
                                                 IsToggled="{Binding IsBackupEnabled, Mode=OneWay}"
                                                 SemanticDescription="Camera backup" />

                <controls:SettingsToggleItemView Text="Photos only"
                                                 SupportingText="Skip videos during camera backup."
                                                 LeadingIconData="{x:Static controls:IconPathData.Image}"
                                                 LeadingIconFrameStyleResourceKey="M3CardCaptureThumbnailFrame"
                                                 IsToggled="{Binding PhotosOnly, Mode=TwoWay}" />

                <controls:SettingsToggleItemView Text="Require charging"
                                                 SupportingText="Run backup only while the phone is plugged in."
                                                 LeadingIconData="{x:Static controls:IconPathData.Device}"
                                                 LeadingIconFrameStyleResourceKey="M3CardUtilityThumbnailFrame"
                                                 IsToggled="{Binding ChargingOnly, Mode=TwoWay}" />
            </controls:SettingsCardView>

            <controls:SettingsCardView>
                <controls:SettingsToggleItemView Text="Wi-Fi only"
                                                 SupportingText="Pause uploads on mobile networks."
                                                 LeadingIconData="{x:Static controls:IconPathData.Transfer}"
                                                 LeadingIconFrameStyleResourceKey="M3CardTransferThumbnailFrame"
                                                 IsToggled="{Binding WifiOnly, Mode=TwoWay}" />

                <controls:SettingsToggleItemView Text="Cellular uploads"
                                                 SupportingText="Allow uploads when Wi-Fi is unavailable."
                                                 LeadingIconData="{x:Static controls:IconPathData.Cloud}"
                                                 LeadingIconFrameStyleResourceKey="M3CardTransferThumbnailFrame"
                                                 IsToggled="{Binding AllowCellular, Mode=TwoWay}" />
            </controls:SettingsCardView>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
