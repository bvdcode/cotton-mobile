<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.ActivityFeedPage"
             x:DataType="viewModels:ActivityFeedViewModel"
             Shell.NavBarIsVisible="False"
             Title="Activity">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh activity" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Padding="18"
                             Spacing="16">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Activity"
                           Style="{StaticResource M3ScreenTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Text="{Binding SummaryText}"
                           Style="{StaticResource M3BodyMedium}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   Style="{StaticResource M3BodyMedium}"
                   MaxLines="2"
                   LineBreakMode="TailTruncation" />

            <Border IsVisible="{Binding IsEmpty}"
                    Style="{StaticResource M3SurfaceCard}"
                    Padding="28,36">
                <VerticalStackLayout Spacing="8"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <Label Text="{Binding EmptyMessage}"
                           Style="{StaticResource M3EmptyTitle}"
                           HorizontalTextAlignment="Center" />

                    <Label Text="{Binding EmptyDetails}"
                           Style="{StaticResource M3CardSupporting}"
                           MaxLines="2"
                           LineBreakMode="WordWrap"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="10"
                                 IsVisible="{Binding IsListVisible}"
                                 BindableLayout.ItemsSource="{Binding Items}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="services:CottonActivityFeedListItem">
                        <Border Style="{StaticResource M3SurfaceCard}"
                                Padding="16">
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  ColumnDefinitions="*,Auto"
                                  RowSpacing="6"
                                  ColumnSpacing="10">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Title}"
                                           Style="{StaticResource M3CardTitle}"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation" />

                                    <Label Text="{Binding DetailText}"
                                           Style="{StaticResource M3CardSupporting}"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        Style="{StaticResource M3NeutralChip}">
                                    <Label Text="{Binding BadgeText}"
                                           Style="{StaticResource M3ChipLabel}"
                                           MaxLines="1"
                                           LineBreakMode="NoWrap" />
                                </Border>

                                <Label Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding ContentText}"
                                       IsVisible="{Binding IsContentVisible}"
                                       Style="{StaticResource M3CardSupporting}"
                                       MaxLines="3"
                                       LineBreakMode="WordWrap" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Button Text="Load more"
                    Command="{Binding LoadMoreCommand}"
                    IsVisible="{Binding IsLoadMoreVisible}"
                    Style="{StaticResource FileChromeButton}"
                    HorizontalOptions="Fill" />
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
