<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:Cotton.Mobile.Behaviors"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             x:Class="Cotton.Mobile.MainPage"
             x:Name="RootPage"
             Shell.NavBarIsVisible="False">

    <Grid x:Name="RootLayout"
          RowDefinitions="*,Auto,Auto"
          Style="{StaticResource M3MainPageRootGrid}">
        <ScrollView Grid.Row="0"
                    IsVisible="{Binding Display.IsBrandHeaderVisible}">
            <VerticalStackLayout Style="{StaticResource M3MainContentStack}">
                <VerticalStackLayout IsVisible="{Binding Display.IsBrandHeaderVisible}"
                                     Style="{StaticResource M3AuthShellStack}">
                    <Grid ColumnDefinitions="Auto,*"
                          Style="{StaticResource M3AuthBrandGrid}">
                        <Border Style="{StaticResource M3AuthBrandMarkFrame}"
                                SemanticProperties.Description="Cotton Cloud">
                            <Image Source="cotton_brand_mark.svg"
                                   Style="{StaticResource M3AuthBrandMarkImage}" />
                        </Border>

                        <Label Grid.Column="1"
                               Text="Cotton Cloud"
                               Style="{StaticResource M3AuthTitle}"
                               SemanticProperties.HeadingLevel="Level1" />
                    </Grid>
                </VerticalStackLayout>

                <Border IsVisible="{Binding Display.IsLoadingVisible}"
                        Style="{StaticResource M3AuthLoadingStatusPanel}">
                    <Grid ColumnDefinitions="Auto,*"
                          Style="{StaticResource M3LoadingStatusGrid}">
                        <Border Style="{StaticResource M3LoadingIndicatorFrame}">
                            <ActivityIndicator IsRunning="{Binding Display.IsLoadingIndicatorRunning}"
                                               Style="{StaticResource M3LoadingActivityIndicator}" />
                        </Border>

                        <Label Grid.Column="1"
                               Text="{Binding Display.LoadingMessage}"
                               Style="{StaticResource M3LoadingMessage}" />
                    </Grid>
                </Border>

                <Border IsVisible="{Binding Display.IsSignInVisible}"
                        Style="{StaticResource M3AuthPanel}">
                    <VerticalStackLayout Style="{StaticResource M3AuthFormStack}">
                        <Border x:Name="InstanceUrlField"
                                Style="{StaticResource M3OutlinedInputField}">
                            <Grid ColumnDefinitions="Auto,*"
                                  Style="{StaticResource M3InputGrid}">
                                <Border x:Name="InstanceUrlIconFrame"
                                        Style="{StaticResource M3InputIconFrame}">
                                    <controls:IconView x:Name="InstanceUrlIcon"
                                                       IconData="{x:Static controls:IconPathData.Cloud}"
                                                       Style="{StaticResource M3InputIcon}" />
                                </Border>

                                <Entry x:Name="InstanceUrlEntry"
                                       Grid.Column="1"
                                       Text="{Binding Display.InstanceUrl, Mode=TwoWay}"
                                       Placeholder="https://app.cottoncloud.dev/"
                                       Keyboard="Url"
                                       ReturnType="Go"
                                       ClearButtonVisibility="WhileEditing"
                                       IsEnabled="{Binding Display.IsInputEnabled}"
                                       ReturnCommand="{Binding ConnectCommand}"
                                       SemanticProperties.Hint="Cotton Cloud server URL">
                                    <Entry.Behaviors>
                                        <behaviors:FocusedInputChromeBehavior Field="{x:Reference InstanceUrlField}"
                                                                             LeadingIconFrame="{x:Reference InstanceUrlIconFrame}"
                                                                             LeadingIcon="{x:Reference InstanceUrlIcon}" />
                                    </Entry.Behaviors>
                                </Entry>
                            </Grid>
                        </Border>

                        <Label Text="{Binding Display.Status}"
                               IsVisible="{Binding Display.IsStatusVisible}"
                               Style="{StaticResource M3AuthStatus}" />

                        <controls:FilledButton Text="Connect"
                                               Command="{Binding ConnectCommand}"
                                               IsEnabled="{Binding Display.IsInputEnabled}"
                                               Style="{StaticResource M3AuthFilledButton}" />
                    </VerticalStackLayout>
                </Border>

                <Border IsVisible="{Binding Display.IsAuthorizationProgressVisible}"
                        Style="{StaticResource M3AuthLoadingStatusPanel}">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          Style="{StaticResource M3LoadingStatusGrid}">
                        <Border Style="{StaticResource M3LoadingIndicatorFrame}">
                            <ActivityIndicator IsRunning="{Binding Display.IsAuthorizationProgressIndicatorRunning}"
                                               Style="{StaticResource M3LoadingActivityIndicator}" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1"
                                             Style="{StaticResource M3CardTextStack}">
                            <Label Text="Waiting for browser approval"
                                   Style="{StaticResource M3CardSupportingStrong}" />

                            <Label Text="{Binding Display.AuthorizationProgressMessage}"
                                   Style="{StaticResource M3CardSupportingBlock}" />
                        </VerticalStackLayout>

                        <controls:IconButton Grid.Column="2"
                                             IconData="{x:Static controls:IconPathData.Close}"
                                             Command="{Binding CancelAuthorizationCommand}"
                                             IsEnabled="{Binding Display.IsCancelAuthorizationEnabled}"
                                             Style="{StaticResource M3FileChromeIconButton}"
                                             SemanticProperties.Description="Cancel browser approval" />
                    </Grid>
                </Border>

                <HorizontalStackLayout IsVisible="{Binding Display.IsLegalFooterVisible}"
                                       Style="{StaticResource M3LegalFooterBar}">
                    <controls:TextAction Text="Privacy"
                                         Command="{Binding PrivacyPolicyCommand}" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <RefreshView Grid.Row="0"
                     IsVisible="{Binding Display.IsProfileVisible}"
                     Command="{Binding RefreshFilesCommand}"
                     IsRefreshing="{Binding Display.IsFilesRefreshing, Mode=TwoWay}">
        <ScrollView>
            <VerticalStackLayout Style="{StaticResource M3MainContentStack}">
                <VerticalStackLayout IsVisible="{Binding Display.IsProfileVisible}"
                                     Style="{StaticResource M3FileBrowserProfileStack}">
                        <VerticalStackLayout x:Name="FileBrowserContent"
                                             Style="{StaticResource M3FileBrowserContentStack}">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  Style="{StaticResource M3FileBrowserTopBar}">
                                <controls:IconButton Grid.Column="0"
                                                     IconData="{x:Static controls:IconPathData.ArrowUp}"
                                                     Style="{StaticResource M3FileBrowserTopBarIconButton}"
                                                     Command="{Binding NavigateFilesUpCommand}"
                                                     IsEnabled="{Binding Display.IsFileUpButtonEnabled}"
                                                     IsVisible="{Binding Display.IsFileUpButtonVisible}"
                                                     ButtonOpacity="{Binding Display.FileUpButtonOpacity}"
                                                     SemanticProperties.Description="Up" />

                                <VerticalStackLayout Grid.Column="1"
                                                     Style="{StaticResource M3FileBrowserTitleStack}">
                                    <Label Text="{Binding Display.FilesTitle}"
                                           Style="{StaticResource M3BrowserTitleLine}" />

                                    <Label Text="{Binding Display.FilesPath}"
                                           IsVisible="{Binding Display.IsFilesPathVisible}"
                                           Style="{StaticResource M3CardMetaLine}" />

                                    <Label Text="{Binding Display.FilesStatus}"
                                           IsVisible="{Binding Display.IsFilesStatusVisible}"
                                           Style="{StaticResource M3CardMetaLine}" />
                                </VerticalStackLayout>

                                <HorizontalStackLayout Grid.Column="2"
                                                       Style="{StaticResource M3FileBrowserActionCluster}">
                                    <controls:IconButton IconData="{x:Static controls:IconPathData.Search}"
                                                         Style="{StaticResource M3FileBrowserTopBarIconButton}"
                                                         Command="{Binding ToggleFileSearchCommand}"
                                                         IsEnabled="{Binding Display.IsFileBrowserChromeEnabled}"
                                                         SemanticProperties.Description="{Binding Display.FileSearchButtonDescription}">
                                        <controls:IconButton.Triggers>
                                            <DataTrigger TargetType="controls:IconButton"
                                                         Binding="{Binding Display.IsFileSearchVisible}"
                                                         Value="True">
                                                <Setter Property="IconData"
                                                        Value="{x:Static controls:IconPathData.Close}" />
                                            </DataTrigger>
                                        </controls:IconButton.Triggers>
                                    </controls:IconButton>

                                    <controls:IconButton IconData="{x:Static controls:IconPathData.Sort}"
                                                         Style="{StaticResource M3FileBrowserTopBarIconButton}"
                                                         Command="{Binding ShowFileSortActionsCommand}"
                                                         IsEnabled="{Binding Display.IsFileBrowserChromeEnabled}"
                                                         IsVisible="{Binding Display.IsFileSortButtonVisible}"
                                                         SemanticProperties.Description="Sort files" />

                                    <controls:IconButton IconData="{x:Static controls:IconPathData.ViewTiles}"
                                                         Style="{StaticResource M3FileBrowserTopBarIconButton}"
                                                         Command="{Binding ShowFileViewActionsCommand}"
                                                         IsEnabled="{Binding Display.IsFileBrowserChromeEnabled}"
                                                         IsVisible="{Binding Display.IsFileViewButtonVisible}"
                                                         SemanticProperties.Description="Change file view" />

                                    <controls:InitialsButton Text="{Binding Display.ProfileInitials}"
                                                             Command="{Binding AccountCommand}"
                                                             IsEnabled="{Binding Display.IsAccountActionEnabled}"
                                                             SemanticProperties.Description="Account" />
                                </HorizontalStackLayout>
                            </Grid>

                            <Label Text="{Binding Display.ProfileStatus}"
                                   IsVisible="{Binding Display.IsProfileStatusVisible}"
                                   Style="{StaticResource M3BodyMedium}" />

                            <Border IsVisible="{Binding Display.IsTransferActivityIndicatorVisible}"
                                    Style="{StaticResource M3FileStatusPanel}"
                                    SemanticProperties.Description="{Binding Display.TransferActivityIndicator.AccessibilityText}">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding Display.TransferActivityIndicator.HasFailures}"
                                                 Value="True">
                                        <Setter Property="Style"
                                                Value="{StaticResource M3FileErrorStatusPanel}" />
                                    </DataTrigger>
                                </Border.Triggers>

                                <Grid ColumnDefinitions="Auto,*,*"
                                      Style="{StaticResource M3FileStatusGrid}">
                                    <controls:IconView IconData="{x:Static controls:IconPathData.Transfer}"
                                                       Style="{StaticResource M3FileStatusIcon}">
                                        <controls:IconView.Triggers>
                                            <DataTrigger TargetType="controls:IconView"
                                                         Binding="{Binding Display.TransferActivityIndicator.HasFailures}"
                                                         Value="True">
                                                <Setter Property="IconData"
                                                        Value="{x:Static controls:IconPathData.Error}" />
                                                <Setter Property="Style"
                                                        Value="{StaticResource M3FileErrorStatusIcon}" />
                                            </DataTrigger>
                                        </controls:IconView.Triggers>
                                    </controls:IconView>

                                    <Label Grid.Column="1"
                                           Text="{Binding Display.TransferActivityIndicator.Text}"
                                           Style="{StaticResource M3FileStatusPrimaryText}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding Display.TransferActivityIndicator.HasFailures}"
                                                         Value="True">
                                                <Setter Property="Style"
                                                        Value="{StaticResource M3FileErrorStatusPrimaryText}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <Label Grid.Column="2"
                                           Text="{Binding Display.TransferActivityIndicator.Details}"
                                           Style="{StaticResource M3FileStatusMetaText}" />

                                    <Grid Grid.ColumnSpan="3"
                                          Style="{StaticResource M3ListItemTouchSurface}">
                                        <Grid.Behaviors>
                                            <behaviors:LongPressBehavior TapCommand="{Binding OpenTransfersCommand}" />
                                        </Grid.Behaviors>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border IsVisible="{Binding Display.IsBackupActivityIndicatorVisible}"
                                    Style="{StaticResource M3FileStatusPanel}"
                                    SemanticProperties.Description="{Binding Display.BackupActivityIndicator.AccessibilityText}">
                                <Grid ColumnDefinitions="Auto,*,*"
                                      Style="{StaticResource M3FileStatusGrid}">
                                    <controls:IconView IconData="{x:Static controls:IconPathData.Backup}"
                                                       Style="{StaticResource M3FileStatusIcon}" />

                                    <Label Grid.Column="1"
                                           Text="{Binding Display.BackupActivityIndicator.Text}"
                                           Style="{StaticResource M3FileStatusPrimaryText}" />

                                    <Label Grid.Column="2"
                                           Text="{Binding Display.BackupActivityIndicator.Details}"
                                           Style="{StaticResource M3FileStatusMetaText}" />

                                    <Grid Grid.ColumnSpan="3"
                                          Style="{StaticResource M3ListItemTouchSurface}">
                                        <Grid.Behaviors>
                                            <behaviors:LongPressBehavior TapCommand="{Binding OpenBackupSetupCommand}" />
                                        </Grid.Behaviors>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border IsVisible="{Binding Display.IsOfflinePackProgressVisible}"
                                    Style="{StaticResource M3FileStatusPanel}"
                                    SemanticProperties.Description="{Binding Display.OfflinePackProgress.AccessibilityText}">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      Style="{StaticResource M3FileStatusGrid}">
                                    <controls:IconView IconData="{x:Static controls:IconPathData.Download}"
                                                       Style="{StaticResource M3FileStatusIcon}" />

                                    <Label Grid.Column="1"
                                           Text="{Binding Display.OfflinePackProgress.Text}"
                                           Style="{StaticResource M3FileStatusPrimaryText}" />

                                    <Label Grid.Column="2"
                                           Text="{Binding Display.OfflinePackProgress.Details}"
                                           Style="{StaticResource M3FileStatusMetaText}" />
                                </Grid>
                            </Border>

                            <Border IsVisible="{Binding Display.IsFilesNoticeVisible}"
                                    Style="{StaticResource M3FileNoticePanel}">
                                <Grid ColumnDefinitions="Auto,*"
                                      Style="{StaticResource M3FileNoticeGrid}">
                                    <Border Style="{StaticResource M3FileNoticeIconFrame}">
                                        <controls:IconView IconData="{x:Static controls:IconPathData.Error}"
                                                           Style="{StaticResource M3FileNoticeIcon}" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Style="{StaticResource M3FileNoticeTextStack}">
                                        <Label Text="{Binding Display.FilesNoticeTitle}"
                                               Style="{StaticResource M3CardSupportingStrong}" />

                                        <Label Text="{Binding Display.FilesNoticeMessage}"
                                               Style="{StaticResource M3CardSupportingWrap}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>

                            <Border IsVisible="{Binding Display.IsFileSearchVisible}"
                                    IsEnabled="{Binding Display.IsFileBrowserChromeEnabled}"
                                    x:Name="FileSearchField"
                                    Style="{StaticResource M3OutlinedInputField}">
                                <Grid ColumnDefinitions="Auto,*"
                                      Style="{StaticResource M3InputGrid}">
                                    <Border x:Name="FileSearchIconFrame"
                                            Style="{StaticResource M3InputIconFrame}">
                                        <controls:IconView x:Name="FileSearchIcon"
                                                           IconData="{x:Static controls:IconPathData.Search}"
                                                           Style="{StaticResource M3InputIcon}" />
                                    </Border>

                                    <Entry x:Name="FileSearchBar"
                                           Grid.Column="1"
                                           Text="{Binding Display.FileSearchText, Mode=TwoWay}"
                                           IsVisible="{Binding Display.IsFileSearchVisible}"
                                           IsEnabled="{Binding Display.IsFileBrowserChromeEnabled}"
                                           Placeholder="Search"
                                           ReturnType="Search"
                                           ClearButtonVisibility="WhileEditing"
                                           SemanticProperties.Hint="Search files and folders">
                                        <Entry.Behaviors>
                                            <behaviors:FocusedInputChromeBehavior Field="{x:Reference FileSearchField}"
                                                                                 LeadingIconFrame="{x:Reference FileSearchIconFrame}"
                                                                                 LeadingIcon="{x:Reference FileSearchIcon}" />
                                        </Entry.Behaviors>
                                    </Entry>
                                </Grid>
                            </Border>

                            <Border IsVisible="{Binding Display.IsFileSelectionBarVisible}"
                                    Style="{StaticResource M3SelectionBar}">
                                <Grid ColumnDefinitions="*,Auto,Auto"
                                      Style="{StaticResource M3SelectionBarGrid}">
                                    <VerticalStackLayout Style="{StaticResource M3SelectionTextStack}">
                                        <Label Text="{Binding Display.FileSelection.TitleText}"
                                               Style="{StaticResource M3SelectionTitleText}" />

                                        <Label Text="{Binding Display.FileSelection.DetailText}"
                                               Style="{StaticResource M3SelectionDetailText}" />
                                    </VerticalStackLayout>

                                    <controls:IconButton Grid.Column="1"
                                                         IconData="{x:Static controls:IconPathData.MoreVertical}"
                                                         Command="{Binding ShowFileSelectionActionsCommand}"
                                                         Style="{StaticResource M3FileChromeIconButton}"
                                                         SemanticProperties.Description="Selected file actions" />

                                    <controls:IconButton Grid.Column="2"
                                                         IconData="{x:Static controls:IconPathData.Close}"
                                                         Command="{Binding ClearFileSelectionCommand}"
                                                         Style="{StaticResource M3FileChromeIconButton}"
                                                         SemanticProperties.Description="Cancel file selection" />
                                </Grid>
                            </Border>

                            <Border IsVisible="{Binding Display.IsFilesLoading}"
                                    Style="{StaticResource M3LoadingStatusPanel}">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      Style="{StaticResource M3LoadingStatusGrid}">
                                    <Border Style="{StaticResource M3LoadingIndicatorFrame}">
                                        <ActivityIndicator IsRunning="{Binding Display.IsFilesLoading}"
                                                           Style="{StaticResource M3LoadingActivityIndicator}" />
                                    </Border>

                                    <Label Grid.Column="1"
                                           Text="{Binding Display.LoadingMessage}"
                                           Style="{StaticResource M3LoadingMessage}" />

                                    <controls:IconButton Grid.Column="2"
                                                         IconData="{x:Static controls:IconPathData.Close}"
                                                         Command="{Binding CancelFileActionCommand}"
                                                         IsEnabled="{Binding Display.CanCancelFileAction}"
                                                         IsVisible="{Binding Display.CanCancelFileAction}"
                                                         Style="{StaticResource M3FileChromeIconButton}"
                                                         SemanticProperties.Description="Cancel file operation" />
                                </Grid>
                            </Border>

                            <VerticalStackLayout IsVisible="{Binding Display.IsInlineFilesLoadingVisible}"
                                                 Style="{StaticResource M3FileSkeletonListStack}">
                                <Grid Style="{StaticResource M3FileSkeletonRowGrid}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{StaticResource M3FileListThumbnailColumnWidth}" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="{StaticResource M3FileActionSize}" />
                                    </Grid.ColumnDefinitions>

                                    <controls:SkeletonBlock Style="{StaticResource M3FileSkeletonThumbnailBlock}" />

                                    <VerticalStackLayout Grid.Column="1"
                                                         Style="{StaticResource M3FileSkeletonTextStack}">
                                        <controls:SkeletonBlock Style="{StaticResource M3FileSkeletonPrimaryLineBlock}" />
                                        <controls:SkeletonBlock Style="{StaticResource M3FileSkeletonSecondaryLineBlock}" />
                                    </VerticalStackLayout>

                                    <controls:SkeletonBlock Grid.Column="2"
                                                            Style="{StaticResource M3FileSkeletonActionBlock}" />
                                </Grid>

                                <Grid Style="{StaticResource M3FileSkeletonRowGrid}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{StaticResource M3FileListThumbnailColumnWidth}" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="{StaticResource M3FileActionSize}" />
                                    </Grid.ColumnDefinitions>

                                    <controls:SkeletonBlock Style="{StaticResource M3FileSkeletonThumbnailBlock}" />

                                    <VerticalStackLayout Grid.Column="1"
                                                         Style="{StaticResource M3FileSkeletonTextStack}">
                                        <controls:SkeletonBlock Style="{StaticResource M3FileSkeletonPrimaryLineBlock}" />
                                        <controls:SkeletonBlock Style="{StaticResource M3FileSkeletonSecondaryLineBlock}" />
                                    </VerticalStackLayout>

                                    <controls:SkeletonBlock Grid.Column="2"
                                                            Style="{StaticResource M3FileSkeletonActionBlock}" />
                                </Grid>

                                <Grid Style="{StaticResource M3FileSkeletonRowGrid}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{StaticResource M3FileListThumbnailColumnWidth}" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="{StaticResource M3FileActionSize}" />
                                    </Grid.ColumnDefinitions>

                                    <controls:SkeletonBlock Style="{StaticResource M3FileSkeletonThumbnailBlock}" />

                                    <VerticalStackLayout Grid.Column="1"
                                                         Style="{StaticResource M3FileSkeletonTextStack}">
                                        <controls:SkeletonBlock Style="{StaticResource M3FileSkeletonPrimaryLineBlock}" />
                                        <controls:SkeletonBlock Style="{StaticResource M3FileSkeletonSecondaryLineBlock}" />
                                    </VerticalStackLayout>

                                    <controls:SkeletonBlock Grid.Column="2"
                                                            Style="{StaticResource M3FileSkeletonActionBlock}" />
                                </Grid>
                            </VerticalStackLayout>

                            <Border IsVisible="{Binding Display.CanRetryFileAction}"
                                    Style="{StaticResource M3AttentionStatusPanel}">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      Style="{StaticResource M3StatusGrid}">
                                    <controls:IconView IconData="{x:Static controls:IconPathData.Error}"
                                                       Style="{StaticResource M3AttentionStatusIcon}" />

                                    <Label Grid.Column="1"
                                           Text="{Binding Display.FilesStatus}"
                                           Style="{StaticResource M3AttentionStatusMessage}" />

                                    <controls:IconButton Grid.Column="2"
                                                         IconData="{x:Static controls:IconPathData.Refresh}"
                                                         Command="{Binding RetryFileActionCommand}"
                                                         IsEnabled="{Binding Display.CanRetryFileAction}"
                                                         Style="{StaticResource M3DestructiveFileChromeIconButton}"
                                                         SemanticProperties.Description="{Binding Display.FileRetryActionText}" />
                                </Grid>
                            </Border>

                            <Border IsVisible="{Binding Display.IsFilesEmptyVisible}"
                                    Style="{StaticResource M3EmptyStateCard}">
                                <VerticalStackLayout Style="{StaticResource M3EmptyStateStack}">
                                    <Border Style="{StaticResource M3EmptyStateIconFrame}">
                                        <controls:IconView IconData="{x:Static controls:IconPathData.File}"
                                                           Style="{StaticResource M3EmptyStateIcon}" />
                                    </Border>

                                    <Label Text="{Binding Display.FilesEmptyMessage}"
                                           Style="{StaticResource M3EmptyTitle}" />

                                    <Label Text="{Binding Display.FilesEmptyDetails}"
                                           IsVisible="{Binding Display.IsFilesEmptyDetailsVisible}"
                                           Style="{StaticResource M3EmptyBody}" />

                                    <controls:IconButton IconData="{x:Static controls:IconPathData.Plus}"
                                                         Command="{Binding ShowFileAddActionsCommand}"
                                                         IsVisible="{Binding Display.IsFilesEmptyAddActionVisible}"
                                                         Style="{StaticResource M3EmptyStateActionIconButton}"
                                                         SemanticProperties.Description="Add files" />
                                </VerticalStackLayout>
                            </Border>

                            <VerticalStackLayout Style="{StaticResource M3FileListStack}"
                                                 IsVisible="{Binding Display.IsFileListViewVisible}"
                                                 BindableLayout.ItemsSource="{Binding Display.FileEntries}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Style="{StaticResource M3FileListRowGrid}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="{StaticResource M3FileListThumbnailColumnWidth}" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="{StaticResource M3FileActionSize}" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.ColumnSpan="3"
                                                    IsVisible="{Binding IsSelected}"
                                                    Style="{StaticResource M3FileSelectionRowOverlay}" />

                                            <Border Style="{StaticResource M3FileListThumbnailSurface}">
                                                <Grid>
                                                    <Image Source="{Binding Thumbnail.Source}"
                                                           Aspect="AspectFill"
                                                           IsVisible="{Binding IsPreviewImageVisible}" />

                                                    <controls:IconView IconData="{x:Static controls:IconPathData.Folder}"
                                                                       IsVisible="{Binding IsFolderThumbnailVisible}"
                                                                       Style="{StaticResource M3FolderThumbnailIcon}" />

                                                    <ActivityIndicator IsRunning="{Binding Thumbnail.IsLoading}"
                                                                       IsVisible="{Binding Thumbnail.IsLoading}"
                                                                       Style="{StaticResource M3ThumbnailActivityIndicator}" />

                                                    <Label Text="{Binding Thumbnail.PlaceholderText}"
                                                           IsVisible="{Binding IsPlaceholderTextVisible}"
                                                           Style="{StaticResource M3DynamicThumbnailPlaceholder}" />
                                                </Grid>
                                            </Border>

                                            <Border Grid.Column="0"
                                                    IsVisible="{Binding IsSelected}"
                                                    Style="{StaticResource M3FileListSelectionMark}">
                                                <controls:IconView IconData="{x:Static controls:IconPathData.Check}"
                                                                   Style="{StaticResource M3FileSelectionCheckIcon}" />
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Style="{StaticResource M3FileListTextStack}">
                                                <Label Text="{Binding Name}"
                                                       Style="{StaticResource M3CardTitle}" />

                                                <Label Text="{Binding DisplayDetails}"
                                                       Style="{StaticResource M3CardSupportingLine}" />
                                            </VerticalStackLayout>

                                            <Grid x:Name="ListEntryTouchSurface"
                                                  Grid.ColumnSpan="2"
                                                  Style="{StaticResource M3ListItemTouchSurface}">
                                                <Grid.Behaviors>
                                                    <behaviors:LongPressBehavior Command="{Binding BindingContext.BeginFileSelectionCommand, Source={x:Reference RootPage}}"
                                                                                 CommandParameter="{Binding BindingContext, Source={x:Reference ListEntryTouchSurface}}"
                                                                                 TapCommand="{Binding BindingContext.ActivateFileBrowserEntryCommand, Source={x:Reference RootPage}}"
                                                                                 TapCommandParameter="{Binding BindingContext, Source={x:Reference ListEntryTouchSurface}}" />
                                                </Grid.Behaviors>
                                            </Grid>

                                            <controls:IconButton Grid.Column="2"
                                                                 IconData="{x:Static controls:IconPathData.MoreVertical}"
                                                                 Style="{StaticResource M3FileChromeIconButton}"
                                                                 Command="{Binding BindingContext.ShowFileBrowserEntryActionsCommand, Source={x:Reference RootPage}}"
                                                                 CommandParameter="{Binding .}"
                                                                 IsEnabled="{Binding BindingContext.Display.IsFileBrowserChromeEnabled, Source={x:Reference RootPage}}"
                                                                 IsVisible="{Binding BindingContext.Display.IsFileEntryActionsVisible, Source={x:Reference RootPage}}"
                                                                 SemanticProperties.Description="{Binding Name, StringFormat='Actions for {0}'}" />
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <FlexLayout IsVisible="{Binding Display.IsFileTileViewVisible}"
                                        BindableLayout.ItemsSource="{Binding Display.FileEntries}"
                                        Style="{StaticResource M3FileTileWrapLayout}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Grid WidthRequest="{Binding Source={x:Reference RootPage}, Path=FileTileSlotWidth}"
                                              Style="{StaticResource M3FileTileSlotGrid}">
                                            <Border HeightRequest="{Binding Source={x:Reference RootPage}, Path=FileTileHeight}"
                                                    Style="{StaticResource M3FileTileCard}">
                                                <Grid Style="{StaticResource M3FileTileContentGrid}">
                                                    <Border Grid.RowSpan="2"
                                                            IsVisible="{Binding IsSelected}"
                                                            Style="{StaticResource M3FileSelectionOverlay}" />

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="{Binding Source={x:Reference RootPage}, Path=FileTilePreviewHeight}" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>

                                                    <Border HeightRequest="{Binding Source={x:Reference RootPage}, Path=FileTilePreviewHeight}"
                                                            Style="{StaticResource M3FilePreviewSurface}">
                                                        <Grid>
                                                            <Image Source="{Binding Thumbnail.Source}"
                                                                   Aspect="AspectFill"
                                                                   IsVisible="{Binding IsPreviewImageVisible}" />

                                                            <controls:IconView IconData="{x:Static controls:IconPathData.Folder}"
                                                                               IsVisible="{Binding IsFolderThumbnailVisible}"
                                                                               IconSize="{Binding Source={x:Reference RootPage}, Path=FileTileFolderIconSize}"
                                                                               Style="{StaticResource M3FolderThumbnailIcon}" />

                                                            <ActivityIndicator IsRunning="{Binding Thumbnail.IsLoading}"
                                                                               IsVisible="{Binding Thumbnail.IsLoading}"
                                                                               Style="{StaticResource M3ThumbnailActivityIndicator}" />

                                                            <Label Text="{Binding Thumbnail.PlaceholderText}"
                                                                   IsVisible="{Binding IsPlaceholderTextVisible}"
                                                                   Style="{StaticResource M3DynamicThumbnailPlaceholder}" />
                                                        </Grid>
                                                    </Border>

                                                    <Border Grid.Row="0"
                                                            IsVisible="{Binding IsSelected}"
                                                            Style="{StaticResource M3FileTileSelectionMark}">
                                                        <controls:IconView IconData="{x:Static controls:IconPathData.Check}"
                                                                           Style="{StaticResource M3FileSelectionCheckIcon}" />
                                                    </Border>

                                                    <VerticalStackLayout Grid.Row="1"
                                                                         Style="{StaticResource M3FileTileTextStack}">
                                                        <Label Text="{Binding Name}"
                                                               Style="{StaticResource M3CardSupportingStrongLine}" />

                                                        <Grid ColumnDefinitions="*,Auto,Auto"
                                                              Style="{StaticResource M3FileTileMetadataGrid}">
                                                            <Label Text="{Binding Details}"
                                                                   Style="{StaticResource M3CardMetaLine}" />

                                                            <Border Grid.Column="1"
                                                                    IsVisible="{Binding HasLocalCopy}"
                                                                    Style="{StaticResource M3AccentOutlineChip}">
                                                                <Label Text="{Binding LocalCopyStatus}"
                                                                       Style="{StaticResource M3AccentOutlineChipLabel}" />
                                                            </Border>

                                                            <Border Grid.Column="2"
                                                                    IsVisible="{Binding IsOfflineAttentionVisible}"
                                                                    Style="{StaticResource M3FileAttentionChip}">
                                                                <Label Text="{Binding OfflineAttentionStatus}"
                                                                       Style="{StaticResource M3ErrorChipLabel}" />
                                                            </Border>
                                                        </Grid>
                                                    </VerticalStackLayout>

                                                    <Grid x:Name="TileEntryTouchSurface"
                                                          Grid.RowSpan="2"
                                                          Style="{StaticResource M3ListItemTouchSurface}">
                                                        <Grid.Behaviors>
                                                            <behaviors:LongPressBehavior Command="{Binding BindingContext.BeginFileSelectionCommand, Source={x:Reference RootPage}}"
                                                                                         CommandParameter="{Binding BindingContext, Source={x:Reference TileEntryTouchSurface}}"
                                                                                         TapCommand="{Binding BindingContext.ActivateFileBrowserEntryCommand, Source={x:Reference RootPage}}"
                                                                                         TapCommandParameter="{Binding BindingContext, Source={x:Reference TileEntryTouchSurface}}" />
                                                        </Grid.Behaviors>
                                                    </Grid>

                                                    <controls:IconButton Grid.Row="0"
                                                                         IconData="{x:Static controls:IconPathData.MoreVertical}"
                                                                         Style="{StaticResource M3FileTileActionIconButton}"
                                                                         Command="{Binding BindingContext.ShowFileBrowserEntryActionsCommand, Source={x:Reference RootPage}}"
                                                                         CommandParameter="{Binding .}"
                                                                         IsEnabled="{Binding BindingContext.Display.IsFileBrowserChromeEnabled, Source={x:Reference RootPage}}"
                                                                         IsVisible="{Binding BindingContext.Display.IsFileEntryActionsVisible, Source={x:Reference RootPage}}"
                                                                         SemanticProperties.Description="{Binding Name, StringFormat='Actions for {0}'}" />

                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                        </VerticalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
        </RefreshView>

        <controls:IconButton Grid.Row="1"
                             IconData="{x:Static controls:IconPathData.Plus}"
                             Style="{StaticResource M3FloatingActionIconButton}"
                             Command="{Binding ShowFileAddActionsCommand}"
                             IsVisible="{Binding Display.IsFileAddButtonVisible}"
                             IsEnabled="{Binding Display.IsFileBrowserChromeEnabled}"
                             SemanticProperties.Description="Add files" />

        <Border Grid.Row="2"
                IsVisible="{Binding Display.IsFileBrowserQuickNavigationVisible}"
                Style="{StaticResource M3NavigationBarSurface}">
            <Grid ColumnDefinitions="*,*,*,*"
                  Style="{StaticResource M3NavigationBarGrid}">
                <controls:NavigationBarItem Grid.Column="0"
                                            Style="{StaticResource M3NavigationBarItemSelected}"
                                            IconData="{x:Static controls:IconPathData.Folder}"
                                            Text="{Binding Display.FilesNavigation.Label}"
                                            SemanticProperties.Description="{Binding Display.FilesNavigation.AccessibilityText}" />

                <controls:NavigationBarItem Grid.Column="1"
                                            Style="{StaticResource M3NavigationBarItemUnselected}"
                                            IconData="{x:Static controls:IconPathData.Transfer}"
                                            Text="Sync"
                                            Command="{Binding OpenSyncSettingsCommand}"
                                            IsEnabled="{Binding Display.IsProfileVisible}"
                                            SemanticProperties.Description="Open sync folders" />

                <controls:NavigationBarItem Grid.Column="2"
                                            Style="{StaticResource M3NavigationBarItemUnselected}"
                                            IconData="{x:Static controls:IconPathData.Backup}"
                                            Text="{Binding Display.BackupNavigation.Label}"
                                            Command="{Binding OpenBackupSetupCommand}"
                                            IsEnabled="{Binding Display.IsProfileVisible}"
                                            SemanticProperties.Description="{Binding Display.BackupNavigation.AccessibilityText}" />

                <controls:NavigationBarItem Grid.Column="3"
                                            Style="{StaticResource M3NavigationBarItemUnselected}"
                                            IconData="{x:Static controls:IconPathData.MoreVertical}"
                                            Text="More"
                                            Command="{Binding AccountCommand}"
                                            IsEnabled="{Binding Display.IsAccountActionEnabled}"
                                            SemanticProperties.Description="{Binding Display.SettingsNavigation.AccessibilityText}" />
            </Grid>
        </Border>

    </Grid>

</ContentPage>
