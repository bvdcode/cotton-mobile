<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.PdfViewerPage"
             x:DataType="viewModels:PdfViewerViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding Title}"
             Style="{StaticResource M3DocumentViewerPage}">

    <controls:ScreenShellView GridStyleResourceKey="M3DocumentViewerSurface">
        <controls:TopAppBar TitleText="{Binding Title}"
                            PrimaryIconData="{x:Static controls:IconPathData.Share}"
                            PrimaryCommand="{Binding ShareCommand}"
                            PrimaryDescription="Share PDF"
                            SecondaryIconData="{x:Static controls:IconPathData.OpenInNew}"
                            SecondaryCommand="{Binding OpenExternallyCommand}"
                            SecondaryDescription="Open PDF" />

        <controls:DocumentViewerBodyView Grid.Row="1">
            <controls:ViewerInfoHeaderView Details="{Binding Details}"
                                           Status="{Binding Status}"
                                           IsStatusVisible="{Binding IsStatusVisible}"
                                           StackStyleResourceKey="M3PdfHeaderStack" />

            <controls:MaterialCollectionView Grid.Row="1"
                                             ItemsSource="{Binding Pages}"
                                             IsVisible="{Binding IsPreviewVisible}"
                                             CollectionStyleResourceKey="M3DocumentViewerCollection"
                                             ItemSizingStrategy="MeasureAllItems"
                                             ItemsLayout="{StaticResource M3PdfPreviewItemsLayout}">
                <controls:MaterialCollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:PdfPreviewPageSnapshot">
                        <controls:PdfPreviewPageView ImageSource="{Binding ImageSource}"
                                                     DisplayHeight="{Binding DisplayHeight}" />
                    </DataTemplate>
                </controls:MaterialCollectionView.ItemTemplate>
            </controls:MaterialCollectionView>

            <controls:LayeredContentView Grid.Row="1"
                                         IsVisible="{Binding IsEmptyVisible}"
                                         GridStyleResourceKey="M3PdfEmptyStateLayer">
                <controls:EmptyStateView IconData="{x:Static controls:IconPathData.File}"
                                         Title="{Binding EmptyText}"
                                         CardStyleResourceKey="M3CenteredPdfEmptyStateCard"
                                         IconFrameStyleResourceKey="M3PdfEmptyStateIconFrame" />
            </controls:LayeredContentView>
        </controls:DocumentViewerBodyView>
    </controls:ScreenShellView>
</ContentPage>
