<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:Cotton.Mobile.Behaviors"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.CaptureDestinationPickerPage"
             x:DataType="viewModels:CaptureDestinationPickerViewModel"
             Shell.NavBarIsVisible="False"
             Title="Choose Destination">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh destinations" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Style="{StaticResource M3ScreenContentStack}">
            <controls:ScreenHeaderView Title="{Binding CurrentFolderName}"
                                       SupportingText="{Binding PathText}"
                                       IsSupportingTextVisible="{Binding IsPathTextVisible}"
                                       IsSupportingTextMultiline="True"
                                       IsBusy="{Binding IsBusy}" />

            <controls:ScreenStatusView Text="{Binding Status}"
                                       IsVisible="{Binding IsStatusVisible}" />

            <Border Style="{StaticResource M3ContentCard}">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                      Style="{StaticResource M3SettingsListItemGrid}">
                    <controls:IconFrame IconData="{x:Static controls:IconPathData.Folder}"
                                        Style="{StaticResource M3FolderThumbnailFrame}" />

                    <VerticalStackLayout Grid.Column="1"
                                         Style="{StaticResource M3CardTextStack}">
                        <Label Text="Current folder"
                               Style="{StaticResource M3CardTitle}" />

                        <Label Text="{Binding SummaryText}"
                               Style="{StaticResource M3CardSupportingLine}" />
                    </VerticalStackLayout>

                    <controls:IconButton Grid.Column="2"
                                         IconData="{x:Static controls:IconPathData.ArrowUp}"
                                         Command="{Binding UpCommand}"
                                         Style="{StaticResource M3FileChromeIconButton}"
                                         SemanticProperties.Description="Go to parent folder" />

                    <controls:IconButton Grid.Column="3"
                                         IconData="{x:Static controls:IconPathData.Check}"
                                         Command="{Binding ChooseCommand}"
                                         Style="{StaticResource M3PrimaryFileChromeIconButton}"
                                         SemanticProperties.Description="Choose current folder" />
                </Grid>
            </Border>

            <controls:FileListSkeletonView IsVisible="{Binding IsLoadingPlaceholderVisible}"
                                           Style="{StaticResource M3FileListSkeletonView}" />

            <controls:EmptyStateView IsVisible="{Binding IsEmpty}"
                                     IconData="{x:Static controls:IconPathData.Folder}"
                                     Title="No subfolders here" />

            <VerticalStackLayout Style="{StaticResource M3SettingsSectionStack}"
                                 IsVisible="{Binding IsListVisible}"
                                 BindableLayout.ItemsSource="{Binding Folders}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:CaptureDestinationFolderItemViewModel">
                        <Border Style="{StaticResource M3ContentCard}">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  Style="{StaticResource M3SettingsListItemGrid}">
                                <controls:IconFrame IconData="{x:Static controls:IconPathData.Folder}"
                                                    Style="{StaticResource M3FolderThumbnailFrame}" />

                                <Label Grid.Column="1"
                                       Text="{Binding DisplayName}"
                                       Style="{StaticResource M3SingleLineListItemTitle}" />

                                <controls:IconButton Grid.Column="2"
                                                     IconData="{x:Static controls:IconPathData.ChevronRight}"
                                                     Command="{Binding OpenCommand}"
                                                     Style="{StaticResource M3FileChromeIconButton}"
                                                     SemanticProperties.Description="{Binding DisplayName, StringFormat='Open {0}'}" />

                                <Grid Grid.ColumnSpan="2"
                                      Style="{StaticResource M3ListItemTouchSurface}">
                                    <Grid.Behaviors>
                                        <behaviors:LongPressBehavior TapCommand="{Binding OpenCommand}" />
                                    </Grid.Behaviors>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
