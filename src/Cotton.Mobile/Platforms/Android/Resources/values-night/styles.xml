<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Cotton.SplashTheme" parent="Maui.SplashTheme">
        <item name="android:colorAccent">@color/cotton_accent</item>
        <item name="colorAccent">@color/cotton_accent</item>
        <item name="android:textColorHighlight">@color/cotton_text_highlight</item>
        <item name="android:textCursorDrawable">@drawable/cotton_text_cursor</item>
        <item name="android:textSelectHandle">@drawable/cotton_text_select_handle</item>
        <item name="android:textSelectHandleLeft">@drawable/cotton_text_select_handle</item>
        <item name="android:textSelectHandleRight">@drawable/cotton_text_select_handle</item>
        <item name="android:statusBarColor">@color/cotton_status_bar</item>
        <item name="android:navigationBarColor">@color/cotton_surface</item>
        <item name="android:navigationBarDividerColor">@color/cotton_surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:enforceStatusBarContrast">false</item>
