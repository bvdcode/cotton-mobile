<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.SecuritySettingsPage"
             x:DataType="viewModels:SecuritySettingsViewModel"
             Shell.NavBarIsVisible="True"
             Title="Security"
             BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Refresh"
                     Command="{Binding LoadCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="18"
                             Spacing="16">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Security"
                           FontSize="28"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Label Text="{Binding SummaryText}"
                           FontSize="13"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   FontSize="13"
                   MaxLines="2"
                   LineBreakMode="TailTruncation"
                   TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

            <Border Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                    StrokeShape="RoundRectangle 18"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="6"
                      ColumnSpacing="12">
                    <Label Text="{Binding AppLockTitle}"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Label Grid.Column="1"
                           Text="{Binding AppLockStatusText}"
                           FontSize="13"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding AppLockDetailText}"
                           FontSize="12"
                           MaxLines="2"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                    <Switch Grid.Row="2"
                            Grid.ColumnSpan="2"
                            HorizontalOptions="End"
                            IsEnabled="{Binding CanToggleAppLock}"
                            IsToggled="{Binding IsAppLockEnabled, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                    StrokeShape="RoundRectangle 18"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="6"
                      ColumnSpacing="12">
                    <Label Text="{Binding DeviceUnlockTitle}"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Label Grid.Column="1"
                           Text="{Binding DeviceUnlockStatusText}"
                           FontSize="13"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding DeviceUnlockDetailText}"
                           FontSize="12"
                           MaxLines="2"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                    <Button Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Text="{Binding DeviceUnlockActionText}"
                            Command="{Binding VerifyDeviceUnlockCommand}"
                            IsEnabled="{Binding CanVerifyDeviceUnlock}"
                            IsVisible="{Binding IsDeviceUnlockActionVisible}"
                            HorizontalOptions="End" />
                </Grid>
            </Border>

            <Border Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                    StrokeShape="RoundRectangle 18"
                    Padding="16"
                    IsVisible="{Binding IsPermissionLedgerVisible}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="6"
                          ColumnSpacing="12">
                        <Label Text="{Binding PermissionLedgerTitle}"
                               FontSize="15"
                               FontAttributes="Bold"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                        <Label Grid.Column="1"
                               Text="{Binding PermissionLedgerStatusText}"
                               FontSize="13"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                        <Label Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="{Binding PermissionLedgerDetailText}"
                               FontSize="12"
                               MaxLines="2"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                    </Grid>

                    <VerticalStackLayout Spacing="10"
                                         BindableLayout.ItemsSource="{Binding PermissionLedgerItems}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="services:CottonPermissionLedgerItem">
                                <Grid ColumnDefinitions="*,Auto"
                                      RowDefinitions="Auto,Auto"
                                      RowSpacing="3"
                                      ColumnSpacing="10">
                                    <Label Text="{Binding Title}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                                    <Label Grid.Column="1"
                                           Text="{Binding StatusText}"
                                           FontSize="12"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                                    <Label Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding DetailText}"
                                           FontSize="12"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                    StrokeShape="RoundRectangle 18"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="6"
                          ColumnSpacing="12">
                        <Label Text="{Binding AccountSessionsTitle}"
                               FontSize="15"
                               FontAttributes="Bold"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                        <Label Grid.Column="1"
                               Text="{Binding AccountSessionsStatusText}"
                               FontSize="13"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                        <Label Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="{Binding AccountSessionsDetailText}"
                               FontSize="12"
                               MaxLines="2"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                    </Grid>

                    <Button Text="{Binding RevokeCurrentSessionActionText}"
                            Command="{Binding RevokeCurrentSessionCommand}"
                            IsEnabled="{Binding CanRevokeCurrentSession}"
                            IsVisible="{Binding IsRevokeCurrentSessionVisible}"
                            HorizontalOptions="Start"
                            Style="{StaticResource DestructiveChromeButton}" />

                    <VerticalStackLayout Spacing="2"
                                         IsVisible="{Binding IsAccountSessionsEmptyVisible}">
                        <Label Text="{Binding AccountSessionsEmptyTitle}"
                               FontSize="13"
                               FontAttributes="Bold"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                        <Label Text="{Binding AccountSessionsEmptyDetails}"
                               FontSize="12"
                               MaxLines="2"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="12"
                                         IsVisible="{Binding IsAccountSessionsListVisible}"
                                         BindableLayout.ItemsSource="{Binding AccountSessions}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="services:CottonAccountSessionListItem">
                                <Grid ColumnDefinitions="*,Auto"
                                      RowDefinitions="Auto,Auto,Auto,Auto"
                                      RowSpacing="3"
                                      ColumnSpacing="10">
                                    <Label Text="{Binding Title}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                                    <Border Grid.Column="1"
                                            Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                                            StrokeShape="RoundRectangle 18"
                                            Padding="8,3"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerHigh}, Dark={StaticResource M3DarkSurfaceContainerHigh}}"
                                            HorizontalOptions="End"
                                            VerticalOptions="Start">
                                        <Label Text="{Binding BadgeText}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               MaxLines="1"
                                               LineBreakMode="NoWrap"
                                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />
                                    </Border>

                                    <Label Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding DetailText}"
                                           FontSize="12"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                                    <Label Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding AccessText}"
                                           FontSize="12"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                                    <Label Grid.Row="3"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding DurationText}"
                                           FontSize="12"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                    StrokeShape="RoundRectangle 18"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="6"
                      ColumnSpacing="12">
                    <Label Text="{Binding LogoutCacheCleanupTitle}"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Label Grid.Column="1"
                           Text="{Binding LogoutCacheCleanupStatusText}"
                           FontSize="13"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding LogoutCacheCleanupDetailText}"
                           FontSize="12"
                           MaxLines="2"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                    <Switch Grid.Row="2"
                            Grid.ColumnSpan="2"
                            HorizontalOptions="End"
                            IsEnabled="{Binding CanToggleLogoutCacheCleanup}"
                            IsToggled="{Binding IsLogoutCacheCleanupEnabled, Mode=TwoWay}" />
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
