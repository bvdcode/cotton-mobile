<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.RecentFilesPage"
             x:Name="RecentFilesRoot"
             x:DataType="viewModels:RecentFilesViewModel"
             Shell.NavBarIsVisible="False"
             Title="Recent files"
             BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">

    <Grid RowDefinitions="Auto,*"
          BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">
        <controls:TopAppBar PrimaryIconData="{x:Static controls:IconPathData.Delete}"
                            PrimaryCommand="{Binding ClearRecentFilesCommand}"
                            PrimaryDescription="Clear recent files"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh recent files" />

        <Grid Grid.Row="1"
              Padding="16"
              RowDefinitions="Auto,Auto,*"
              RowSpacing="14">
        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="12">
            <VerticalStackLayout Spacing="2">
                <Label Text="Recent files"
                       Style="{StaticResource M3ScreenTitle}"
                       MaxLines="1"
                       LineBreakMode="TailTruncation" />

                <Label Text="{Binding SummaryText}"
                       FontSize="13"
                       MaxLines="1"
                       LineBreakMode="TailTruncation"
                       TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
            </VerticalStackLayout>

            <ActivityIndicator Grid.Column="1"
                               IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               VerticalOptions="Center" />
        </Grid>

        <Label Grid.Row="1"
               Text="{Binding Status}"
               IsVisible="{Binding IsStatusVisible}"
               FontSize="13"
               MaxLines="2"
               LineBreakMode="TailTruncation"
               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

        <Border Grid.Row="2"
                IsVisible="{Binding IsEmpty}"
                Style="{StaticResource M3SurfaceCard}"
                Padding="28,36">
            <VerticalStackLayout Spacing="8"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <Label Text="{Binding EmptyMessage}"
                       Style="{StaticResource M3EmptyTitle}"
                       HorizontalTextAlignment="Center" />

                <Label Text="{Binding EmptyDetails}"
                       Style="{StaticResource M3CardSupporting}"
                       MaxLines="2"
                       LineBreakMode="WordWrap"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Items}"
                        IsVisible="{Binding IsListVisible}"
                        SelectionMode="None"
                        ItemSizingStrategy="MeasureFirstItem">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical"
                                   ItemSpacing="10" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="services:CottonRecentFileListItem">
                    <Border Style="{StaticResource M3SurfaceCard}"
                            Padding="16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding BindingContext.OpenRecentFileCommand, Source={x:Reference RecentFilesRoot}}"
                                                  CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <Grid RowDefinitions="Auto,Auto"
                              ColumnDefinitions="*,Auto"
                              RowSpacing="6"
                              ColumnSpacing="10">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding FileName}"
                                       Style="{StaticResource M3CardTitle}"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation" />

                                <Label Text="{Binding DetailText}"
                                       Style="{StaticResource M3CardSupporting}"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>

                            <Border Grid.Column="1"
                                    Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="8,3"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerHigh}, Dark={StaticResource M3DarkSurfaceContainerHigh}}"
                                    VerticalOptions="Start">
                                <Label Text="{Binding BadgeText}"
                                       Style="{StaticResource M3ChipLabel}"
                                       MaxLines="1"
                                       LineBreakMode="NoWrap" />
                            </Border>

                            <Button Grid.Column="1"
                                    Grid.Row="1"
                                    Text="Remove"
                                    Style="{StaticResource CompactChromeButton}"
                                    MinimumWidthRequest="74"
                                    HeightRequest="32"
                                    VerticalOptions="Start"
                                    Command="{Binding BindingContext.RemoveRecentFileCommand, Source={x:Reference RecentFilesRoot}}"
                                    CommandParameter="{Binding .}"
                                    SemanticProperties.Description="Remove recent file" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
