<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:services="clr-namespace:Cotton.Mobile.Services;assembly=Cotton.Mobile.Core"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.SecuritySettingsPage"
             x:DataType="viewModels:SecuritySettingsViewModel"
             Shell.NavBarIsVisible="False"
             Title="Security">

    <Grid RowDefinitions="Auto,*">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh security" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Padding="18"
                             Spacing="16">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Security"
                           Style="{StaticResource M3ScreenTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Text="{Binding SummaryText}"
                           Style="{StaticResource M3BodyMedium}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </Grid>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsStatusVisible}"
                   Style="{StaticResource M3BodyMedium}"
                   MaxLines="2"
                   LineBreakMode="TailTruncation" />

            <Border Style="{StaticResource M3SurfaceCard}"
                    Padding="16">
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="6"
                      ColumnSpacing="12">
                    <Label Text="{Binding AppLockTitle}"
                           Style="{StaticResource M3CardTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Grid.Column="1"
                           Text="{Binding AppLockStatusText}"
                           Style="{StaticResource M3CardSupporting}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding AppLockDetailText}"
                           Style="{StaticResource M3CardSupporting}"
                           MaxLines="2"
                           LineBreakMode="TailTruncation" />

                    <Switch Grid.Row="2"
                            Grid.ColumnSpan="2"
                            HorizontalOptions="End"
                            IsEnabled="{Binding CanToggleAppLock}"
                            IsToggled="{Binding IsAppLockEnabled, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource M3SurfaceCard}"
                    Padding="16">
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="6"
                      ColumnSpacing="12">
                    <Label Text="{Binding DeviceUnlockTitle}"
                           Style="{StaticResource M3CardTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Grid.Column="1"
                           Text="{Binding DeviceUnlockStatusText}"
                           Style="{StaticResource M3CardSupporting}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding DeviceUnlockDetailText}"
                           Style="{StaticResource M3CardSupporting}"
                           MaxLines="2"
                           LineBreakMode="TailTruncation" />

                    <Button Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Text="{Binding DeviceUnlockActionText}"
                            Command="{Binding VerifyDeviceUnlockCommand}"
                            IsEnabled="{Binding CanVerifyDeviceUnlock}"
                            IsVisible="{Binding IsDeviceUnlockActionVisible}"
                            Style="{StaticResource M3PrimaryButton}"
                            HorizontalOptions="End" />
                </Grid>
            </Border>

            <Border Style="{StaticResource M3SurfaceCard}"
                    Padding="16"
                    IsVisible="{Binding IsPermissionLedgerVisible}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="6"
                          ColumnSpacing="12">
                        <Label Text="{Binding PermissionLedgerTitle}"
                               Style="{StaticResource M3CardTitle}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />

                        <Label Grid.Column="1"
                               Text="{Binding PermissionLedgerStatusText}"
                               Style="{StaticResource M3CardSupporting}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />

                        <Label Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="{Binding PermissionLedgerDetailText}"
                               Style="{StaticResource M3CardSupporting}"
                               MaxLines="2"
                               LineBreakMode="TailTruncation" />
                    </Grid>

                    <VerticalStackLayout Spacing="10"
                                         BindableLayout.ItemsSource="{Binding PermissionLedgerItems}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="services:CottonPermissionLedgerItem">
                                <Grid ColumnDefinitions="*,Auto"
                                      RowDefinitions="Auto,Auto"
                                      RowSpacing="3"
                                      ColumnSpacing="10">
                                    <Label Text="{Binding Title}"
                                           Style="{StaticResource M3CardSupportingStrong}"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation" />

                                    <Label Grid.Column="1"
                                           Text="{Binding StatusText}"
                                           Style="{StaticResource M3CardSupporting}"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation" />

                                    <Label Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding DetailText}"
                                           Style="{StaticResource M3CardSupporting}"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource M3SurfaceCard}"
                    Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="6"
                          ColumnSpacing="12">
                        <Label Text="{Binding AccountSessionsTitle}"
                               Style="{StaticResource M3CardTitle}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />

                        <Label Grid.Column="1"
                               Text="{Binding AccountSessionsStatusText}"
                               Style="{StaticResource M3CardSupporting}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />

                        <Label Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="{Binding AccountSessionsDetailText}"
                               Style="{StaticResource M3CardSupporting}"
                               MaxLines="2"
                               LineBreakMode="TailTruncation" />
                    </Grid>

                    <Button Text="{Binding RevokeCurrentSessionActionText}"
                            Command="{Binding RevokeCurrentSessionCommand}"
                            IsEnabled="{Binding CanRevokeCurrentSession}"
                            IsVisible="{Binding IsRevokeCurrentSessionVisible}"
                            HorizontalOptions="Start"
                            Style="{StaticResource DestructiveChromeButton}" />

                    <VerticalStackLayout Spacing="2"
                                         IsVisible="{Binding IsAccountSessionsEmptyVisible}">
                        <Label Text="{Binding AccountSessionsEmptyTitle}"
                               Style="{StaticResource M3CardSupportingStrong}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />

                        <Label Text="{Binding AccountSessionsEmptyDetails}"
                               Style="{StaticResource M3CardSupporting}"
                               MaxLines="2"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="12"
                                         IsVisible="{Binding IsAccountSessionsListVisible}"
                                         BindableLayout.ItemsSource="{Binding AccountSessions}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="services:CottonAccountSessionListItem">
                                <Grid ColumnDefinitions="*,Auto"
                                      RowDefinitions="Auto,Auto,Auto,Auto"
                                      RowSpacing="3"
                                      ColumnSpacing="10">
                                    <Label Text="{Binding Title}"
                                           Style="{StaticResource M3CardSupportingStrong}"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation" />

                                    <Border Grid.Column="1"
                                            Style="{StaticResource M3NeutralChip}"
                                            HorizontalOptions="End">
                                        <Label Text="{Binding BadgeText}"
                                               Style="{StaticResource M3ChipLabel}"
                                               MaxLines="1"
                                               LineBreakMode="NoWrap" />
                                    </Border>

                                    <Label Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding DetailText}"
                                           Style="{StaticResource M3CardSupporting}"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation" />

                                    <Label Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding AccessText}"
                                           Style="{StaticResource M3CardSupporting}"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation" />

                                    <Label Grid.Row="3"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding DurationText}"
                                           Style="{StaticResource M3CardSupporting}"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource M3SurfaceCard}"
                    Padding="16">
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="6"
                      ColumnSpacing="12">
                    <Label Text="{Binding LogoutCacheCleanupTitle}"
                           Style="{StaticResource M3CardTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Grid.Column="1"
                           Text="{Binding LogoutCacheCleanupStatusText}"
                           Style="{StaticResource M3CardSupporting}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding LogoutCacheCleanupDetailText}"
                           Style="{StaticResource M3CardSupporting}"
                           MaxLines="2"
                           LineBreakMode="TailTruncation" />

                    <Switch Grid.Row="2"
                            Grid.ColumnSpan="2"
                            HorizontalOptions="End"
                            IsEnabled="{Binding CanToggleLogoutCacheCleanup}"
                            IsToggled="{Binding IsLogoutCacheCleanupEnabled, Mode=TwoWay}" />
                </Grid>
            </Border>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
