<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Cotton.Mobile.Controls"
             xmlns:viewModels="clr-namespace:Cotton.Mobile.ViewModels"
             x:Class="Cotton.Mobile.NotificationSettingsPage"
             x:DataType="viewModels:NotificationSettingsViewModel"
             Shell.NavBarIsVisible="False"
             Title="Notifications"
             BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">

    <Grid RowDefinitions="Auto,*"
          BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurface}, Dark={StaticResource M3DarkSurface}}">
        <controls:TopAppBar IsPrimaryActionVisible="False"
                            SecondaryIconData="{x:Static controls:IconPathData.Refresh}"
                            SecondaryCommand="{Binding LoadCommand}"
                            SecondaryDescription="Refresh notifications" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Padding="18"
                             Spacing="16">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Notifications"
                           Style="{StaticResource M3ScreenTitle}"
                           MaxLines="1"
                           LineBreakMode="TailTruncation" />

                    <Label Text="{Binding EnabledCategoriesText}"
                           FontSize="13"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                </VerticalStackLayout>

                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   VerticalOptions="Center" />
            </Grid>

            <Border IsVisible="{Binding IsAttentionStatusVisible}"
                    Stroke="{AppThemeBinding Light={StaticResource M3LightError}, Dark={StaticResource M3DarkError}}"
                    StrokeShape="RoundRectangle 18"
                    Padding="12"
                    BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="10">
                    <controls:IconView IconData="{x:Static controls:IconPathData.Error}"
                                       IconColor="{AppThemeBinding Light={StaticResource M3LightError}, Dark={StaticResource M3DarkError}}"
                                       IconSize="24"
                                       VerticalOptions="Center" />

                    <Label Grid.Column="1"
                           Text="{Binding Status}"
                           FontSize="13"
                           MaxLines="2"
                           LineBreakMode="TailTruncation"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Button Grid.Column="2"
                            Text="Retry"
                            Command="{Binding LoadCommand}"
                            Style="{StaticResource FileChromeButton}"
                            HeightRequest="36"
                            MinimumWidthRequest="76"
                            Padding="12,0"
                            VerticalOptions="Center" />
                </Grid>
            </Border>

            <Label Text="{Binding Status}"
                   IsVisible="{Binding IsNeutralStatusVisible}"
                   FontSize="13"
                   MaxLines="2"
                   LineBreakMode="TailTruncation"
                   TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

            <Border Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                    StrokeShape="RoundRectangle 18"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="*,Auto"
                      RowSpacing="6"
                      ColumnSpacing="12">
                    <Label Text="{Binding PermissionTitle}"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Label Grid.Column="1"
                           Text="{Binding PermissionStatusText}"
                           FontSize="15"
                           FontAttributes="Bold"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding PermissionDetailText}"
                           FontSize="12"
                           MaxLines="2"
                           LineBreakMode="TailTruncation"
                           TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                    <Button Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Text="{Binding PermissionActionText}"
                            Command="{Binding PermissionActionCommand}"
                            IsVisible="{Binding IsPermissionActionVisible}"
                            Style="{StaticResource FileChromeButton}"
                            HeightRequest="44"
                            HorizontalOptions="Fill" />
                </Grid>
            </Border>

            <Border Stroke="{AppThemeBinding Light={StaticResource M3LightOutlineVariant}, Dark={StaticResource M3DarkOutlineVariant}}"
                    StrokeShape="RoundRectangle 18"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource M3LightSurfaceContainerLow}, Dark={StaticResource M3DarkSurfaceContainerLow}}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <Label Text="Server push"
                               FontSize="15"
                               FontAttributes="Bold"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                        <Label Grid.Column="1"
                               Text="{Binding RemotePushStatusText}"
                               IsVisible="{Binding IsRemotePushStatusVisible}"
                               FontSize="13"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                    </Grid>

                    <Grid IsVisible="{Binding IsRemotePushUnavailable}"
                          ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="8">
                        <controls:IconView IconData="{x:Static controls:IconPathData.Error}"
                                           IconColor="{AppThemeBinding Light={StaticResource M3LightError}, Dark={StaticResource M3DarkError}}"
                                           IconSize="24"
                                           VerticalOptions="Start" />

                        <Label Grid.Column="1"
                               Text="{Binding RemotePushUnavailableTitle}"
                               FontSize="14"
                               FontAttributes="Bold"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                        <Label Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="{Binding RemotePushUnavailableDetail}"
                               FontSize="12"
                               MaxLines="2"
                               LineBreakMode="TailTruncation"
                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />

                        <Button Grid.Row="2"
                                Grid.ColumnSpan="2"
                                Text="Retry"
                                Command="{Binding LoadCommand}"
                                Style="{StaticResource FileChromeButton}"
                                HeightRequest="40"
                                HorizontalOptions="Fill" />
                    </Grid>

                    <VerticalStackLayout Spacing="12"
                                         IsVisible="{Binding HasRemotePushPreferences}"
                                         BindableLayout.ItemsSource="{Binding RemotePushPreferences}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:RemotePushPreferenceItemViewModel">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding Title}"
                                               FontSize="14"
                                               MaxLines="1"
                                               LineBreakMode="TailTruncation"
                                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurface}, Dark={StaticResource M3DarkOnSurface}}" />

                                        <Label Text="{Binding DetailText}"
                                               FontSize="12"
                                               MaxLines="2"
                                               LineBreakMode="TailTruncation"
                                               TextColor="{AppThemeBinding Light={StaticResource M3LightOnSurfaceVariant}, Dark={StaticResource M3DarkOnSurfaceVariant}}" />
                                    </VerticalStackLayout>

                                    <Switch Grid.Column="1"
                                            VerticalOptions="Center"
                                            IsEnabled="{Binding CanToggle}"
                                            IsToggled="{Binding IsEnabled, Mode=TwoWay}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
