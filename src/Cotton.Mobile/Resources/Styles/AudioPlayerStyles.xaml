<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Cotton.Mobile.Controls">

    <Style TargetType="Grid" x:Key="M3AudioPlayerLayer">
        <Setter Property="Padding" Value="{StaticResource M3AudioPlayerPadding}" />
        <Setter Property="BackgroundColor" Value="{StaticResource M3DarkSurfaceDim}" />
    </Style>

    <Style TargetType="VerticalStackLayout" x:Key="M3AudioPlayerStack">
        <Setter Property="Spacing" Value="{StaticResource Space20}" />
        <Setter Property="MaximumWidthRequest" Value="{StaticResource M3AudioPlayerMaxWidth}" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style TargetType="controls:IconFrame" x:Key="M3AudioArtworkFrame">
        <Setter Property="FrameSize" Value="{StaticResource M3AudioArtworkSize}" />
        <Setter Property="IconSize" Value="{StaticResource M3AudioArtworkIconSize}" />
        <Setter Property="FrameCornerRadius" Value="{StaticResource M3AudioArtworkCornerRadius}" />
        <Setter Property="FrameBackgroundColor" Value="{StaticResource M3DarkActionContainer}" />
        <Setter Property="IconColor" Value="{StaticResource M3DarkOnActionContainer}" />
        <Setter Property="BorderColor" Value="{StaticResource M3DarkActionContainer}" />
        <Setter Property="BorderWidth" Value="{StaticResource M3StrokeNone}" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <Style TargetType="VerticalStackLayout" x:Key="M3AudioIdentityStack">
        <Setter Property="Spacing" Value="{StaticResource Space4}" />
    </Style>

    <Style TargetType="Label" x:Key="M3AudioPlayerTitle" BasedOn="{StaticResource M3TitleLarge}">
        <Setter Property="TextColor" Value="{StaticResource M3DarkOnSurface}" />
        <Setter Property="FontFamily" Value="{StaticResource M3FontFamilyMedium}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
        <Setter Property="MaxLines" Value="2" />
    </Style>

    <Style TargetType="Label" x:Key="M3AudioPlayerDetails" BasedOn="{StaticResource M3BodyMedium}">
        <Setter Property="TextColor" Value="{StaticResource M3DarkOnSurfaceVariant}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
        <Setter Property="MaxLines" Value="1" />
    </Style>

    <Style TargetType="VerticalStackLayout" x:Key="M3AudioTimelineStack">
        <Setter Property="Spacing" Value="{StaticResource SpaceNone}" />
    </Style>

    <Style TargetType="Slider" x:Key="M3AudioTimeline">
        <Setter Property="HeightRequest" Value="{StaticResource M3AudioTimelineHeight}" />
        <Setter Property="MinimumTrackColor" Value="{StaticResource M3DarkAction}" />
        <Setter Property="MaximumTrackColor" Value="{StaticResource M3DarkSurfaceContainerHighest}" />
        <Setter Property="ThumbColor" Value="{StaticResource M3DarkAction}" />
    </Style>

    <Style TargetType="Label" x:Key="M3AudioElapsedTime" BasedOn="{StaticResource M3LabelMedium}">
        <Setter Property="TextColor" Value="{StaticResource M3DarkOnSurfaceVariant}" />
        <Setter Property="MinimumWidthRequest" Value="{StaticResource M3AudioTimeLabelMinWidth}" />
        <Setter Property="HorizontalTextAlignment" Value="Start" />
    </Style>

    <Style TargetType="Label" x:Key="M3AudioDuration" BasedOn="{StaticResource M3AudioElapsedTime}">
        <Setter Property="HorizontalTextAlignment" Value="End" />
    </Style>

    <Style TargetType="controls:IconButton" x:Key="M3AudioPlaybackIconButton" BasedOn="{StaticResource M3ViewerCenteredPlayIconButton}" />
</ResourceDictionary>
